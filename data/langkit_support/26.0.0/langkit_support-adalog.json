ile":"langkit_support-adalog.ads","line":79,"column":4},"code":"Trav_Trace : GNATCOLL.Traces.Trace_Handle := GNATCOLL.Traces.Create\n  (\"LANGKIT.SOLVER.TRAVERSAL\", Default => GNATCOLL.Traces.From_Config);","documentation":{"description":"Trace to show when starting the processing of a compound relation in the\nsymbolic solver."}},{"id":"4e81eb1cd184d09d","name":"Verbose_Trace","qualified_name":"Langkit_Support.Adalog.Verbose_Trace","kind":"ada_variable","location":{"file":"langkit_support-adalog.ads","line":71,"column":4},"code":"Verbose_Trace : GNATCOLL.Traces.Trace_Handle := GNATCOLL.Traces.Create\n  (\"LANGKIT.SOLVER.VERBOSE\", Default => GNATCOLL.Traces.From_Config);","documentation":{"description":"Trace to show when:\n\n* a variable gets assigned a value;\n* a variable gets assigned an Id;\n* a variable gets (un)aliased."}}],"exceptions":[{"id":"ee9d09741d75684c","name":"Early_Binding_Error","qualified_name":"Langkit_Support.Adalog.Early_Binding_Error","kind":"ada_exception","location":{"file":"langkit_support-adalog.ads","line":45,"column":4},"code":"Early_Binding_Error : exception;","documentation":{"description":"Exception raised when an equation cannot be solved because a logic\nvariable is referenced but is never assigned a value."}},{"id":"f4d9f1cba254a3ab","name":"Timeout_Error","qualified_name":"Langkit_Support.Adalog.Timeout_Error","kind":"ada_exception","location":{"file":"langkit_support-adalog.ads","line":49,"column":4},"code":"Timeout_Error : exception;","documentation":{"description":"Exception raised when the resolution of a complex relation exceeded the\nnumber of steps allowed."}}]}