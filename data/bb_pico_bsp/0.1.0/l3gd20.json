e_Axis_Gyroscope)","documentation":{"description":"See App Note 4505, pg 15, Figure 5 and Table 9 for the concept. Enables\nthe low pass filter LPF2 in the diagrams, for output to the data\nregisters and the FIFO. The value of LPF2 is determined by the output\ndata rate and bandwidth selections specified when calling procedure\nConfigure. These values are shown in the App Note, pg 16, Table 11.\nThe filter allows frequencies lower than the LPF2 \"cutoff\" value, and\nattenuates those at or above the cutoff. Note that the high pass filter\nis independent of the low pass filter.","parameters":[{"name":"This","description":""}]}},{"id":"1b31b08c8de8d8f5","name":"FIFO_Below_Watermark","qualified_name":"L3GD20.FIFO_Below_Watermark","kind":"ada_function","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_components_0.1.0_1f29afaf/7389c20513aed6b60277452010e3c9b50fb267e66d1e833acd403f1466b26782/src/motion/l3gd20/l3gd20.ads","line":353,"column":13},"code":"function FIFO_Below_Watermark (This : Three_Axis_Gyroscope) return Boolean"},{"id":"e526947c9c20cac9","name":"FIFO_Empty","qualified_name":"L3GD20.FIFO_Empty","kind":"ada_function","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_components_0.1.0_1f29afaf/7389c20513aed6b60277452010e3c9b50fb267e66d1e833acd403f1466b26782/src/motion/l3gd20/l3gd20.ads","line":355,"column":13},"code":"function FIFO_Empty (This : Three_Axis_Gyroscope) return Boolean"},{"id":"a5547ec0a5b53e5a","name":"FIFO_Overrun","qualified_name":"L3GD20.FIFO_Overrun","kind":"ada_function","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_components_0.1.0_1f29afaf/7389c20513aed6b60277452010e3c9b50fb267e66d1e833acd403f1466b26782/src/motion/l3gd20/l3gd20.ads","line":357,"column":13},"code":"function FIFO_Overrun (This : Three_Axis_Gyroscope) return Boolean"},{"id":"1965c3e342928bcc","name":"Full_Scale_Sensitivity","qualified_name":"L3GD20.Full_Scale_Sensitivity","kind":"ada_function","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_components_0.1.0_1f29afaf/7389c20513aed6b60277452010e3c9b50fb267e66d1e833acd403f1466b26782/src/motion/l3gd20/l3gd20.ads","line":179,"column":13},"code":"function Full_Scale_Sensitivity (This : Three_Axis_Gyroscope) return Float","documentation":{"description":"Returns the sensitivity per LSB based on the Full_Scale_Selection\nspecified to procedure Configure. Used to scale raw angle rates. Note\nthat the values are already in terms of millidegrees per second per\ndigit, so to use these values you should multiply, rather than divide.\nNB: These values are not measured on the specific device on the board\nin use. Instead, they are statistical averages determined at the factory\nfor this component family, so you will likely need to tweak them a bit.","parameters":[{"name":"This","description":""}]}},{"id":"072abc345af34063","name":"Get_Raw_Angle_Rates","qualified_name":"L3GD20.Get_Raw_Angle_Rates","kind":"ada_procedure","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_components_0.1.0_1f29afaf/7389c20513aed6b60277452010e3c9b50fb267e66d1e833acd403f1466b26782/src/motion/l3gd20/l3gd20.ads","line":302,"column":14},"code":"procedure Get_Raw_Angle_Rates\n  (This  : Three_Axis_Gyroscope;\n   Rates : out Angle_Rates)","documentation":{"description":"Returns the latest data, swapping UInt8s if required by the endianess\nselected by a previous call to Configure.\nNB: does NOT check whether the gyro status indicates data are ready.\nNB: does NOT apply any sensitity scaling.","parameters":[{"name":"This","description":""},{"name":"Rates","description":""}]}},{"id":"21138081d4606498","name":"Get_Raw_Angle_Rates_FIFO","qualified_name":"L3GD20.Get_Raw_Angle_Rates_FIFO","kind":"ada_procedure","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_components_0.1.0_1f29afaf/7389c20513aed6b60277452010e3c9b50fb267e66d1e833acd403f1466b26782/src/motion/l3gd20/l3gd20.ads","line":342,"column":14},"code":"procedure Get_Raw_Angle_Rates_FIFO\n  (This   : in out Three_Axis_Gyroscope;\n   Buffer : out Angle_Rates_FIFO_Buffer)","documentation":{"description":"Returns the latest raw data in the FIFO, swapping UInt8s if required by\nthe endianess selected by a previous call to Configure. Fills the entire\nbuffer passed.\nNB: does NOT apply any sensitity scaling.","parameters":[{"name":"This","description":""},{"name":"Buffer","description":""}]}},{"id":"c019929fae1d4d67","name":"Initialize","qualified_name":"L3GD20.Initialize","kind":"ada_procedure","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_components_0.1.0_1f29afaf/7389c20513aed6b60277452010e3c9b50fb267e66d1e833acd403f1466b26782/src/motion/l3gd20/l3gd20.ads","line":59,"column":14},"code":"procedure Initialize\n  (This        : in out Three_Axis_Gyroscope;\n   Port        : Any_SPI_Port;\n   Chip_Select : Any_GPIO_Point)","documentation":{"description":"Does device-specific initialization. Must be called prior to use.\n\nNB: does NOT init/configure SPI and GPIO IO, which must be done\n(elsewhere) prior to calling this routine.","parameters":[{"name":"This","description":""},{"name":"Port","description":""},{"name":"Chip_Select","description":""}]}},{"id":"62df715291ef4245","name":"Interrupt1_Source","qualified_name":"L3GD20.Interrupt1_Source","kind":"ada_function","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_components_0.1.0_1f29afaf/7389c20513aed6b60277452010e3c9b50fb267e66d1e833acd403f1466b26782/src/motion/l3gd20/l3gd20.ads","line":508,"column":13},"code":"function Interrupt1_Source (This : Three_Axis_Gyroscope) return Interrupt1_Sources"},{"id":"24a249a2ef9b716d","name":"Reboot","qualified_name":"L3GD20.Reboot","kind":"ada_procedure","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_components_0.1.0_1f29afaf/7389c20513aed6b60277452010e3c9b50fb267e66d1e833acd403f1466b26782/src/motion/l3gd20/l3gd20.a