tion":{"file":"src/den.ads","line":233,"column":13},"code":"function Canonical_Parent (This : Path) return Canonical_Path"},{"id":"581b8691f093d371","name":"Canonizable","qualified_name":"Den.Canonizable","kind":"ada_function","location":{"file":"src/den.ads","line":204,"column":13},"code":"function Canonizable (This : String) return Boolean","documentation":{"description":"Says if Canonical (This) will succeed.","parameters":[{"name":"This","description":""}]}},{"id":"be4a737d452a4c8a","name":"Contains_Parts","qualified_name":"Den.Contains_Parts","kind":"ada_function","location":{"file":"src/den.ads","line":95,"column":13},"code":"function Contains_Parts (This : AAA.Strings.Vector) return Boolean"},{"id":"7230817e6e5692e2","name":"Contains_Paths","qualified_name":"Den.Contains_Paths","kind":"ada_function","location":{"file":"src/den.ads","line":70,"column":13},"code":"function Contains_Paths (This : AAA.Strings.Set) return Boolean"},{"id":"0e219ab8ff2b4814","name":"Dir_Separator","qualified_name":"Den.Dir_Separator","kind":"ada_function","location":{"file":"src/den.ads","line":20,"column":13},"code":"function Dir_Separator return Character"},{"id":"48576b28cdb38448","name":"Driveless_Root","qualified_name":"Den.Driveless_Root","kind":"ada_function","location":{"file":"src/den.ads","line":42,"column":13},"code":"function Driveless_Root return Absolute_Path","documentation":{"description":"The root of the filesystem in Unix-like (/), the current drive root (\\)\non Windows without the actual drive (\\)."}},{"id":"1d1c44f0779510f1","name":"Exists","qualified_name":"Den.Exists","kind":"ada_function","location":{"file":"src/den.ads","line":157,"column":13},"code":"function Exists (This : Path; Resolve_Links : Boolean := False)\n                 return Boolean"},{"id":"032751cefc13f395","name":"Explain","qualified_name":"Den.Explain","kind":"ada_function","location":{"file":"src/den.ads","line":142,"column":13},"code":"function Explain (This : Path) return String","docum