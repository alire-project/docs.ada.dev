{"schema_version":"1","crate":"light_stm32g0xx","version":"15.0.1","id":"1853790f7dda8b92","name":"Ada.Characters.Handling","qualified_name":"Ada.Characters.Handling","kind":"ada_package","location":{"file":"gnat/a-chahan.ads","line":43,"column":9},"code":"package Ada.Characters.Handling","documentation":{"description":"--------------------------------------\n Character Classification Functions --\n--------------------------------------"},"subtypes":[{"id":"2477a11ab800e55c","name":"ISO_646","qualified_name":"Ada.Characters.Handling.ISO_646","kind":"ada_subtype","location":{"file":"gnat/a-chahan.ads","line":305,"column":12},"code":"subtype ISO_646 is\n  Character range Character'Val (0) .. Character'Val (127);"}],"subprograms":[{"id":"ab5dffe9523371be","name":"Is_Alphanumeric","qualified_name":"Ada.Characters.Handling.Is_Alphanumeric","kind":"ada_function","location":{"file":"gnat/a-chahan.ads","line":138,"column":13},"code":"function Is_Alphanumeric          (Item : Character) return Boolean","documentation":{"description":"True if Item is an alphanumeric character. An alphanumeric character is\na character that is either a letter or a decimal digit.","parameters":[{"name":"Item","description":""}]}},{"id":"4861457cbfc05f85","name":"Is_Basic","qualified_name":"Ada.Characters.Handling.Is_Basic","kind":"ada_function","location":{"file":"gnat/a-chahan.ads","line":103,"column":13},"code":"function Is_Basic                 (Item : Character) return Boolean","documentation":{"description":"True if Item is a basic letter. A basic letter is a character that\nis in one of the ranges 'A'..'Z' and 'a'..'z', or that is one of\nthe following: UC_AE_Diphthong, LC_AE_Diphthong, UC_Icelandic_Eth,\nLC_Icelandic_Eth, UC_Icelandic_Thorn, LC_Icelandic_Thorn, or\nLC_German_Sharp_S.","parameters":[{"name":"Item","description":""}]}},{"id":"e055594f2ec5179c","name":"Is_Character","qualified_name":"Ada.Characters.Handling.Is_Character","kind":"ada_function","location":{"file":"gnat/a-chahan.ads","line":358,"column":13},"code":"function Is_Character (Item : Wide_Character) return Boolean","documentation":{"description":"Returns True if Wide_Character'Pos(Item) <=\nCharacter'Pos(Character'Last).","parameters":[{"name":"Item","description":""}]}},{"id":"66f727386c192267","name":"Is_Control","qualified_name":"Ada.Characters.Handling.Is_Control","kind":"ada_function","location":{"file":"gnat/a-chahan.ads","line":62,"column":13},"code":"function Is_Control               (Item : Character) return Boolean","documentation":{"description":"True if Item is a control character. A control character is a character\nwhose position is in one of the ranges 0..31 or 127..159.","parameters":[{"name":"Item","description":""}]}},{"id":"e2d99c263a2668d1","name":"Is_Decimal_Digit","qualified_name":"Ada.Characters.Handling.Is_Decimal_Digit","kind":"ada_function","location":{"file":"gnat/a-chahan.ads","line":127,"column":13},"code":"function Is_Decimal_Digit         (Item : Character) return Boolean"},{"id":"5368b4857b6678f5","name":"Is_Digit","qualified_name":"Ada.Characters.Handling.Is_Digit","kind":"ada_function","location":{"file":"gnat/a-chahan.ads","line":121,"column":13},"code":"function Is_Digit                 (Item : Character) return Boolean","documentation":{"description":"True if Item is a decimal digit. A decimal digit is a character in the\nrange '0'..'9'.","parameters":[{"name":"Item","description":""}]}},{"id":"f9a2b7986e071e47","name":"Is_Graphic","qualified_name":"Ada.Characters.Handling.Is_Graphic","kind":"ada_function","location":{"file":"gnat/a-chahan.ads","line":69,"column":13},"code":"function Is_Graphic               (Item : Character) return Boolean","documentation":{"description":"True if Item is a graphic character. A graphic character is a character\nwhose position is in one of the ranges 32..126 or 160..255.","parameters":[{"name":"Item","description":""}]}},{"id":"16fe3b498b2f2c77","name":"Is_Hexadecimal_Digit","qualified_name":"Ada.Characters.Handling.Is_Hexadecimal_Digit","kind":"ada_function","location":{"file":"gnat/a-chahan.ads","line":130,"column":13},"code":"function Is_Hexadecimal_Digit     (Item : Character) return Boolean","documentation":{"description":"True if Item is a hexadecimal digit. A hexadecimal digit is a character\nthat is either a decimal digit or that is in one of the ranges 'A'..'F'\nor 'a'..'f'.","parameters":[{"name":"Item","description":""}]}},{"id":"028c8f438105788a","name":"Is_ISO_646","qualified_name":"Ada.Characters.Handling.Is_ISO_646","kind":"ada_function","location":{"file":"gnat/a-chahan.ads","line":308,"column":13},"code":"function Is_ISO_646 (Item : Character) return Boolean","documentation":{"description":"The function whose formal parameter, Item, is of type Character returns\nTrue if Item is in the subtype ISO_646.","parameters":[{"name":"Item","description":""}]}},{"id":"09d51de8c74395c2","name":"Is_ISO_646","qualified_name":"Ada.Characters.Handling.Is_ISO_646","kind":"ada_function","location":{"file":"gnat/a-chahan.ads","line":314,"column":13},"code":"function Is_ISO_646 (Item : String)    return Boolean","documentation":{"description":"The function whose formal parameter, Item, is of type String returns\nTrue if Is_ISO_646(Item(I)) is True for each I in Item'Range.","parameters":[{"name":"Item","description":""}]}},{"id":"9c70b258d2835c6a","name":"Is_Letter","qualified_name":"Ada.Characters.Handling.Is_Letter","kind":"ada_function","location":{"file":"gnat/a-chahan.ads","line":76,"column":13},"code":"function Is_Letter                (Item : Character) return Boolean","documentation":{"description":"True if Item is a letter. A letter is a character that is in one of the\nranges 'A'..'Z' or 'a'..'z', or whose position is in one of the ranges\n192..214, 216..246, or 248..255.","parameters":[{"name":"Item","description":""}]}},{"id":"3aaac73ae83b7a19","name":"Is_Line_Terminator","qualified_name":"Ada.Characters.Handling.Is_Line_Terminator","kind":"ada_function","location":{"file":"gnat/a-chahan.ads","line":152,"column":13},"code":"function Is_Line_Terminator       (Item : Character) return Boolean","documentation":{"description":"True if Item is a character with position 10..13 (Line_Feed,\nLine_Tabulation, Form_Feed, Carriage_Return) or 133 (Next_Line).","parameters":[{"name":"Item","description":""}]}},{"id":"f85d66ce6700e30d","name":"Is_Lower","qualified_name":"Ada.Characters.Handling.Is_Lower","kind":"ada_function","location":{"file":"gnat/a-chahan.ads","line":85,"column":13},"code":"function Is_Lower                 (Item : Character) return Boolean","documentation":{"description":"True if Item is a lower-case letter. A lower-case letter is a character\nthat is in the range 'a'..'z', or whose position is in one of the ranges\n223..246 or 248..255.","parameters":[{"name":"Item","description":""}]}},{"id":"16ab87c1e6cfdd36","name":"Is_Mark","qualified_name":"Ada.Characters.Handling.Is_Mark","kind":"ada_function","location":{"file":"gnat/a-chahan.ads","line":159,"column":13},"code":"function Is_Mark                  (Item : Character) return Boolean","documentation":{"description":"Never True (no value of type Character has categories Mark, Non-Spacing\nor Mark, Spacing Combining).","parameters":[{"name":"Item","description":""}]}},{"id":"fbf3e533ea7207e1","name":"Is_NFKC","qualified_name":"Ada.Characters.Handling.Is_NFKC","kind":"ada_function","location":{"file":"gnat/a-chahan.ads","line":183,"column":13},"code":"function Is_NFKC                  (Item : Character) return Boolean","documentation":{"description":"True if Item could be present in a string normalized to Normalization\nForm KC (as defined by Clause 21 of ISO/IEC 10646:2017); this includes\nall characters except those with positions 160, 168, 170, 175, 178, 179,\n180, 181, 184, 185, 186, 188, 189, and 190.","parameters":[{"name":"Item","description":""}]}},{"id":"5eb857874c792e2b","name":"Is_Other_Format","qualified_name":"Ada.Characters.Handling.Is_Other_Format","kind":"ada_function","location":{"file":"gnat/a-chahan.ads","line":165,"column":13},"code":"function Is_Other_Format          (Item : Character) return Boolean","documentation":{"description":"True if Item is a character with position 173 (Soft_Hyphen).","parameters":[{"name":"Item","description":""}]}},{"id":"1bf058dfac6a8218","name":"Is_Punctuation_Connector","qualified_name":"Ada.Characters.Handling.Is_Punctuation_Connector","kind":"ada_function","location":{"file":"gnat/a-chahan.ads","line":170,"column":13},"code":"function Is_Punctuation_Connector (Item : Character) return Boolean","documentation":{"description":"True if Item is a character with position 95 ('_', known as Low_Line or\nUnderscore).","parameters":[{"name":"Item","description":""}]}},{"id":"41a23f0864de4a5a","name":"Is_Space","qualified_name":"Ada.Characters.Handling.Is_Space","kind":"ada_function","location":{"file":"gnat/a-chahan.ads","line":177,"column":13},"code":"function Is_Space                 (Item : Character) return Boolean","documentation":{"description":"True if Item is a character with position 32 (' ') or 160\n(No_Break_Space).","parameters":[{"name":"Item","description":""}]}},{"id":"d848f9427976a423","name":"Is_Special","qualified_name":"Ada.Characters.Handling.Is_Special","kind":"ada_function","location":{"file":"gnat/a-chahan.ads","line":145,"column":13},"code":"function Is_Special               (Item : Character) return Boolean","documentation":{"description":"True if Item is a special graphic character. A special graphic character\nis a graphic character that is not alphanumeric.","parameters":[{"name":"Item","description":""}]}},{"id":"1489a1a46548aa1c","name":"Is_String","qualified_name":"Ada.Characters.Handling.Is_String","kind":"ada_function","location":{"file":"gnat/a-chahan.ads","line":365,"column":13},"code":"function Is_String    (Item : Wide_String)    return Boolean","documentation":{"description":"Returns True if Is_Character(Item(I)) is True for each I in Item'Range.","parameters":[{"name":"Item","description":""}]}},{"id":"5d5cc1c86de55fd4","name":"Is_Upper","qualified_name":"Ada.Characters.Handling.Is_Upper","kind":"ada_function","location":{"file":"gnat/a-chahan.ads","line":94,"column":13},"code":"function Is_Upper                 (Item : Character) return Boolean","documentation":{"description":"True if Item is an upper-case letter. An upper-case letter is a\ncharacter that is in the range 'A'..'Z' or whose position is in one\nof the ranges 192..214 or 216..222.","parameters":[{"name":"Item","description":""}]}},{"id":"0cfc6282f6fcf1c2","name":"To_Basic","qualified_name":"Ada.Characters.Handling.To_Basic","kind":"ada_function","location":{"file":"gnat/a-chahan.ads","line":244,"column":13},"code":"function To_Basic (Item : Character) return Character","documentation":{"description":"Returns the letter corresponding to Item but with no diacritical mark,\nif Item is a letter but not a basic letter; returns Item otherwise.","parameters":[{"name":"Item","description":""}]}},{"id":"389444658ef9a8b3","name":"To_Basic","qualified_name":"Ada.Characters.Handling.To_Basic","kind":"ada_function","location":{"file":"gnat/a-chahan.ads","line":290,"column":13},"code":"function To_Basic (Item : String) return String"},{"id":"7d7c0d7e4ea39eaf","name":"To_Character","qualified_name":"Ada.Characters.Handling.To_Character","kind":"ada_function","location":{"file":"gnat/a-chahan.ads","line":384,"column":13},"code":"function To_Character\n  (Item       : Wide_Character;\n   Substitute : Character := ' ') return Character","documentation":{"description":"Returns the Character corresponding to Item if Is_Character(Item), and\nreturns the Substitute Character otherwise.","parameters":[{"name":"Item","description":""},{"name":"Substitute","description":""}]}},{"id":"782e6b3c48efed88","name":"To_ISO_646","qualified_name":"Ada.Characters.Handling.To_ISO_646","kind":"ada_function","location":{"file":"gnat/a-chahan.ads","line":321,"column":13},"code":"function To_ISO_646\n  (Item       : Character;\n   Substitute : ISO_646 := ' ') return ISO_646","documentation":{"description":"The function whose first formal parameter, Item, is of type Character\nreturns Item if Is_ISO_646(Item), and returns the Substitute ISO_646\ncharacter otherwise.","parameters":[{"name":"Item","description":""},{"name":"Substitute","description":""}]}},{"id":"73e88d09da89971c","name":"To_ISO_646","qualified_name":"Ada.Characters.Handling.To_ISO_646","kind":"ada_function","location":{"file":"gnat/a-chahan.ads","line":331,"column":13},"code":"function To_ISO_646\n  (Item       : String;\n   Substitute : ISO_646 := ' ') return String","documentation":{"description":"The function whose first formal parameter, Item, is of type String\nreturns the String whose Range is 1..Item'Length and each of whose\nelements is given by To_ISO_646 of the corresponding element in Item.","parameters":[{"name":"Item","description":""},{"name":"Substitute","description":""}]}},{"id":"e995013b912c5d27","name":"To_Lower","qualified_name":"Ada.Characters.Handling.To_Lower","kind":"ada_function","location":{"file":"gnat/a-chahan.ads","line":209,"column":13},"code":"function To_Lower (Item : Character) return Character","documentation":{"description":"Returns the corresponding lower-case value for Item if Is_Upper(Item),\nand returns Item otherwise.","parameters":[{"name":"Item","description":""}]}},{"id":"62b69e5a909d5747","name":"To_Lower","qualified_name":"Ada.Characters.Handling.To_Lower","kind":"ada_function","location":{"file":"gnat/a-chahan.ads","line":274,"column":13},"code":"function To_Lower (Item : String) return String"},{"id":"8e5b542fbf648f7f","name":"To_String","qualified_name":"Ada.Characters.Handling.To_String","kind":"ada_function","location":{"file":"gnat/a-chahan.ads","line":396,"column":13},"code":"function To_String\n  (Item       : Wide_String;\n   Substitute : Character := ' ') return String","documentation":{"description":"Returns the String whose range is 1..Item'Length and each of whose\nelements is given by To_Character of the corresponding element in Item.","parameters":[{"name":"Item","description":""},{"name":"Substitute","description":""}]}},{"id":"b82c48f50538f4d1","name":"To_Upper","qualified_name":"Ada.Characters.Handling.To_Upper","kind":"ada_function","location":{"file":"gnat/a-chahan.ads","line":224,"column":13},"code":"function To_Upper (Item : Character) return Character","documentation":{"description":"Returns the corresponding upper-case value for Item if Is_Lower(Item)\nand Item has an upper-case form, and returns Item otherwise. The lower\ncase letters LC_German_Sharp_S and LC_Y_Diaeresis do not have upper case\nforms.","parameters":[{"name":"Item","description":""}]}},{"id":"400271699f58b7f7","name":"To_Upper","qualified_name":"Ada.Characters.Handling.To_Upper","kind":"ada_function","location":{"file":"gnat/a-chahan.ads","line":282,"column":13},"code":"function To_Upper (Item : String) return String"},{"id":"44fde519a3034a12","name":"To_Wide_Character","qualified_name":"Ada.Characters.Handling.To_Wide_Character","kind":"ada_function","location":{"file":"gnat/a-chahan.ads","line":409,"column":13},"code":"function To_Wide_Character\n  (Item : Character) return Wide_Character","documentation":{"description":"Returns the Wide_Character X such that Character'Pos(Item) =\nWide_Character'Pos (X).","parameters":[{"name":"Item","description":""}]}},{"id":"ca07c1ce6184bb1e","name":"To_Wide_String","qualified_name":"Ada.Characters.Handling.To_Wide_String","kind":"ada_function","location":{"file":"gnat/a-chahan.ads","line":417,"column":13},"code":"function To_Wide_String\n  (Item : String) return Wide_String","documentation":{"description":"Returns the Wide_String whose range is 1..Item'Length and each of whose\nelements is given by To_Wide_Character of the corresponding element in\nItem.","parameters":[{"name":"Item","description":""}]}}]}