","documentation":{"description":"Return image of file Fname time stamp.","parameters":[{"name":"Fname","description":""}]}},{"id":"1239ef056da7f0e6","name":"Increment_Indentation","qualified_name":"XE_IO.Increment_Indentation","kind":"ada_procedure","location":{"file":"../Dist/xe_io.ads","line":187,"column":14},"code":"procedure Increment_Indentation"},{"id":"24093c6c2ffcb25f","name":"Is_Directory","qualified_name":"XE_IO.Is_Directory","kind":"ada_function","location":{"file":"../Dist/xe_io.ads","line":55,"column":13},"code":"function Is_Directory    (Fname : File_Name_Type) return Boolean"},{"id":"f1c327b84ba9714a","name":"Is_Predefined_File","qualified_name":"XE_IO.Is_Predefined_File","kind":"ada_function","location":{"file":"../Dist/xe_io.ads","line":93,"column":13},"code":"function Is_Predefined_File (Fname : File_Name_Type) return Boolean","documentation":{"description":"Return True when Fname belongs to Ada, GNAT, Interfaces or\nSystem hierarchy.","parameters":[{"name":"Fname","description":""}]}},{"id":"1a3a0d65c6c71d8c","name":"Is_Regular_File","qualified_name":"XE_IO.Is_Regular_File","kind":"ada_function","location":{"file":"../Dist/xe_io.ads","line":56,"column":13},"code":"function Is_Regular_File (Fname : File_Name_Type) return Boolean"},{"id":"e4c162bcb26eab6c","name":"Message","qualified_name":"XE_IO.Message","kind":"ada_procedure","location":{"file":"../Dist/xe_io.ads","line":126,"column":14},"code":"procedure Message\n  (S1 : String  := No_Str;\n   S2 : Name_Id := No_Name;\n   S3 : String  := No_Str;\n   S4 : Name_Id := No_Name;\n   S5 : String  := No_Str)","documentation":{"description":"Display a message to the standard output. The message is the\nconcatenation of S1 to S5. Parameters with default values are not\ndisplayed.","parameters":[{"name":"S1","description":""},{"name":"S2","description":""},{"name":"S3","description":""},{"name":"S4","description":""},{"name":"S5","description":""}]}},{"id":"95b5d79b3a6cefb4","name":"Normalize_CWD","qualified_name":"XE_IO.Normalize_CWD","kind":"ada_function","location":{"file":"../Dist/xe_io.ads","line":86,"column":13},"code":"function Normalize_CWD (F : File_Name_Type) return File_Name_Type","documentation":{"description":"Remove any leading CWD (./)","parameters":[{"name":"F","description":""}]}},{"id":"43629189acfa6ac5","name":"Read_File","qualified_name":"XE_IO.Read_File","kind":"ada_procedure","location":{"file":"../Dist/xe_io.ads","line":197,"column":14},"code":"procedure Read_File\n  (Fname  : File_Name_Type;\n   First  : out Text_Ptr;\n   Last   : out Text_Ptr;\n   Buffer : out Text_Buffer_Ptr)"},{"id":"d6fb2e8f2fba4913","name":"Register_Temp_File","qualified_name":"XE_IO.Register_Temp_File","kind":"ada_procedure","location":{"file":"../Dist/xe_io.ads","line":104,"column":14},"code":"procedure Register_Temp_File\n  (File  : out File_Descriptor;\n   Fname : in out File_Name_Type)","documentation":{"description":"When Fname is null, create a new temporary file. Otherwise,\nconsidere Fname as a temporary file and therefore remove it\nwhen Remove_All_Temporary_Files is invoked.","parameters":[{"name":"File","description":""},{"name":"Fname","description":""}]}},{"id":"d3e7924a9bef6fcf","name":"Register_Temp_File","qualified_name":"XE_IO.Register_Temp_File","kind":"ada_procedure","location":{"file":"../Dist/xe_io.ads","line":111,"column":14},"code":"procedure Register_Temp_File\n  (Fname : File_Name_Type)","documentation":{"description":"Insert Fname in the list of temporary files","parameters":[{"name":"Fname","description":""}]}},{"id":"d425a9f20967aec0","name":"Remove_All_Temp_Files","qualified_name":"XE_IO.Remove_All_Temp_Files","kind":"ada_procedure","location":{"file":"../Dist/xe_io.ads","line":119,"column":14},"code":"procedure Remove_All_Temp_Files","documentation":{"description":"Remove all the files registered as temporary files"}},{"id":"596485a27a938cd0","name":"Remove_Temp_File","qualified_name":"XE_IO.Remove_Temp_File","kind":"ada_procedure","location":{"file":"../Dist/xe_io.ads","line":115,"column":14},"code":"procedure Remove_Temp_File\n  (Fname : File_Name_Type)","documentation":{"description":"Remove Fname file and remove it in the temporary files list","parameters":[{"name":"Fname","description":""}]}},{"id":"ad7c2ae8557695bf","name":"Set_Output","qualified_name":"XE_IO.Set_Output","kind":"ada_procedure","location":{"file":"../Dist/xe_io.ads","line":145,"column":14},"code":"procedure Set_Output (New_Output : GNAT.OS_Lib.File_Descriptor)","documentation":{"description":"Sets subsequent output to appear on the given file","parameters":[{"name":"New_Output","description":""}]}},{"id":"75c2e9fd8add5de6","name":"Set_Space_Increment","qualified_name":"XE_IO.Set_Space_Increment","kind":"ada_procedure","location":{"file":"../Dist/xe_io.ads","line":189,"column":14},"code":"procedure Set_Space_Increment (Value : Natural)"},{"id":"d8e5534261e287da","name":"Set_Standard_Error","qualified_name":"XE_IO.Set_Standard_Error","kind":"ada_procedure","location":{"file":"../Dist/xe_io.ads","line":148,"column":14},"code":"procedure Set_Standard_Error","documentation":{"description":"Sets subsequent output to appear on the standard error file\n(whatever that might mean for the host operating system, if\nanything)."}},{"id":"e553df812416cea8","name":"Set_Standard_Output","qualified_name":"XE_IO.Set_Standard_Output","kind":"ada_procedure","location":{"file":"../Dist/xe_io.ads","line":153,"column":14},"code":"procedure Set_Standard_Output","documentation":{"description":"Sets subsequent output to appear on the standard output file\n(whatever that might mean for the host operating system, if\nanything). Output to standard output is the default mode before\nany call to either of the Set procedures."}},{"id":"334245b5e5450634","name":"Strip_Directory","qualified_name":"XE_IO.Strip_Directory","kind":"ada_function","location":{"file":"../Dist/xe_io.ads","line":74,"column":13},"code":"function Strip_Directory (Fname : String) return String","documentation":{"description":"Strips the prefix directory name (if any) from Name. Returns the\nstripped name. Name cannot end with a directory separator.","parameters":[{"name":"Fname","description":""}]}},{"id":"a5b991612ffb88ce","name":"Strip_Directory","qualified_name":"XE_IO.Strip_Directory","kind":"ada_function","location":{"file":"../Dist/xe_io.ads","line":75,"column":13},"code":"function Strip_Directory (Fname : File_Name_Type) return File_Name_Type","documentation":{"description":"Strips the prefix directory name (if any) from Name. Returns the\nstripped name. Name cannot end with a directory separator.","parameters":[{"name":"Fname","description":""}]}},{"id":"104f7b2615dfc39c","name":"Strip_Exec_Suffix","qualified_name":"XE_IO.Strip_Exec_Suffix","kind":"ada_function","location":{"file":"../Dist/xe_io.ads","line":83,"column":13},"code":"function Strip_Exec_Suffix (Fname : File_Name_Type) return File_Name_Type","documentation":{"description":"When suffix is an executable suffix, strip it","parameters":[{"name":"Fname","description":""}]}},{"id":"bb4260a74d241ffd","name":"Strip_Suffix","qualified_name":"XE_IO.Strip_Suffix","kind":"ada_function","location":{"file":"../Dist/xe_io.ads","line":79,"column":13},"code":"function Strip_Suffix (Fname : File_Name_Type) return File_Name_Type","documentation":{"description":"Strips the suffix (the last '.' and whatever comes after it) from Name.\nReturns the stripped name.","parameters":[{"name":"Fname","description":""}]}},{"id":"47c988514157fbe4","name":"To_Absolute_File","qualified_name":"XE_IO.To_Absolute_File","kind":"ada_function","location":{"file":"../Dist/xe_io.ads","line":58,"column":13},"code":"function To_Absolute_File (Fname : File_Name_Type) return File_Name_Type","documentation":{"description":"When the directory corresponding to Fname is already an\nabsolute directory, return Fname. Otherwise, prefix Fname by\nthe current directory.","parameters":[{"name":"Fname","description":""}]}},{"id":"c7ebd232eb1cdfb5","name":"To_Afile","qualified_name":"XE_IO.To_Afile","kind":"ada_function","location":{"file":"../Dist/xe_io.ads","line":89,"column":13},"code":"function To_Afile (Fname : File_Name_Type) return File_Name_Type","documentation":{"description":"Strip suffix and add resp. ALI suffix or object suffix","parameters":[{"name":"Fname","description":""}]}},{"id":"519b077f50c04187","name":"To_Ofile","qualified_name":"XE_IO.To_Ofile","kind":"ada_function","location":{"file":"../Dist/xe_io.ads","line":90,"column":13},"code":"function To_Ofile (Fname : File_Name_Type) return File_Name_Type","documentation":{"description":"Strip suffix and add resp. ALI suffix or object suffix","parameters":[{"name":"Fname","description":""}]}},{"id":"f27fd98a617cfd92","name":"Write_Char","qualified_name":"XE_IO.Write_Char","kind":"ada_procedure","location":{"file":"../Dist/xe_io.ads","line":159,"column":14},"code":"procedure Write_Char (C : Character)","documentation":{"description":"Write one character to the standard output file. Note that the\ncharacter should not be LF or CR (use Write_Eol for end of line)","parameters":[{"name":"C","description":""}]}},{"id":"d96d4c5067107f7c","name":"Write_Eol","qualified_name":"XE_IO.Write_Eol","kind":"ada_procedure","location":{"file":"../Dist/xe_io.ads","line":163,"column":14},"code":"procedure Write_Eol (N : Natural := 1)","documentation":{"description":"Write an end of line (whatever is required by the system in use,\ne.g. CR/LF for DOS, or LF for Unix) to the standard output file.\nThis routine also empties the line buffer, actually writing it\nto the file. Note that Write_Eol is the only routine that causes\nany actual output to be written.","parameters":[{"name":"N","description":""}]}},{"id":"4cdad4e7cf2948ac","name":"Write_Indentation","qualified_name":"XE_IO.Write_Indentation","kind":"ada_procedure","location":{"file":"../Dist/xe_io.ads","line":190,"column":14},"code":"procedure Write_Indentation (Offset : Integer := 0)"},{"id":"aff4790ee5db39f3","name":"Write_Int","qualified_name":"XE_IO.Write_Int","kind":"ada_procedure","location":{"file":"../Dist/xe_io.ads","line":170,"column":14},"code":"procedure Write_Int (Val : Int)","documentation":{"description":"Write an integer value with no leading blanks or zeroes. Negative\nvalues are preceded by a minus sign).","parameters":[{"name":"Val","description":""}]}},{"id":"51710148a0c26e9e","name":"Write_Line","qualified_name":"XE_IO.Write_Line","kind":"ada_procedure","location":{"file":"../Dist/xe_io.ads","line":180,"column":14},"code":"procedure Write_Line (S : String)","documentation":{"description":"Equivalent to Write_Str (S) followed by Write_Eol;","parameters":[{"name":"S","description":""}]}},{"id":"ae8ad8b1cc232ece","name":"Write_Program_Name","qualified_name":"XE_IO.Write_Program_Name","kind":"ada_procedure","location":{"file":"../Dist/xe_io.ads","line":139,"column":14},"code":"procedure Write_Program_Name"},{"id":"5e9959c634aa4a95","name":"Write_Space","qualified_name":"XE_IO.Write_Space","kind":"ada_procedure","location":{"file":"../Dist/xe_io.ads","line":191,"column":14},"code":"procedure Write_Space"},{"id":"b001debe650c47d9","name":"Write_Stamp_Comparison","qualified_name":"XE_IO.Write_Stamp_Comparison","kind":"ada_procedure","location":{"file":"../Dist/xe_io.ads","line":136,"column":14},"code":"procedure Write_Stamp_Comparison\n  (Newer, Older   : File_Name_Type)"},{"id":"e225d86ed15d90bc","name":"Write_Str","qualified_name":"XE_IO.Write_Str","kind":"ada_procedure","location":{"file":"../Dist/xe_io.ads","line":174,"column":14},"code":"procedure Write_Str (S : String)","documentation":{"description":"Write a string of characters to the standard output file. Note that\nend of line is handled separately using WRITE_EOL, so the string\nshould not contain either of the characters LF or CR, but it may\ncontain horizontal tab characters.","parameters":[{"name":"S","description":""}]}}]}