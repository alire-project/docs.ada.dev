{"schema_version":"1","crate":"gnatdist_garlic","version":"6.0.1","id":"5b4c1fb78e9ff159","name":"XE_IO","qualified_name":"XE_IO","kind":"ada_package","location":{"file":"../Dist/xe_io.ads","line":31,"column":9},"code":"package XE_IO","documentation":{"description":"-------------------------------\n File and Directory Handling --\n-------------------------------"},"variables":[{"id":"9476376bdbf2785c","name":"N_Space","qualified_name":"XE_IO.N_Space","kind":"ada_variable","location":{"file":"../Dist/xe_io.ads","line":184,"column":4},"code":"N_Space         : Natural := 0;"},{"id":"34d849fe986138d1","name":"Space_Increment","qualified_name":"XE_IO.Space_Increment","kind":"ada_variable","location":{"file":"../Dist/xe_io.ads","line":183,"column":4},"code":"Space_Increment : Natural := 2;"}],"subprograms":[{"id":"3dd16fce93a93b12","name":"Copy_File","qualified_name":"XE_IO.Copy_File","kind":"ada_procedure","location":{"file":"../Dist/xe_io.ads","line":37,"column":14},"code":"procedure Copy_File (Source, Target : File_Name_Type)","documentation":{"description":"Copy source file into target file (preserves file stamps).","parameters":[{"name":"Source","description":""},{"name":"Target","description":""}]}},{"id":"5e1f1ee7af39e375","name":"Create_Dir","qualified_name":"XE_IO.Create_Dir","kind":"ada_procedure","location":{"file":"../Dist/xe_io.ads","line":50,"column":14},"code":"procedure Create_Dir (Dname : Directory_Name_Type)","documentation":{"description":"Create a directory Dname. This function creates all the\nsubdirectories (separated by a Directory_Separator) one by one\nand then creates the final directory.","parameters":[{"name":"Dname","description":""}]}},{"id":"3b151767290f18cf","name":"Create_File","qualified_name":"XE_IO.Create_File","kind":"ada_procedure","location":{"file":"../Dist/xe_io.ads","line":40,"column":14},"code":"procedure Create_File\n  (File  : out File_Descriptor;\n   Fname : File_Name_Type;\n   Exec  : Boolean := False)","documentation":{"des