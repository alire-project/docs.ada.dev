m_cpu-disk.ads","line":84,"column":14},"code":"procedure write(self : in out fd_ctrl; addr : addr_bus; data : data_bus)","documentation":{"description":"\n  Read from a port address","parameters":[{"name":"self","description":""},{"name":"addr","description":""},{"name":"data","description":""}]}},{"id":"03c3c10936e85b7e","name":"write","qualified_name":"BBS.Sim_CPU.disk.write","kind":"ada_procedure","location":{"file":"../../../../home/runner/.local/share/alire/builds/bbs_simcpu_0.3.3_182249e5/9cdc441e7ff3f33fced7ac7acaa0da633fb83bcec604d59dd89b3ca09151f539/src/io/bbs-sim_cpu-disk.ads","line":234,"column":14},"code":"procedure write(self : in out hd_ctrl)","documentation":{"description":"=========================================================================","parameters":[{"name":"self","description":""}]}},{"id":"a358a120c93702b0","name":"write","qualified_name":"BBS.Sim_CPU.disk.write","kind":"ada_procedure","location":{"file":"../../../../home/runner/.local/share/alire/builds/bbs_simcpu_0.3.3_182249e5/9cdc441e7ff3f33fced7ac7acaa0da633fb83bcec604d59dd89b3ca09151f539/src/io/bbs-sim_cpu-disk.ads","line":193,"column":14},"code":"procedure write(self : in out hd_ctrl; addr : addr_bus; data : data_bus)","documentation":{"description":"\n  Read from a port address","parameters":[{"name":"self","description":""},{"name":"addr","description":""},{"name":"data","description":""}]}}],"formals":[{"id":"b501bc1466566318","name":"sector_size","qualified_name":"BBS.Sim_CPU.disk.sector_size","kind":"ada_formal","location":{"file":"../../../../home/runner/.local/share/alire/builds/bbs_simcpu_0.3.3_182249e5/9cdc441e7ff3f33fced7ac7acaa0da633fb83bcec604d59dd89b3ca09151f539/src/io/bbs-sim_cpu-disk.ads","line":23,"column":3},"code":"sector_size : Natural;"}]}