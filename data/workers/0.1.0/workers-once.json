ption":"Notify no more jobs will be added, so tasks can die once everything is\nprocessed. Will wait for all jobs to complete. Will raise a copy of the\nfirst exception caught during job execution, if any.","parameters":[{"name":"This","description":""}]}}],"formals":[{"id":"57daf8f1a97bb230","name":"Early_Abort","qualified_name":"Workers.Once.Early_Abort","kind":"ada_formal","location":{"file":"src/workers-once.ads","line":21,"column":4},"code":"Early_Abort : Boolean := True;","documentation":{"description":"If any job raises, stop all others ASAP. Otherwise complete them all.\nSee comment on No_More_Jobs."}},{"id":"3f41be28b951b993","name":"Input","qualified_name":"Workers.Once.Input","kind":"ada_formal","location":{"file":"src/workers-once.ads","line":10,"column":9},"code":"type Input (<>) is private;","documentation":{"description":"The type describing the job to perform"}},{"id":"8089dce1906778da","name":"Process","qualified_name":"Workers.Once.Process","kind":"ada_formal","location":{"file":"src/workers-once.ads","line":13,"column":19},"code":"procedure Process (Job : Input)","documentation":{"description":"This procedure will be called by worker threads, must generate\nresults and do something with them (taking care of thread safety,\nsee Worker.Mutexes for a simple mutex or use your own protected type).","parameters":[{"name":"Job","description":""}]}},{"id":"2cc07141ff27b7b3","name":"Size","qualified_name":"Workers.Once.Size","kind":"ada_formal","location":{"file":"src/workers-once.ads","line":18,"column":4},"code":"Size : Positive := Positive (System.Multiprocessors.Number_Of_CPUs);","documentation":{"description":"How many workers will the pool have"}}]}