{"schema_version":"1","crate":"coap_spark","version":"0.10.0","id":"c831825aa9c4257e","name":"CoAP_SPARK.Options","qualified_name":"CoAP_SPARK.Options","kind":"ada_package","location":{"file":"src/coap_spark-options.ads","line":6,"column":9},"code":"package CoAP_SPARK.Options","documentation":{"description":"According to Section 5.10. Option Definitions \"Table 4: Options\"\nthe maximum size for uint options is 4 bytes.\nThe other registered options by IANA are also not larger than 4 bytes.\nMaximum size in general is 1034 bytes."},"simple_types":[{"id":"40e699991900d275","name":"Indefinite_Option","qualified_name":"CoAP_SPARK.Options.Indefinite_Option","kind":"ada_simple_type","location":{"file":"src/coap_spark-options.ads","line":156,"column":9},"code":"type Indefinite_Option (Value_Length : Option_Value_Length) is private\nwith\n  Dynamic_Predicate =>\n    Has_Valid_Length\n      (Option_Properties_Table (Indefinite_Option.Number).Format,\n       Natural (Value_Length));"},{"id":"6e8340372049dd9f","name":"Option","qualified_name":"CoAP_SPARK.Options.Option","kind":"ada_simple_type","location":{"file":"src/coap_spark-options.ads","line":149,"column":9},"code":"type Option is private\nwith\n  Dynamic_Predicate =>\n    Has_Valid_Length\n      (Option_Properties_Table (Option.Number).Format,\n       (if Option.Value = null then 0 else Option.Value.all'Length));"},{"id":"d6a557550d057633","name":"Option_Format","qualified_name":"CoAP_SPARK.Options.Option_Format","kind":"ada_simple_type","location":{"file":"src/coap_spark-options.ads","line":35,"column":9},"code":"type Option_Format is (Unknown, Empty, Opaque, UInt, UTF8_String);"}],"array_types":[{"id":"1596f2cdb1fede99","name":"Option_Table","qualified_name":"CoAP_SPARK.Options.Option_Table","kind":"ada_array_type","location":{"file":"src/coap_spark-options.ads","line":43,"column":9},"code":"type Option_Table is array (RFLX.CoAP.Option_Numbers) of Option_Properties;"}],"record_types":[{"id":"14297c02517806f9","name":