18a8c81ec1b7c97d521e34e338ee687fd74/src/clic-subcommand-instance.ads","line":51,"column":14},"code":"procedure Load_Aliases (Conf     : CLIC.Config.Instance;\n                        Root_Key : String := \"alias\")","documentation":{"description":"Load aliases from the given configuration.\n\nAll the config keys in the format \"<Root_Key>.<sub-key>\" are\nprocessed. If the value of a key is a (not null) String, <sub-key>\nis registered as an alias for the value (parsed into a list with\nGNAT.OS_Lib.Argument_String_To_List).\n\nFor instance when Root_Key := \"alias\" (default):\nalias.test1 = \"cmd arg1 arg2\" # Valid: test1 -> [\"cmd\", \"arg1\", \"arg2\"]\nalias.test2 = \"cmd\"           # Valid: test2 -> [\"cmd\"]\nalias.test3 = \"\"              # Ignored\nalias.test4.test = \"cmd arg1\" # Ignored\nalias.test5 = 20              # Ignored\nalias.test6 = [\"cmd\", \"arg1\"] # Ignored","parameters":[{"name":"Conf","description":""},{"name":"Root_Key","description":""}]}},{"id":"6914d960fe751035","name":"Parse_Global_Switches","qualified_name":"CLIC.Subcommand.Instance.Parse_Global_Switches","kind":"ada_procedure","location":{"file":"../../../home/runner/.local/share/alire/builds/clic_0.3.0_56bbdc00/999105376a33c1da6df82bf23715d18a8c81ec1b7c97d521e34e338ee687fd74/src/clic-subcommand-instance.ads","line":76,"column":14},"code":"procedure Parse_Global_Switches\n  (Command_Line : AAA.Strings.Vector := AAA.Strings.Empty_Vector)","documentation":{"description":"Optional. Call this procedure before Execute to get only global switches\nparsed. This can be useful to check the values of global switches before\nrunning a sub-command or change the behavior of your program based on\nthese (e.g. verbosity, output color, etc.).\n\nIf Command_Line is not empty it will be used instead of the actual\ncommand line arguments from Ada.Command_Line.","parameters":[{"name":"Command_Line","description":""}]}},{"id":"612fd95886233513","name":"Register","qualified_name":"CLIC.Subcommand.Instance.Register","kind":"ada_procedure","location":{"file":"../../../home/runner/.local/share/alire/builds/clic_0.3.0_56bbdc00/999105376a33c1da6df82bf23715d18a8c81ec1b7c97d521e34e338ee687fd74/src/clic-subcommand-instance.ads","line":37,"column":14},"code":"procedure Register (Cmd : not null Command_Access)","documentation":{"description":"Register a sub-command","parameters":[{"name":"Cmd","description":""}]}},{"id":"2638927d7e05c60b","name":"Register","qualified_name":"CLIC.Subcommand.Instance.Register","kind":"ada_procedure","location":{"file":"../../../home/runner/.local/share/alire/builds/clic_0.3.0_56bbdc00/999105376a33c1da6df82bf23715d18a8c81ec1b7c97d521e34e338ee687fd74/src/clic-subcommand-instance.ads","line":43,"column":14},"code":"procedure Register (Topic : not null Help_Topic_Access)","documentation":{"description":"Register a help topic","parameters":[{"name":"Topic","description":""}]}},{"id":"f5f4cc6909fb2dfe","name":"Register","qualified_name":"CLIC.Subcommand.Instance.Register","kind":"ada_procedure","location":{"file":"../../../home/runner/.local/share/alire/builds/clic_0.3.0_56bbdc00/999105376a33c1da6df82bf23715d18a8c81ec1b7c97d521e34e338ee687fd74/src/clic-subcommand-instance.ads","line":40,"column":14},"code":"procedure Register (Group : String; Cmd : not null Command_Access)","documentation":{"description":"Register a sub-command in a group","parameters":[{"name":"Group","description":""},{"name":"Cmd","description":""}]}},{"id":"e96830f5b7342995","name":"Set_Alias","qualified_name":"CLIC.Subcommand.Instance.Set_Alias","kind":"ada_procedure","location":{"file":"../../../home/runner/.local/share/alire/builds/clic_0.3.0_56bbdc00/999105376a33c1da6df82bf23715d18a8c81ec1b7c97d521e34e338ee687fd74/src/clic-subcommand-instance.ads","line":46,"column":14},"code":"procedure Set_Alias (Alias : Identifier; Replacement : AAA.Strings.Vector)","documentation":{"description":"Define Alias such that \"<Main_Command_Name> <Alias> <Extra_Args>\" will\nbe replaced by 