{% extends "base.html.j2" %}

{% block title %}Ada/SPARK Package Registry{% endblock %}
{% block description %}Browse API documentation for Ada and SPARK packages from the Alire index. Covers all publicly indexed crates.{% endblock %}
{% block keywords %}Ada, SPARK, Alire, Ada packages, Ada API documentation, Ada library{% endblock %}

{% block extra_head %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Ada/SPARK Package Registry",
  "description": "API documentation for Ada and SPARK packages from the Alire index.",
  "url": "{{ base_url }}/"
}
</script>
{% endblock %}

{% block content %}
<div class="page-index">
  <h1>Ada/SPARK Package Registry</h1>
  <p class="page-intro">
    API documentation for Ada and SPARK packages from the
    <a href="https://alire.ada.dev">Alire</a> index.
    {% if updated %}Last updated {{ updated[:10] }}.{% endif %}
    <a href="{{ base_url }}/errors.html" class="errors-link">View failed builds</a>
  </p>

  {% if recent_crates %}
  <section class="recently-documented">
    <h2>Recently documented</h2>
    <ul class="crate-list">
      {% for crate in recent_crates %}
      <li class="crate-item">
        <a class="crate-name" href="{{ base_url }}/c/{{ crate.name }}/">{{ crate.name }}</a>
        {% if crate.latest %}
        <span class="crate-version">{{ crate.latest }}</span>
        {% endif %}
        {% if crate.description %}
        <span class="crate-desc">{{ crate.description }}</span>
        {% endif %}
      </li>
      {% endfor %}
    </ul>
  </section>
  {% endif %}

  <div class="search-bar">
    <label for="crate-search" class="sr-only">Search crates</label>
    <input id="crate-search" type="search" placeholder="Search crates by name, tags, or description…"
           autocomplete="off" spellcheck="false">
    <span id="crate-count" class="search-count"></span>
  </div>

  {% if crates %}
  <ul class="crate-list" id="crate-list">
    {% for crate in crates %}
    <li class="crate-item" data-name="{{ crate.name }}"
        data-tags="{{ crate.tags | join(' ') if crate.tags else '' }}">
      <a class="crate-name" href="{{ base_url }}/c/{{ crate.name }}/">{{ crate.name }}</a>
      {% if crate.latest %}
      <span class="crate-version">{{ crate.latest }}</span>
      {% endif %}
      {% if crate.description %}
      <span class="crate-desc">{{ crate.description }}</span>
      {% endif %}
      {% if crate.tags %}
      <span class="crate-tags" aria-label="Tags">
        {% for tag in crate.tags %}<span class="tag">{{ tag }}</span>{% endfor %}
      </span>
      {% endif %}
    </li>
    {% endfor %}
  </ul>
  <p id="no-results" class="no-results" hidden>No crates match your search.</p>
  {% else %}
  <p>No crates have been indexed yet.</p>
  {% endif %}
</div>
{% endblock %}

{% block extra_scripts %}
<script>
(function () {
  const input = document.getElementById('crate-search');
  const list  = document.getElementById('crate-list');
  const count = document.getElementById('crate-count');
  const none  = document.getElementById('no-results');
  if (!input || !list) return;

  const items = Array.from(list.querySelectorAll('.crate-item'));
  count.textContent = items.length + ' crate' + (items.length !== 1 ? 's' : '');

  // Fuzzy matching: calculate similarity score between two strings
  function fuzzyScore(str, query) {
    str = str.toLowerCase();
    query = query.toLowerCase();

    // Exact match gets highest score
    if (str === query) return 1000;
    if (str.includes(query)) return 500 + (100 - str.indexOf(query));

    // Fuzzy match: check how many query chars appear in order
    let score = 0;
    let strIdx = 0;
    let queryIdx = 0;
    let consecutiveMatches = 0;

    while (strIdx < str.length && queryIdx < query.length) {
      if (str[strIdx] === query[queryIdx]) {
        score += 10 + consecutiveMatches * 5; // Bonus for consecutive matches
        consecutiveMatches++;
        queryIdx++;
      } else {
        consecutiveMatches = 0;
      }
      strIdx++;
    }

    // If we matched all query characters, it's a valid fuzzy match
    if (queryIdx === query.length) {
      return score;
    }

    return 0; // No match
  }

  // Search and rank results
  function searchCrates(query) {
    if (!query) {
      // No query: show all items in original order
      items.forEach(function (li) {
        li.hidden = false;
        li.style.order = '';
      });
      return items.length;
    }

    const results = items.map(function (li) {
      const name = li.dataset.name || '';
      const tags = li.dataset.tags || '';
      const descEl = li.querySelector('.crate-desc');
      const desc = descEl ? descEl.textContent : '';

      // Calculate scores for different fields
      const nameScore = fuzzyScore(name, query) * 3; // Name matches worth 3x
      const tagScore = fuzzyScore(tags, query) * 2;  // Tag matches worth 2x
      const descScore = fuzzyScore(desc, query);      // Description matches worth 1x

      const totalScore = nameScore + tagScore + descScore;

      return { element: li, score: totalScore };
    });

    // Sort by score (highest first) and show/hide based on match
    let visible = 0;
    results
      .sort(function (a, b) { return b.score - a.score; })
      .forEach(function (result, index) {
        if (result.score > 0) {
          result.element.hidden = false;
          result.element.style.order = index; // Reorder by relevance
          visible++;
        } else {
          result.element.hidden = true;
          result.element.style.order = '';
        }
      });

    return visible;
  }

  // Debounce search for performance
  let searchTimeout;
  input.addEventListener('input', function () {
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(function () {
      const q = input.value.trim();
      const visible = searchCrates(q);
      count.textContent = visible + ' crate' + (visible !== 1 ? 's' : '');
      none.hidden = visible > 0;
    }, 150); // 150ms debounce
  });
}());
</script>
{% endblock %}
