<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% block title %}Ada/SPARK Package Registry{% endblock %}</title>
  <meta name="description" content="{% block description %}Browse API documentation for Ada and SPARK packages from the Alire index.{% endblock %}">
  <meta name="keywords" content="{% block keywords %}Ada, SPARK, Alire, Ada packages, API documentation{% endblock %}">
  <link rel="stylesheet" href="{{ base_url }}/assets/style.css">
  {% block extra_head %}{% endblock %}
</head>
<body>
  <header class="site-header">
    <nav class="site-nav" aria-label="Site navigation">
      <a class="site-logo" href="{{ base_url }}/">Ada/SPARK Docs</a>
      {% block breadcrumb %}{% endblock %}
    </nav>
  </header>

  <main class="site-main">
    {% block content %}{% endblock %}
  </main>

  <footer class="site-footer">
    <p>
      Documentation generated by
      <a href="https://github.com/AdaCore/gnatdoc">gnatdoc</a>
      from crates in the
      <a href="https://alire.ada.dev">Alire</a> index.
      Generated {{ now[:10] }}.
    </p>
  </footer>
  {% block extra_scripts %}{% endblock %}
</body>
</html>
