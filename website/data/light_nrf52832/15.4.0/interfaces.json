{"schema_version":"1","crate":"light_nrf52832","version":"15.4.0","id":"0274021b904cdec6","name":"Interfaces","qualified_name":"Interfaces","kind":"ada_package","location":{"file":"gnat/interfac.ads","line":47,"column":9},"code":"package Interfaces","documentation":{"description":"Definitions of 8, 16, 24, 32, 64 and 128 bit signed and unsigned integer\ntypes."},"simple_types":[{"id":"f84577649af16436","name":"IEEE_Extended_Float","qualified_name":"Interfaces.IEEE_Extended_Float","kind":"ada_simple_type","location":{"file":"gnat/interfac.ads","line":245,"column":9},"code":"type IEEE_Extended_Float is new Long_Long_Float;"},{"id":"b8a02f569fb5bba7","name":"IEEE_Float_32","qualified_name":"Interfaces.IEEE_Float_32","kind":"ada_simple_type","location":{"file":"gnat/interfac.ads","line":231,"column":9},"code":"type IEEE_Float_32 is digits 6;"},{"id":"4ad26638df13d554","name":"IEEE_Float_64","qualified_name":"Interfaces.IEEE_Float_64","kind":"ada_simple_type","location":{"file":"gnat/interfac.ads","line":234,"column":9},"code":"type IEEE_Float_64 is digits 15;"},{"id":"05fb2037ce0b8f66","name":"Integer_128","qualified_name":"Interfaces.Integer_128","kind":"ada_simple_type","location":{"file":"gnat/interfac.ads","line":76,"column":9},"code":"type Integer_128 is new Long_Long_Long_Integer;","documentation":{"description":"We use Long_Long_Long_Integer instead of literal bounds to allow this\nunit to be compiled with compilers not supporting 128-bit integers.\nWe do not put a confirming size clause of 128 bits for the same reason."}},{"id":"588b4a88a6cd07b5","name":"Integer_16","qualified_name":"Interfaces.Integer_16","kind":"ada_simple_type","location":{"file":"gnat/interfac.ads","line":62,"column":9},"code":"type Integer_16 is range -2 ** 15 .. 2 ** 15 - 1;"},{"id":"432a7e9f76ea4e2a","name":"Integer_32","qualified_name":"Interfaces.Integer_32","kind":"ada_simple_type","location":{"file":"gnat/interfac.ads","line":65,"column":9},"code":"type Integer_32 is range -2 ** 31 .. 2 ** 31 - 1;"},{"id":"e59e55bcddac329a","name":"Integer_64","qualified_name":"Interfaces.Integer_64","kind":"ada_simple_type","location":{"file":"gnat/interfac.ads","line":68,"column":9},"code":"type Integer_64 is new Long_Long_Integer;","documentation":{"description":"We use Long_Long_Integer'First instead of -2 ** 63 to allow this unit to\ncompile when using custom target configuration files where the maximum\ninteger is 32 bits. This is useful for static analysis tools such as\nSPARK or CodePeer. In the normal case Long_Long_Integer is 64-bits so we\nget the desired 64-bit type."}},{"id":"4dccc662144099a4","name":"Integer_8","qualified_name":"Interfaces.Integer_8","kind":"ada_simple_type","location":{"file":"gnat/interfac.ads","line":59,"column":9},"code":"type Integer_8  is range -2 **  7 .. 2 **  7 - 1;"},{"id":"3ce78bf8424cf1ae","name":"Unsigned_128","qualified_name":"Interfaces.Unsigned_128","kind":"ada_simple_type","location":{"file":"gnat/interfac.ads","line":99,"column":9},"code":"type Unsigned_128 is mod 2 ** Long_Long_Long_Integer'Size;","documentation":{"description":"See comment on Integer_128 above"}},{"id":"ae087c11c9531a3f","name":"Unsigned_16","qualified_name":"Interfaces.Unsigned_16","kind":"ada_simple_type","location":{"file":"gnat/interfac.ads","line":84,"column":9},"code":"type Unsigned_16 is mod 2 ** 16;"},{"id":"379d4a216e84a31b","name":"Unsigned_24","qualified_name":"Interfaces.Unsigned_24","kind":"ada_simple_type","location":{"file":"gnat/interfac.ads","line":87,"column":9},"code":"type Unsigned_24 is mod 2 ** 24;","documentation":{"description":"Declare this type for compatibility with legacy Ada compilers.\nThis is particularly useful in the context of CodePeer analysis."}},{"id":"df7ddff3e5b2c4c3","name":"Unsigned_32","qualified_name":"Interfaces.Unsigned_32","kind":"ada_simple_type","location":{"file":"gnat/interfac.ads","line":92,"column":9},"code":"type Unsigned_32 is mod 2 ** 32;"},{"id":"34c2094646c51e4c","name":"Unsigned_64","qual