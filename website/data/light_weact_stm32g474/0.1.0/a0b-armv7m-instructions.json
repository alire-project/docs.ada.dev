ource/a0b-armv7m-instructions.ads","line":60,"column":14},"code":"procedure Disable_Faults","documentation":{"description":"Disable FIQ\n\nDisables FIQ interrupts by setting the F-bit in the CPSR.\nCan only be executed in Privileged modes."}},{"id":"d4c32440fcd391ca","name":"Disable_Interrupts","qualified_name":"A0B.ARMv7M.Instructions.Disable_Interrupts","kind":"ada_procedure","location":{"file":"../../../../home/runner/.local/share/alire/builds/a0b_armv7m_0.4.0_bb8b0af2/e961cf8f7b443e28e32b9ad61e827adb676c6b7b35166cb3586963c14b9013cc/source/a0b-armv7m-instructions.ads","line":48,"column":14},"code":"procedure Disable_Interrupts","documentation":{"description":"Disable IRQ Interrupts\n\nDisables IRQ interrupts by setting the I-bit in the CPSR.\nCan only be executed in Privileged modes."}},{"id":"d902967dab5cea1c","name":"Enable_Faults","qualified_name":"A0B.ARMv7M.Instructions.Enable_Faults","kind":"ada_procedure","location":{"file":"../../../../home/runner/.local/share/alire/builds/a0b_armv7m_0.4.0_bb8b0af2/e961cf8f7b443e28e32b9ad61e827adb676c6b7b35166cb3586963c14b9013cc/source/a0b-armv7m-instructions.ads","line":54,"column":14},"code":"procedure Enable_Faults","documentation":{"description":"Enable FIQ\n\nEnables FIQ interrupts by clearing the F-bit in the CPSR.\nCan only be executed in Privileged modes."}},{"id":"a2fdea40f4b2a891","name":"Enable_Interrupts","qualified_name":"A0B.ARMv7M.Instructions.Enable_Interrupts","kind":"ada_procedure","location":{"file":"../../../../home/runner/.local/share/alire/builds/a0b_armv7m_0.4.0_bb8b0af2/e961cf8f7b443e28e32b9ad61e827adb676c6b7b35166cb3586963c14b9013cc/source/a0b-armv7m-instructions.ads","line":42,"column":14},"code":"procedure Enable_Interrupts","documentation":{"description":"Enable IRQ Interrupts\n\nEnables IRQ interrupts by clearing the I-bit in the CPSR.\nCan only be executed in Privileged modes."}},{"id":"9ef10c412d800826","name":"Get_BASEPRI","qualified_name":"A0B.ARMv7M.Instructions.Get_BASEPRI","kind":"ada_f