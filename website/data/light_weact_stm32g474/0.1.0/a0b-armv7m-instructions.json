s Stack Pointer (PSP)."}},{"id":"2f19674e83ea2cc7","name":"Instruction_Synchronization_Barrier","qualified_name":"A0B.ARMv7M.Instructions.Instruction_Synchronization_Barrier","kind":"ada_procedure","location":{"file":"../../../../home/runner/.local/share/alire/builds/a0b_armv7m_0.4.0_bb8b0af2/e961cf8f7b443e28e32b9ad61e827adb676c6b7b35166cb3586963c14b9013cc/source/a0b-armv7m-instructions.ads","line":35,"column":14},"code":"procedure Instruction_Synchronization_Barrier","documentation":{"description":"Instruction Synchronization Barrier\n\nInstruction Synchronization Barrier flushes the pipeline in the\nprocessor, so that all instructions following the ISB are fetched from\ncache or memory, after the instruction has been completed."}},{"id":"e465c373881fb87e","name":"Set_BASEPRI","qualified_name":"A0B.ARMv7M.Instructions.Set_BASEPRI","kind":"ada_procedure","location":{"file":"../../../../home/runner/.local/share/alire/builds/a0b_armv7m_0.4.0_bb8b0af2/e961cf8f7b443e28e32b9ad61e827adb676c6b7b35166cb3586963c14b9013cc/source/a0b-armv7m-instructions.ads","line":101,"column":14},"code":"procedure Set_BASEPRI (To : A0B.ARMv7M.Priority_Value)","documentation":{"description":"Set Base Priority\n\nAssigns the given value to the Base Priority register.\n\nXXX Note, GCC 13.2 fails to compile code when register is represented\nas record like other registers.","parameters":[{"name":"To","description":""}]}},{"id":"e1c8a5da8f8ec35c","name":"Set_CONTROL","qualified_name":"A0B.ARMv7M.Instructions.Set_CONTROL","kind":"ada_procedure","location":{"file":"../../../../home/runner/.local/share/alire/builds/a0b_armv7m_0.4.0_bb8b0af2/e961cf8f7b443e28e32b9ad61e827adb676c6b7b35166cb3586963c14b9013cc/source/a0b-armv7m-instructions.ads","line":85,"column":14},"code":"procedure Set_CONTROL (To : CONTROL_Register)","documentation":{"description":"Set Control Register\n\nWrites the given value to the Control Register.\n\nInstruction_Synchronization_Barrier should be called after change of\nthe value of the CONTROL register.","parameters":[{"name":"To","description":""}]}},{"id":"51d72dce4c6a1564","name":"Set_MSP","qualified_name":"A0B.ARMv7M.Instructions.Set_MSP","kind":"ada_procedure","location":{"file":"../../../../home/runner/.local/share/alire/builds/a0b_armv7m_0.4.0_bb8b0af2/e961cf8f7b443e28e32b9ad61e827adb676c6b7b35166cb3586963c14b9013cc/source/a0b-armv7m-instructions.ads","line":114,"column":14},"code":"procedure Set_MSP (To : System.Address)","documentation":{"description":"Set Main Stack Pointer\n\nAssigns the given value to the Main Stack Pointer (MSP).","parameters":[{"name":"To","description":""}]}},{"id":"a6baf5d596b0f5cc","name":"Set_PSP","qualified_name":"A0B.ARMv7M.Instructions.Set_PSP","kind":"ada_procedure","location":{"file":"../../../../home/runner/.local/share/alire/builds/a0b_armv7m_0.4.0_bb8b0af2/e961cf8f7b443e28e32b9ad61e827adb676c6b7b35166cb3586963c14b9013cc/source/a0b-armv7m-instructions.ads","line":124,"column":14},"code":"procedure Set_PSP (To : System.Address)","documentation":{"description":"Set Process Stack Pointer\n\nAssigns the given value to the Process Stack Pointer (PSP).","parameters":[{"name":"To","description":""}]}},{"id":"f491a48409221c44","name":"Wait_For_Event","qualified_name":"A0B.ARMv7M.Instructions.Wait_For_Event","kind":"ada_procedure","location":{"file":"../../../../home/runner/.local/share/alire/builds/a0b_armv7m_0.4.0_bb8b0af2/e961cf8f7b443e28e32b9ad61e827adb676c6b7b35166cb3586963c14b9013cc/source/a0b-armv7m-instructions.ads","line":23,"column":14},"code":"procedure Wait_For_Event","documentation":{"description":"Wait For Event\n\nWait For Event is a hint instruction that permits the processor to\nenter a low-power state until one of a number of events occurs."}},{"id":"5de98d55a01a9298","name":"Wait_For_Interrupt","qualified_name":"A0B.ARMv7M.Instructions.Wait_For_Interrupt","kind":"ada_procedure","location":{"file":"../../../../home/runner/.local/share/alire/builds/a0b_armv7m_0.4.0_bb8b0af2/e961cf8f7b443e28