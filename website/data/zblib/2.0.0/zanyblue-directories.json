ecified by Name.","parameters":[{"name":"Name","description":""}]}},{"id":"e9b6f3ee99d0df08","name":"Get_Next_Entry","qualified_name":"ZanyBlue.Directories.Get_Next_Entry","kind":"ada_procedure","location":{"file":"os/zanyblue-directories.ads","line":175,"column":14},"code":"procedure Get_Next_Entry\n  (Search          : in out Search_Type;\n   Directory_Entry :    out Directory_Entry_Type)","documentation":{"description":"Returns the next Directory_Entry for the search described by Search that\nmatches the pattern and filter.","parameters":[{"name":"Search","description":""},{"name":"Directory_Entry","description":""}]}},{"id":"c0d0f02a671b1990","name":"Kind","qualified_name":"ZanyBlue.Directories.Kind","kind":"ada_function","location":{"file":"os/zanyblue-directories.ads","line":202,"column":13},"code":"function Kind\n  (Directory_Entry : Directory_Entry_Type)\n   return File_Kind","documentation":{"description":"Returns the kind of external file represented by Directory_Entry.","parameters":[{"name":"Directory_Entry","description":""}]}},{"id":"55ee88271190e9ec","name":"Kind","qualified_name":"ZanyBlue.Directories.Kind","kind":"ada_function","location":{"file":"os/zanyblue-directories.ads","line":131,"column":13},"code":"function Kind\n  (Name : String)\n   return File_Kind","documentation":{"description":"Returns the kind of external file represented by Name.","parameters":[{"name":"Name","description":""}]}},{"id":"1f27b513ee9dcce6","name":"Modification_Time","qualified_name":"ZanyBlue.Directories.Modification_Time","kind":"ada_function","location":{"file":"os/zanyblue-directories.ads","line":212,"column":13},"code":"function Modification_Time\n  (Directory_Entry : Directory_Entry_Type)\n   return Ada.Calendar.Time","documentation":{"description":"Returns the time that the external file represented by Directory_Entry\nwas most recently modified.","parameters":[{"name":"Directory_Entry","description":""}]}},{"id":"bbd5eeb1e1e303a7","name":"Modification_Time","qu