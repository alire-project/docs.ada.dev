xternal file represented by Name.","parameters":[{"name":"Name","description":""}]}},{"id":"885e7011e4c1210b","name":"Start_Search","qualified_name":"ZanyBlue.Directories.Start_Search","kind":"ada_procedure","location":{"file":"os/zanyblue-directories.ads","line":157,"column":14},"code":"procedure Start_Search\n  (Search    : in out Search_Type;\n   Directory :        String;\n   Pattern   :        String;\n   Filter    :        Filter_Type := (others => True))","documentation":{"description":"Starts a search in the directory entry in the directory named by\nDirectory for entries matching Pattern. Pattern represents a file name\nmatching pattern.","parameters":[{"name":"Search","description":""},{"name":"Directory","description":""},{"name":"Pattern","description":""},{"name":"Filter","description":""}]}}]}