/core/src/gnatcoll-buffer.ads","line":104,"column":13},"code":"function Check (Self : in out Reader'Class; Str : String) return Boolean","documentation":{"description":"Check whether the next characters in the buffer are equal to Str. If\nStr is found Check return True and buffer position updated to the\nlatest character of Str. If False is returned then buffer position is\nnot updated.","parameters":[{"name":"Self","description":""},{"name":"Str","description":""}]}},{"id":"c2d54a68dc7fa13b","name":"Current_Char","qualified_name":"GNATCOLL.Buffer.Current_Char","kind":"ada_function","location":{"file":"../../../../home/runner/.local/share/alire/builds/gnatcoll_26.0.0_cc5dd0a1/7ccbed38d8b88fe1ce3c718d0f0a1da149c4b5af155bbe12ed9d190dcda52463/core/src/gnatcoll-buffer.ads","line":95,"column":13},"code":"function Current_Char (Self : Reader'Class) return Character","documentation":{"description":"Get the current character in the buffer. Call to that function is only\nvalid if Is_End_Of_Data returns False.","parameters":[{"name":"Self","description":""}]}},{"id":"88274a07b0119ea4","name":"Current_Position","qualified_name":"GNATCOLL.Buffer.Current_Position","kind":"ada_function","location":{"file":"../../../../home/runner/.local/share/alire/builds/gnatcoll_26.0.0_cc5dd0a1/7ccbed38d8b88fe1ce3c718d0f0a1da149c4b5af155bbe12ed9d190dcda52463/core/src/gnatcoll-buffer.ads","line":116,"column":13},"code":"function Current_Position (Self : Reader'Class) return Long_Long_Integer","documentation":{"description":"Return absolute position in the stream","parameters":[{"name":"Self","description":""}]}},{"id":"aa8c0735bd756ea0","name":"Current_Text_Position","qualified_name":"GNATCOLL.Buffer.Current_Text_Position","kind":"ada_procedure","location":{"file":"../../../../home/runner/.local/share/alire/builds/gnatcoll_26.0.0_cc5dd0a1/7ccbed38d8b88fe1ce3c718d0f0a1da149c4b5af155bbe12ed9d190dcda52463/core/src/gnatcoll-buffer.ads","line":120,"column":14},"code":"procedure Current_Text_Position\