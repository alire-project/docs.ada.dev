 : aliased Interfaces.RP2040.UInt32;\n   TIMELR   : aliased Interfaces.RP2040.UInt32;\n   ALARM0   : aliased Interfaces.RP2040.UInt32;\n   ALARM1   : aliased Interfaces.RP2040.UInt32;\n   ALARM2   : aliased Interfaces.RP2040.UInt32;\n   ALARM3   : aliased Interfaces.RP2040.UInt32;\n   ARMED    : aliased ARMED_Register;\n   TIMERAWH : aliased Interfaces.RP2040.UInt32;\n   TIMERAWL : aliased Interfaces.RP2040.UInt32;\n   DBGPAUSE : aliased DBGPAUSE_Register;\n   PAUSE    : aliased PAUSE_Register;\n   INTR     : aliased INTR_Register;\n   INTE     : aliased INTE_Register;\n   INTF     : aliased INTF_Register;\n   INTS     : aliased INTS_Register;\nend record;","documentation":{"fields":[{"name":"TIMEHW","description":"Write to bits 31:0 of time\\n writes do not get copied to time until\ntimehw is written"},{"name":"TIMELW","description":"Read from bits 63:32 of time\\n always read timelr before timehr"},{"name":"TIMEHR","description":"Read from bits 31:0 of time"},{"name":"TIMELR","description":"Arm alarm 0, and configure the time it will fire.\\n Once armed, the\nalarm fires when TIMER_ALARM0 == TIMELR.\\n The alarm will disarm\nitself once it fires, and can\\n be disarmed early using the ARMED\nstatus register."},{"name":"ALARM0","description":"Arm alarm 1, and configure the time it will fire.\\n Once armed, the\nalarm fires when TIMER_ALARM1 == TIMELR.\\n The alarm will disarm\nitself once it fires, and can\\n be disarmed early using the ARMED\nstatus register."},{"name":"ALARM1","description":"Arm alarm 2, and configure the time it will fire.\\n Once armed, the\nalarm fires when TIMER_ALARM2 == TIMELR.\\n The alarm will disarm\nitself once it fires, and can\\n be disarmed early using the ARMED\nstatus register."},{"name":"ALARM2","description":"Arm alarm 3, and configure the time it will fire.\\n Once armed, the\nalarm fires when TIMER_ALARM3 == TIMELR.\\n The alarm will disarm\nitself once it fires, and can\\n be disarmed early using the ARMED\nstatus register."},{"name":"ALARM3","description":"Indicates the armed/disarmed status of each alarm.\\n A write to the\ncorresponding ALARMx register arms the alarm.\\n Alarms automatically\ndisarm upon firing, but writing ones here\\n will disarm immediately\nwithout waiting to fire."},{"name":"ARMED","description":"Raw read from bits 63:32 of time (no side effects)"},{"name":"TIMERAWH","description":"Raw read from bits 31:0 of time (no side effects)"},{"name":"TIMERAWL","description":"Set bits high to enable pause when the corresponding debug ports are\nactive"},{"name":"DBGPAUSE","description":"Set high to pause the timer"},{"name":"PAUSE","description":"Raw Interrupts"},{"name":"INTR","description":"Interrupt Enable"},{"name":"INTE","description":"Interrupt Force"},{"name":"INTF","description":"Interrupt status after masking & forcing"},{"name":"INTS","description":""}]}}],"subtypes":[{"id":"e2d5bb29095b7b25","name":"ARMED_ARMED_Field","qualified_name":"Interfaces.RP2040.TIMER.ARMED_ARMED_Field","kind":"ada_subtype","location":{"file":"../../../home/runner/.local/share/alire/builds/light_tasking_rp2040_15.3.0_c9c04aed/4065265df7b86a3736218c3d73ac26491bb2d7b8c240d11b26563991788017d8/gnat/i-rp2040-timer.ads","line":38,"column":12},"code":"subtype ARMED_ARMED_Field is Interfaces.RP2040.UInt4;"},{"id":"a178f42e41be356f","name":"DBGPAUSE_DBG_Element","qualified_name":"Interfaces.RP2040.TIMER.DBGPAUSE_DBG_Element","kind":"ada_subtype","location":{"file":"../../../home/runner/.local/share/alire/builds/light_tasking_rp2040_15.3.0_c9c04aed/4065265df7b86a3736218c3d73ac26491bb2d7b8c240d11b26563991788017d8/gnat/i-rp2040-timer.ads","line":60,"column":12},"code":"subtype DBGPAUSE_DBG_Element is Interfaces.RP2040.Bit;"},{"id":"83a95e8d17a15fb7","name":"INTE_ALARM_0_Field","qualified_name":"Interfaces.RP2040.TIMER.INTE_ALARM_0_Field","kind":"ada_subtype","location":{"file":"../../../home/runner/.local/share/alire/builds/light_tasking_rp2040_15.3.0_c9c04aed/4065265df7b86a3736218c3d73ac26491bb2d7b