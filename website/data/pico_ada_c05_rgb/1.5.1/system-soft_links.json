ocumentation":{"description":"Used in conjunction with Library_Exception, set when an exception has\nbeen stored."}},{"id":"4abb132c9b9f7bee","name":"Lock_Task","qualified_name":"System.Soft_Links.Lock_Task","kind":"ada_variable","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/bdea63aefd2c9f503503d03ddcc8ea23c3dca8fb74694724dfc6a305bb8a89de/gnat/s-soflin.ads","line":92,"column":4},"code":"Lock_Task : No_Param_Proc := Task_Lock_Soft'Access;","documentation":{"description":"Locks out other tasks. Preceding a section of code by Task_Lock and\nfollowing it by Task_Unlock creates a critical region. This is used\nfor ensuring that a region of non-tasking code (such as code used to\nallocate memory) is tasking safe. Note that it is valid for calls to\nTask_Lock/Task_Unlock to be nested, and this must work properly, i.e.\nonly the corresponding outer level Task_Unlock will actually unlock."}},{"id":"896efc30493d1667","name":"Task_Termination_Handler","qualified_name":"System.Soft_Links.Task_Termination_Handler","kind":"ada_variable","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/bdea63aefd2c9f503503d03ddcc8ea23c3dca8fb74694724dfc6a305bb8a89de/gnat/s-soflin.ads","line":154,"column":4},"code":"Task_Termination_Handler : EO_Param_Proc := Task_Termination_Soft'Access;","documentation":{"description":"Handle task termination routines (task/non-task case as appropriate)"}},{"id":"b95dd51f2dd489ec","name":"Traceback_Decorator_Wrapper","qualified_name":"System.Soft_Links.Traceback_Decorator_Wrapper","kind":"ada_variable","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/bdea63aefd2c9f503503d03ddcc8ea23c3dca8fb74694724dfc6a305bb8a89de/gnat/s-soflin.ads","line":198,"column":4},"code":"Traceback_Decorator_Wrapper : Traceback_Decorator_Wrapper_Call;","documentation":{"description":"Wrapper to the possible user specified traceback decorator to be\ncalled during automatic output of exception data.\n\nThe null value of this wrapper corresponds to the null value of the\ncurrent actual decorator. This is ensured first by the null initial\nvalue of the corresponding variables, and then by Set_Trace_Decorator\nin g-exctra.adb."}},{"id":"843690401e3388c0","name":"Unlock_Task","qualified_name":"System.Soft_Links.Unlock_Task","kind":"ada_variable","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/bdea63aefd2c9f503503d03ddcc8ea23c3dca8fb74694724dfc6a305bb8a89de/gnat/s-soflin.ads","line":100,"column":4},"code":"Unlock_Task : No_Param_Proc := Task_Unlock_Soft'Access;","documentation":{"description":"Releases lock previously set by call to Lock_Task. In the nested case,\nall nested locks must be released before other tasks competing for the\ntasking lock are released.\n\nNote: the recommended protocol for using Lock_Task and Unlock_Task\nis as follows:\n\n  Locked_Processing : begin\n     System.Soft_Links.Lock_Task.all;\n     ...\n     System.Soft_Links.Unlock_Task.all;\n\n  exception\n     when others =>\n        System.Soft_Links.Unlock_Task.all;\n        raise;\n  end Locked_Processing;\n\nThis ensures that the lock is not left set if an exception is raised\nexplicitly or implicitly during the critical locked region."}}],"subprograms":[{"id":"2e21b3fa4857d804","name":"Abort_Defer_Raven","qualified_name":"System.Soft_Links.Abort_Defer_Raven","kind":"ada_procedure","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/bdea63aefd2c9f503503d03ddcc8ea23c3dca8fb74694724dfc6a305bb8a89de/gnat/s-soflin.ads","line":80,"column":14},"code":"procedure Abort_Defer_Raven","documentation":{"description":"Defer task abort (Ravenscar case, does nothing)"}},{"id":"17a346e40014608a","name":"Abort_Undefer_Raven","qualified_name":"System.Soft_Links.Abort_Undefer_Raven","kind":"ada_procedure","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/bdea63aefd2c9f503503d03ddcc8ea23c3dca8fb74694724dfc6a305bb8a89de/gnat/s-soflin.ads","line":83,"column":14},"code":"procedure Abort_Undefer_Raven","documentation":{"description":"Undefer task abort (Ravenscar case, does nothing)"}},{"id":"0c1f2d53cd2845e7","name":"Acquire_RTS_Lock_Soft","qualified_name":"System.Soft_Links.Acquire_RTS_Lock_Soft","kind":"ada_procedure","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/bdea63aefd2c9f503503d03ddcc8ea23c3dca8fb74694724dfc6a305bb8a89de/gnat/s-soflin.ads","line":163,"column":14},"code":"procedure Acquire_RTS_Lock_Soft (Addr : Address)","documentation":{"description":"Acquire the RTS lock at Addr","parameters":[{"name":"Addr","description":""}]}},{"id":"50fbe2bf6ac7ac1a","name":"Adafinal_Soft","qualified_name":"System.Soft_Links.Adafinal_Soft","kind":"ada_procedure","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/bdea63aefd2c9f503503d03ddcc8ea23c3dca8fb74694724dfc6a305bb8a89de/gnat/s-soflin.ads","line":122,"column":14},"code":"procedure Adafinal_Soft","documentation":{"description":"Programs do not terminate in Ravenscar"}},{"id":"99f917ab18795ef2","name":"Get_Current_Excep_Soft","qualified_name":"System.Soft_Links.Get_Current_Excep_Soft","kind":"ada_function","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/bdea63aefd2c9f503503d03ddcc8ea23c3dca8fb74694724dfc6a305bb8a89de/gnat/s-soflin.ads","line":138,"column":13},"code":"function Get_Current_Excep_Soft return EOA"},{"id":"ecf2f703ddf0bc96","name":"Get_GNAT_Exception","qualified_name":"System.Soft_Links.Get_GNAT_Exception","kind":"ada_function","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/bdea63aefd2c9f503503d03ddcc8ea23c3dca8fb74694724dfc6a305bb8a89de/gnat/s-soflin.ads","line":143,"column":13},"code":"function Get_GNAT_E