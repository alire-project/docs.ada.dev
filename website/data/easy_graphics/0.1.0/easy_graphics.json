phics.TRANSPARENT","kind":"ada_constant","location":{"file":"src/easy_graphics.ads","line":45,"column":4},"code":"TRANSPARENT : constant RGBA_8 := (0, 0, 0, 0);"},{"id":"b7fce712022e9508","name":"WHITE","qualified_name":"Easy_Graphics.WHITE","kind":"ada_constant","location":{"file":"src/easy_graphics.ads","line":42,"column":4},"code":"WHITE   : constant RGBA_8 := (255, 255, 255, 255);","documentation":{"description":"Totally transparent colour..."}},{"id":"784cbec1c0b8640f","name":"YELLOW","qualified_name":"Easy_Graphics.YELLOW","kind":"ada_constant","location":{"file":"src/easy_graphics.ads","line":43,"column":4},"code":"YELLOW  : constant RGBA_8 := (255, 255, 0, 255);","documentation":{"description":"Totally transparent colour..."}}],"exceptions":[{"id":"029f354467b9c2a0","name":"Too_Many_Colours","qualified_name":"Easy_Graphics.Too_Many_Colours","kind":"ada_exception","location":{"file":"src/easy_graphics.ads","line":175,"column":4},"code":"Too_Many_Colours : exception;"}],"subprograms":[{"id":"b661ff54ae5532cc","name":"Back","qualified_name":"Easy_Graphics.Back","kind":"ada_procedure","location":{"file":"src/easy_graphics.ads","line":170,"column":14},"code":"procedure Back      (Turtle : in out Turtle_Rec; Steps  : Natural)"},{"id":"9a30f21f78441522","name":"Char","qualified_name":"Easy_Graphics.Char","kind":"ada_procedure","location":{"file":"src/easy_graphics.ads","line":114,"column":14},"code":"procedure Char (Img : in out Easy_Image;\n                Chr : Character;\n                Baseline : Point;\n                Height, Width : Positive;\n                Colour : RGBA_8;\n                Thickness : Weight := Normal)","documentation":{"description":"Draw a character on the image using the built-in 16-segment style font.\nThe font is intended only for simple annotations and consists of (latin)\nletter, numeric, and a few symbol characters.  Characters not in the\nfont will be displayed as spaces.\nIt is suggested that Height := 2 * Width.","parameters":[{"name":"Img","description":""},{"name":"Chr","description":""},{"name":"Baseline","description":""},{"name":"Height","description":""},{"name":"Width","description":""},{"name":"Colour","description":""},{"name":"Thickness","description":""}]}},{"id":"c12ce1c4c703dd6f","name":"Circle","qualified_name":"Easy_Graphics.Circle","kind":"ada_procedure","location":{"file":"src/easy_graphics.ads","line":104,"column":14},"code":"procedure Circle (Img    : in out Easy_Image;\n                  Centre : Point;\n                  Radius : Positive;\n                  Colour : RGBA_8;\n                  Fill   : Filled_Or_Outline)","documentation":{"description":"Draw an optionally filled circle using the given centre-point,\nradius, & colour using Bresenham's algorithm.","parameters":[{"name":"Img","description":""},{"name":"Centre","description":""},{"name":"Radius","description":""},{"name":"Colour","description":""},{"name":"Fill","description":""}]}},{"id":"c99416b241b7288c","name":"Fill","qualified_name":"Easy_Graphics.Fill","kind":"ada_procedure","location":{"file":"src/easy_graphics.ads","line":82,"column":14},"code":"procedure Fill (Img : in out Easy_Image; Colour : RGBA_8)","documentation":{"description":"Fill given image with colour.","parameters":[{"name":"Img","description":""},{"name":"Colour","description":""}]}},{"id":"dfd4e36888dd92f8","name":"Forward","qualified_name":"Easy_Graphics.Forward","kind":"ada_procedure","location":{"file":"src/easy_graphics.ads","line":169,"column":14},"code":"procedure Forward   (Turtle : in out Turtle_Rec; Steps  : Natural)"},{"id":"c4d608cc42f0dcad","name":"Go_To","qualified_name":"Easy_Graphics.Go_To","kind":"ada_procedure","location":{"file":"src/easy_graphics.ads","line":163,"column":14},"code":"procedure Go_To     (Turtle : in out Turtle_Rec; Position : Point)","documentation":{"description":"Set the position of the Turtle","parameters":[{"name":"Turtle","description":""},{"name":"Position","description":""}]}},{"id":"345d4d4bf1fa5094","name":"Home","qualified_name":"Easy_Graphics.Home","kind":"ada_procedure","location":{"file":"src/easy_graphics.ads","line":160,"column":14},"code":"procedure Home      (Turtle : in out Turtle_Rec)","documentation":{"description":"Centre the turtle","parameters":[{"name":"Turtle","description":""}]}},{"id":"b4a1ab4b27795b2e","name":"HSV_To_RGB","qualified_name":"Easy_Graphics.HSV_To_RGB","kind":"ada_function","location":{"file":"src/easy_graphics.ads","line":47,"column":13},"code":"function HSV_To_RGB (H, S, V : Float) return RGBA_8","documentation":{"description":"Convert given HSV colour to RGBA_8","parameters":[{"name":"H","description":""},{"name":"S","description":""},{"name":"V","description":""}]}},{"id":"d266f280c079e7d1","name":"Left","qualified_name":"Easy_Graphics.Left","kind":"ada_procedure","location":{"file":"src/easy_graphics.ads","line":171,"column":14},"code":"procedure Left      (Turtle : in out Turtle_Rec; Angle  : Degrees)"},{"id":"f199fac08c9728b7","name":"Line","qualified_name":"Easy_Graphics.Line","kind":"ada_procedure","location":{"file":"src/easy_graphics.ads","line":85,"column":14},"code":"procedure Line (Img : in out Easy_Image;\n                Start, Stop : Point;\n                Colour : RGBA_8)","documentation":{"description":"Draw line from Start to Stop using Bresenham's algorithm.\nShamelessly adapted from Rosetta Code task.","parameters":[{"name":"Img","description":""},{"name":"Start","description":""},{"name":"Stop","description":""},{"name":"Colour","description":""}]}},{"id":"a2c2691a16fb28f1","name":"New_Image","qualified_name":"Easy_Graphics.New_Image","kind":"ada_function","location":{"file":"src/easy_graphics.ads","line":56,"column":13},"code":"function New_Image (Bottom_Left, Top_Right : Point; Colour : RGBA_8) return Easy_Image","documentation":{"description":"Create a new Easy_Image.","parameters":[{"name":"Bottom_Left","description":""},{"name":"Top_Right","description":""},{"name":"Colour","description":""}],"returns":"a new Easy_Image with the specified bounds and colour."}},{"id":"7ca25443ce65e46a","name":"New_Turtle","qualified_name":"Easy_Graphics.New_Turtle","kind":"ada_function","location":{"file":"src/easy_graphics.ads","line":158,"column":13},"code":"function New_Turtle (Img_Acc : access Easy_Image) return Turtle_Rec"},{"id":"64fba09b0b9b4658","name":"Pen_Color","qualified_name":"Easy_Graphics.Pen_Color","kind":"ada_procedure","location":{"file":"src/easy_graphics.ads","line":168,"column":14},"code":"procedure Pen_Color (Turtle : in out Turtle_Rec; Colour : RGBA_8)"},{"id":"4918983e6bee55bd","name":"Pen_Down","qualified_name":"Easy_Graphics.Pen_Down","kind":"ada_procedure","location":{"file":"src/easy_graphics.ads","line":167,"column":14},"code":"procedure Pen_Down  (Turtle : in out Turtle_Rec)"},{"id":"8c73ae5bba4c2d3e","name":"Pen_Up","qualified_name":"Easy_Graphics.Pen_Up","kind":"ada_procedure","location":{"file":"src/easy_graphics.ads","line":166,"column":14},"code":"procedure Pen_Up    (Turtle : in out Turtle_Rec)"},{"id":"c7a376a4157b60a3","name":"Plot","qualified_name":"Easy_Graphics.Plot","kind":"ada_procedure","location":{"file":"src/easy_graphics.ads","line":74,"column":14},"code":"procedure Plot (Img : in out Easy_Image; Pt : Point; Colour : RGBA_8)","documentation":{"description":"Sets a single pixel to the given colour.\nN.B. Does nothing if given coordinates are outside the image boundary.","parameters":[{"name":"Img","description":""},{"name":"Pt","description":""},{"name":"Colour","description":""}]}},{"id":"344ec40bfbe1a2e3","name":"Rect","qualified_name":"Easy_Graphics.Rect","kind":"ada_procedure","location":{"file":"src/easy_graphics.ads","line":91,"column":14},"code":"procedure Rect (Img : in out Easy_Image;\n                Bottom_Left, Top_Right : Point;\n                Colour : RGBA_8;\n                Fill   : Filled_Or_Outline)","documentation":{"description":"Draw a horizontally-aligned rectangle on the image.\nOptionally filled.","parameters":[{"name":"Img","description":""},{"name":"Bottom_Left","description":""},{"name":"Top_Right","description":""},{"name":"Colour","description":""},{"name":"Fill","description":""}]}},{"id":"cb66ee0a7a7398fe","name":"Right","qualified_name":"Easy_Graphics.Right","kind":"ada_procedure","location":{"file":"src/easy_graphics.ads","line":172,"column":14},"code":"procedure Right     (Turtle : in out Turtle_Rec; Angle  : Degrees)"},{"id":"50460ba013763d84","name":"Set_Alpha","qualified_name":"Easy_Graphics.Set_Alpha","kind":"ada_procedure","location":{"file":"src/easy_graphics.ads","line":78,"column":14},"code":"procedure Set_Alpha (Img : in out Easy_Image; Pt : Point; Alpha : Level_8)","documentation":{"description":"Changes the Alpha (transparency) value of the specified point.\nN.B. Does nothing if given coordinates are outside the image boundary.","parameters":[{"name":"Img","description":""},{"name":"Pt","description":""},{"name":"Alpha","description":""}]}},{"id":"50d8769044656db2","name":"Text","qualified_name":"Easy_Graphics.Text","kind":"ada_procedure","location":{"file":"src/easy_graphics.ads","line":126,"column":14},"code":"procedure Text (Img : in out Easy_Image;\n                S   : String;\n                Bottom_Left : Point;\n                Height, Width, Spacing : Positive;\n                Colour : RGBA_8;\n                Thickness : Weight := Normal)","documentation":{"description":"Draw a string on the image using the 16-segment style built-in font.\nThe font is intended only for simple annotations and consists of (latin)\nletter, numeric, and a few symbol characters.  Characters not in the\nfont will be displayed as spaces.\nThe _character_ height and width must be specified and it is suggested\nthat Height := 2 * Width.\nSpacing is the number of points that will separate each character.","parameters":[{"name":"Img","description":""},{"name":"S","description":""},{"name":"Bottom_Left","description":""},{"name":"Height","description":""},{"name":"Width","description":""},{"name":"Spacing","description":""},{"name":"Colour","description":""},{"name":"Thickness","description":""}]}},{"id":"982107f6c09e7100","name":"Triangle","qualified_name":"Easy_Graphics.Triangle","kind":"ada_procedure","location":{"file":"src/easy_graphics.ads","line":98,"column":14},"code":"procedure Triangle (Img        : in out Easy_Image;\n                    P1, P2, P3 : Point;\n                    Colour     : RGBA_8;\n                    Fill       : Filled_Or_Outline)","documentation":{"description":"Draw an optionally filled triangle on the given image.","parameters":[{"name":"Img","description":""},{"name":"P1","description":""},{"name":"P2","description":""},{"name":"P3","description":""},{"name":"Colour","description":""},{"name":"Fill","description":""}]}},{"id":"005c50982e2a9450","name":"Turn_To","qualified_name":"Easy_Graphics.Turn_To","kind":"ada_procedure","location":{"file":"src/easy_graphics.ads","line":173,"column":14},"code":"procedure Turn_To   (Turtle : in out Turtle_Rec; Heading : Degrees)"},{"id":"e66b9c87d9d59121","name":"Write_GIF","qualified_name":"Easy_Graphics.Write_GIF","kind":"ada_procedure","location":{"file":"src/easy_graphics.ads","line":150,"column":14},"code":"procedure Write_GIF (Img : Easy_Image;  Filename : String)","documentation":{"description":"Write a (currently uncompressed) GIF file to disk.\nCurrently restricted to images with fewer than 128 colours.","parameters":[{"name":"Img","description":""},{"name":"Filename","description":""}]}},{"id":"e14e9bef21cc3336","name":"Write_PAM","qualified_name":"Easy_Graphics.Write_PAM","kind":"ada_procedure","location":{"file":"src/easy_graphics.ads","line":145,"column":14},"code":"procedure Write_PAM (Img : Easy_Image;  Filename : String)","documentation":{"description":"Write an image as a PAM file to disk using plain (ASCII) or raw (mostly binary) format.\nAlpha (transparency) values are included in the image.\nThere is no compression whatsoever.","parameters":[{"name":"Img","description":""},{"name":"Filename","description":""}]}},{"id":"59dd8e7072c56ce0","name":"Write_PPM","qualified_name":"Easy_Graphics.Write_PPM","kind":"ada_procedure","location":{"file":"src/easy_graphics.ads","line":140,"column":14},"code":"procedure Write_PPM (Img : Easy_Image;  Filename : String; Plain_Raw : PPM_Type := Raw)","documentation":{"description":"Write an image as a PPM file to disk using plain (ASCII) or raw (mostly binary) format.\nAlpha (transparency) values are ignored as they are not supported by this format.\nRaw PPMs are significantly smaller than plain, but there is still no compression whatsoever.","parameters":[{"name":"Img","description":""},{"name":"Filename","description":""},{"name":"Plain_Raw","description":""}]}},{"id":"ec6ad0b90149b6b3","name":"X_First","qualified_name":"Easy_Graphics.X_First","kind":"ada_function","location":{"file":"src/easy_graphics.ads","line":60,"column":13},"code":"function X_First (Img : Easy_Image) return Integer"},{"id":"23e173c542b0767c","name":"X_Last","qualified_name":"Easy_Graphics.X_Last","kind":"ada_function","location":{"file":"src/easy_graphics.ads","line":62,"column":13},"code":"function X_Last  (Img : Easy_Image) return Integer"},{"id":"429ad5b677f98cbc","name":"Xs","qualified_name":"Easy_Graphics.Xs","kind":"ada_function","location":{"file":"src/easy_graphics.ads","line":66,"column":13},"code":"function Xs (Img : Easy_Image) return Ordinates_Arr","documentation":{"description":"Returns an array containing all X ordinates, suitable for iterating via 'of'.","parameters":[{"name":"Img","description":""}]}},{"id":"a4911274e68346e4","name":"Y_First","qualified_name":"Easy_Graphics.Y_First","kind":"ada_function","location":{"file":"src/easy_graphics.ads","line":61,"column":13},"code":"function Y_First (Img : Easy_Image) return Integer"},{"id":"fff30416c05261a5","name":"Y_Last","qualified_name":"Easy_Graphics.Y_Last","kind":"ada_function","location":{"file":"src/easy_graphics.ads","line":63,"column":13},"code":"function Y_Last  (Img : Easy_Image) return Integer"},{"id":"8312ce34defb7a9c","name":"Ys","qualified_name":"Easy_Graphics.Ys","kind":"ada_function","location":{"file":"src/easy_graphics.ads","line":68,"column":13},"code":"function Ys (Img : Easy_Image) return Ordinates_Arr","documentation":{"description":"Returns an array containing all Y ordinates, suitable for iterating via 'of'.","parameters":[{"name":"Img","description":""}]}}]}