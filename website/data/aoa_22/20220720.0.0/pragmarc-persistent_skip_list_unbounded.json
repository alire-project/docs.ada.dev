 in Persistent_Skip_List) return Natural","documentation":{"description":"Returns a count of the number of values stored in List\n\nTime : O(1)","parameters":[{"name":"List","description":""}]}},{"id":"247858313d2b7d45","name":"Open_List","qualified_name":"PragmARC.Persistent_Skip_List_Unbounded.Open_List","kind":"ada_function","location":{"file":"../../../home/runner/.local/share/alire/builds/pragmarc_20240323.0.0_31d8919a/e70a8c739ac58c125da41ab4417fc0154dea7b33835cea0fd59dd11d63775117/src/pragmarc-persistent_skip_list_unbounded.ads","line":36,"column":13},"code":"function Open_List (Filename : in String; Write_On_Modify : in Boolean := False) return Persistent_Skip_List","documentation":{"description":"If a file named Filename exists, opens it and reads it into a Persistent_Skip_List, which is returned\nOtherwise, creates an empty file named Filename and returns an empty Persistent_Skip_List\nRaises Invalid_File if Filename exists but does not represent a valid Persistent_Skip_List\nif Write_On_Modify, the list will be written to Filename whenever it is modified (safer but slower)\nOtherwise, it will be written when finalized (Faster but less safe)","parameters":[{"name":"Filename","description":""},{"name":"Write_On_Modify","description":""}]}},{"id":"5bf925358153198d","name":"Search","qualified_name":"PragmARC.Persistent_Skip_List_Unbounded.Search","kind":"ada_function","location":{"file":"../../../home/runner/.local/share/alire/builds/pragmarc_20240323.0.0_31d8919a/e70a8c739ac58c125da41ab4417fc0154dea7b33835cea0fd59dd11d63775117/src/pragmarc-persistent_skip_list_unbounded.ads","line":58,"column":13},"code":"function Search (List : in Persistent_Skip_List; Item : in Element) return Result","documentation":{"description":"If there exists a value stored in List such that Value = Item, returns (Found => True, Item => Value)\nReturns (Found => False) otherwise\n\nTime: approximately O(log N)","parameters":[{"name":"List","description":""},{"name":"Item","description":""}]}}],"formals":[{"id":"ea0ca170cb54b463","name":"\"<\"","qualified_name":"PragmARC.Persistent_Skip_List_Unbounded.\"<\"","kind":"ada_formal","location":{"file":"../../../home/runner/.local/share/alire/builds/pragmarc_20240323.0.0_31d8919a/e70a8c739ac58c125da41ab4417fc0154dea7b33835cea0fd59dd11d63775117/src/pragmarc-persistent_skip_list_unbounded.ads","line":25,"column":18},"code":"function \"<\" (Left : in Element; Right : in Element) return Boolean","documentation":{"description":"Orders Elements; usually will work on a part (the key) of an Element\nElements will be ordered in ascending order according to \"<\"","parameters":[{"name":"Left","description":""},{"name":"Right","description":""}]}},{"id":"16114dc2eb28acba","name":"\"=\"","qualified_name":"PragmARC.Persistent_Skip_List_Unbounded.\"=\"","kind":"ada_formal","location":{"file":"../../../home/runner/.local/share/alire/builds/pragmarc_20240323.0.0_31d8919a/e70a8c739ac58c125da41ab4417fc0154dea7b33835cea0fd59dd11d63775117/src/pragmarc-persistent_skip_list_unbounded.ads","line":29,"column":18},"code":"function \"=\" (Left : in Element; Right : in Element) return Boolean","documentation":{"description":"Usually operates on part (the key) of an Element","parameters":[{"name":"Left","description":""},{"name":"Right","description":""}]}},{"id":"c98e8e822c8356f2","name":"Element","qualified_name":"PragmARC.Persistent_Skip_List_Unbounded.Element","kind":"ada_formal","location":{"file":"../../../home/runner/.local/share/alire/builds/pragmarc_20240323.0.0_31d8919a/e70a8c739ac58c125da41ab4417fc0154dea7b33835cea0fd59dd11d63775117/src/pragmarc-persistent_skip_list_unbounded.ads","line":23,"column":9},"code":"type Element is private;","documentation":{"description":"Values to store in the list"}}]}