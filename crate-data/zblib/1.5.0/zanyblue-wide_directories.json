":"ada_function","location":{"file":"os/zanyblue-wide_directories.ads","line":178,"column":13},"code":"function Wide_Kind\n   (Directory_Entry : Wide_Directory_Entry_Type) return Wide_File_Kind","documentation":{"description":"Returns the kind of external file represented by Directory_Entry.","parameters":[{"name":"Directory_Entry","description":""}]}},{"id":"f04f97542c472bac","name":"Wide_Modification_Time","qualified_name":"ZanyBlue.Wide_Directories.Wide_Modification_Time","kind":"ada_function","location":{"file":"os/zanyblue-wide_directories.ads","line":122,"column":13},"code":"function Wide_Modification_Time\n   (Name : Wide_String) return Ada.Calendar.Time","documentation":{"description":"Returns the time that the external file represented by Name was most\nrecently modified.","parameters":[{"name":"Name","description":""}]}},{"id":"03a106b679a09b00","name":"Wide_Modification_Time","qualified_name":"ZanyBlue.Wide_Directories.Wide_Modification_Time","kind":"ada_function","location":{"file":"os/zanyblue-wide_directories.ads","line":186,"column":13},"code":"function Wide_Modification_Time\n  (Directory_Entry : Wide_Directory_Entry_Type) return Ada.Calendar.Time","documentation":{"description":"Returns the time that the external file represented by Directory_Entry\nwas most recently modified.","parameters":[{"name":"Directory_Entry","description":""}]}},{"id":"dd4eebb1cbb63ec3","name":"Wide_More_Entries","qualified_name":"ZanyBlue.Wide_Directories.Wide_More_Entries","kind":"ada_function","location":{"file":"os/zanyblue-wide_directories.ads","line":149,"column":13},"code":"function Wide_More_Entries (Search : Wide_Search_Type) return Boolean","documentation":{"description":"Returns True if more entries are available to be returned by a call\nto Get_Next_Entry for the specified search object, and False otherwise.","parameters":[{"name":"Search","description":""}]}},{"id":"4b2b528f07eeaa17","name":"Wide_Rename","qualified_name":"ZanyBlue.Wide_Directories.Wide_Rename",