ure","location":{"file":"os/zanyblue-wide_directories.ads","line":70,"column":14},"code":"procedure Wide_Delete_File (Name : Wide_String)","documentation":{"description":"Deletes an existing ordinary or special file with Name.","parameters":[{"name":"Name","description":""}]}},{"id":"2430d90c97819a5d","name":"Wide_Delete_Tree","qualified_name":"ZanyBlue.Wide_Directories.Wide_Delete_Tree","kind":"ada_procedure","location":{"file":"os/zanyblue-wide_directories.ads","line":67,"column":14},"code":"procedure Wide_Delete_Tree (Directory : Wide_String)","documentation":{"description":"Deletes an existing directory with name Directory.","parameters":[{"name":"Directory","description":""}]}},{"id":"85452ab1ef36b47c","name":"Wide_End_Search","qualified_name":"ZanyBlue.Wide_Directories.Wide_End_Search","kind":"ada_procedure","location":{"file":"os/zanyblue-wide_directories.ads","line":146,"column":14},"code":"procedure Wide_End_Search (Search : in out Wide_Search_Type)","documentation":{"description":"Ends the search represented by Search.","parameters":[{"name":"Search","description":""}]}},{"id":"60e626cc73a0e4dd","name":"Wide_Exists","qualified_name":"ZanyBlue.Wide_Directories.Wide_Exists","kind":"ada_function","location":{"file":"os/zanyblue-wide_directories.ads","line":112,"column":13},"code":"function Wide_Exists (Name : Wide_String) return Boolean","documentation":{"description":"Returns True if external file represented by Name exists, and False\notherwise.","parameters":[{"name":"Name","description":""}]}},{"id":"3d151f0f82ee6749","name":"Wide_Extension","qualified_name":"ZanyBlue.Wide_Directories.Wide_Extension","kind":"ada_function","location":{"file":"os/zanyblue-wide_directories.ads","line":92,"column":13},"code":"function Wide_Extension (Name : Wide_String) return Wide_String","documentation":{"description":"Returns the extension name corresponding to Name.","parameters":[{"name":"Name","description":""}]}},{"id":"3ea18fe833ec791f","name":"Wide_Full_Name","qualif