yBlue.Wide_Directories.Wide_Simple_Name","kind":"ada_function","location":{"file":"os/zanyblue-wide_directories.ads","line":168,"column":13},"code":"function Wide_Simple_Name\n   (Directory_Entry : Wide_Directory_Entry_Type) return Wide_String","documentation":{"description":"Returns the simple external name of the external file (including\ndirectories) represented by Directory_Entry.","parameters":[{"name":"Directory_Entry","description":""}]}},{"id":"871d0fe62b1c579d","name":"Wide_Size","qualified_name":"ZanyBlue.Wide_Directories.Wide_Size","kind":"ada_function","location":{"file":"os/zanyblue-wide_directories.ads","line":119,"column":13},"code":"function Wide_Size (Name : Wide_String) return Wide_File_Size","documentation":{"description":"Returns the size of the external file represented by Name.","parameters":[{"name":"Name","description":""}]}},{"id":"1d53a6908cec1477","name":"Wide_Size","qualified_name":"ZanyBlue.Wide_Directories.Wide_Size","kind":"ada_function","location":{"file":"os/zanyblue-wide_directories.ads","line":182,"column":13},"code":"function Wide_Size\n   (Directory_Entry : Wide_Directory_Entry_Type) return Wide_File_Size","documentation":{"description":"Returns the size of the external file represented by Directory_Entry.","parameters":[{"name":"Directory_Entry","description":""}]}},{"id":"d0bb08a0c7e3b1a9","name":"Wide_Start_Search","qualified_name":"ZanyBlue.Wide_Directories.Wide_Start_Search","kind":"ada_procedure","location":{"file":"os/zanyblue-wide_directories.ads","line":137,"column":14},"code":"procedure Wide_Start_Search\n  (Search    : in out Wide_Search_Type;\n   Directory : Wide_String;\n   Pattern   : Wide_String;\n   Filter    : Wide_Filter_Type := (others => True))","documentation":{"description":"Starts a search in the directory entry in the directory named by\nDirectory for entries matching Pattern. Pattern represents a file name\nmatching pattern.","parameters":[{"name":"Search","description":""},{"name":"Directory","descriptio