{"schema_version":"1","crate":"braillart","version":"0.1.0","id":"4ee922e25afc1a84","name":"Braillart","qualified_name":"Braillart","kind":"ada_package","location":{"file":"src/braillart.ads","line":3,"column":9},"code":"package Braillart","documentation":{"description":"Facilities to use Braille characters as a kind of dot-matrix"},"array_types":[{"id":"3a1b8b95de6d6ed9","name":"Cell_Matrix","qualified_name":"Braillart.Cell_Matrix","kind":"ada_array_type","location":{"file":"src/braillart.ads","line":39,"column":9},"code":"type Cell_Matrix is array (Rows, Cols) of Boolean with\n  Component_Size => 1,\n  Size           => 8,\n  Convention     => Fortran;"},{"id":"bfa3389bb1da2d42","name":"Full_Matrix","qualified_name":"Braillart.Full_Matrix","kind":"ada_array_type","location":{"file":"src/braillart.ads","line":63,"column":9},"code":"type Full_Matrix is array (Rows'Base range <>, Cols'Base range <>) of Boolean;"},{"id":"ad0ca98d9a414a40","name":"Line_Matrix","qualified_name":"Braillart.Line_Matrix","kind":"ada_array_type","location":{"file":"src/braillart.ads","line":56,"column":9},"code":"type Line_Matrix is array (Rows range <>, Cols'Base range <>) of Boolean;","documentation":{"description":"A whole line given as a continuous matrix"}},{"id":"85e875a5b9dc1255","name":"Matrix_Array","qualified_name":"Braillart.Matrix_Array","kind":"ada_array_type","location":{"file":"src/braillart.ads","line":50,"column":9},"code":"type Matrix_Array is array (Positive range <>) of Cell_Matrix;"}],"subtypes":[{"id":"a27750e731426572","name":"BChar","qualified_name":"Braillart.BChar","kind":"ada_subtype","location":{"file":"src/braillart.ads","line":11,"column":12},"code":"subtype BChar is UChar range UChar'Val (16#2800#) .. UChar'Val (16#28FF#);","documentation":{"description":"Braille patterns are like a binary counter, growing in row-first order,\nfrom the top-left. There is a catch in that a full 3x2 matrix is filled\nfirst, and the last row for a 4x2 matrix is filled next. Hence, values\n1, 2, 4 grow with the Char values but then the sequence changes:\n16#2800# = '⠀', 16#2801# = '⠁', 16#2802# = '⠂', 16#2803# = '⠃',\n16#2804# = '⠄', but 16#2848# = '⡀', whereas 16#2808# = '⠈'. This\nmakes not straightforward to apply 'Val. Instead, use Value below or the\nPatterns array for such low-level manipulation (or any of the high-level\nmatrices below)."}},{"id":"ab1a4eea064e2e5f","name":"BCount","qualified_name":"Braillart.BCount","kind":"ada_subtype","location":{"file":"src/braillart.ads","line":27,"column":12},"code":"subtype BCount is Natural range 0 .. 255;"},{"id":"82ed70e8215f706a","name":"BString","qualified_name":"Braillart.BString","kind":"ada_subtype","location":{"file":"src/braillart.ads","line":22,"column":12},"code":"subtype BString is UString with\n  Predicate => (for all C of BString => C in BChar);"},{"id":"e3dac8c6519f8f11","name":"Cols","qualified_name":"Braillart.Cols","kind":"ada_subtype","location":{"file":"src/braillart.ads","line":37,"column":12},"code":"subtype Cols is Positive range 1 .. 2;"},{"id":"79a3be42c88ce7a3","name":"Line_List","qualified_name":"Braillart.Line_List","kind":"ada_subtype","location":{"file":"src/braillart.ads","line":68,"column":12},"code":"subtype Line_List is Line_Lists.List;"},{"id":"add4b6f3400c006b","name":"Rows","qualified_name":"Braillart.Rows","kind":"ada_subtype","location":{"file":"src/braillart.ads","line":36,"column":12},"code":"subtype Rows is Positive range 1 .. 4;"},{"id":"0822ed4e157e6ad5","name":"UChar","qualified_name":"Braillart.UChar","kind":"ada_subtype","location":{"file":"src/braillart.ads","line":7,"column":12},"code":"subtype UChar is Wide_Wide_Character;"},{"id":"b80d0ce111d627cc","name":"UString","qualified_name":"Braillart.UString","kind":"ada_subtype","location":{"file":"src/braillart.ads","line":8,"column":12},"code":"subtype UString is Wide_Wide_String;"}],"constants":[{"id":"85ca842538481cc2","name":"Patterns","qualified_name":"Braillart.Patterns","kind":"ada_constant","location":{"file":"src/braillart.ads","line":74,"column":4},"code":"Patterns : constant array (BCount) of BChar :=\n  ('⠀', '⠁', '⠂', '⠃', '⠄', '⠅', '⠆', '⠇', '⡀', '⡁', '⡂', '⡃', '⡄', '⡅', '⡆', '⡇',\n   '⠈', '⠉', '⠊', '⠋', '⠌', '⠍', '⠎', '⠏', '⡈', '⡉', '⡊', '⡋', '⡌', '⡍', '⡎', '⡏',\n   …\n   '⢸', '⢹', '⢺', '⢻', '⢼', '⢽', '⢾', '⢿', '⣸', '⣹', '⣺', '⣻', '⣼', '⣽', '⣾', '⣿');"}],"subprograms":[{"id":"2d736808fd7bea59","name":"Canvas","qualified_name":"Braillart.Canvas","kind":"ada_function","location":{"file":"src/braillart.ads","line":70,"column":13},"code":"function Canvas (M : Full_Matrix) return Line_List"},{"id":"3f1c88726081d153","name":"Cell","qualified_name":"Braillart.Cell","kind":"ada_function","location":{"file":"src/braillart.ads","line":46,"column":13},"code":"function Cell (M : Cell_Matrix) return BChar"},{"id":"385b02033de4a48f","name":"Cell_Line","qualified_name":"Braillart.Cell_Line","kind":"ada_function","location":{"file":"src/braillart.ads","line":52,"column":13},"code":"function Cell_Line (M : Matrix_Array) return BString"},{"id":"cf16aabc70740dcb","name":"Dot","qualified_name":"Braillart.Dot","kind":"ada_function","location":{"file":"src/braillart.ads","line":44,"column":13},"code":"function Dot (R : Rows; C : Cols) return BChar"},{"id":"691e870f43757b58","name":"Panorama","qualified_name":"Braillart.Panorama","kind":"ada_function","location":{"file":"src/braillart.ads","line":59,"column":13},"code":"function Panorama (M : Line_Matrix) return BString"},{"id":"acf864432c171318","name":"Value","qualified_name":"Braillart.Value","kind":"ada_function","location":{"file":"src/braillart.ads","line":29,"column":13},"code":"function Value (Pos : BCount) return BChar","documentation":{"description":"Note that this is not the Unicode code-point order! This returns the\npatterns in the order of Patterns at the end of this package. (What\nwould be the \"natural\" order for a 4x2 matrix.)","parameters":[{"name":"Pos","description":""}]}}],"generic_instantiations":[{"id":"2c72f988963b9e54","name":"Line_Lists","qualified_name":"Braillart.Line_Lists","kind":"ada_package_instantiation","location":{"file":"src/braillart.ads","line":65,"column":12},"code":"package Line_Lists is new\n  Ada.Containers.Indefinite_Doubly_Linked_Lists (BString);"}]}