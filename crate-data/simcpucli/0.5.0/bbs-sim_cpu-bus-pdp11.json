1.readp","kind":"ada_function","location":{"file":"../../../../home/runner/.local/share/alire/builds/bbs_simcpu_0.5.0_c779a728/9cdc441e7ff3f33fced7ac7acaa0da633fb83bcec604d59dd89b3ca09151f539/src/bus/bbs-sim_cpu-bus-pdp11.ads","line":110,"column":13},"code":"function readp(self : in out unibus; addr : addr_bus; status : out bus_stat) return data_bus"},{"id":"9a83fc1a27a303d3","name":"reset","qualified_name":"BBS.Sim_CPU.bus.pdp11.reset","kind":"ada_procedure","location":{"file":"../../../../home/runner/.local/share/alire/builds/bbs_simcpu_0.5.0_c779a728/9cdc441e7ff3f33fced7ac7acaa0da633fb83bcec604d59dd89b3ca09151f539/src/bus/bbs-sim_cpu-bus-pdp11.ads","line":141,"column":14},"code":"procedure reset(self : in out unibus)","documentation":{"description":"========================================================================","parameters":[{"name":"self","description":""}]}},{"id":"2d8a02b941e0d807","name":"set_max_addr","qualified_name":"BBS.Sim_CPU.bus.pdp11.set_max_addr","kind":"ada_procedure","location":{"file":"../../../../home/runner/.local/share/alire/builds/bbs_simcpu_0.5.0_c779a728/9cdc441e7ff3f33fced7ac7acaa0da633fb83bcec604d59dd89b3ca09151f539/src/bus/bbs-sim_cpu-bus-pdp11.ads","line":129,"column":14},"code":"procedure set_max_addr(self : in out unibus; size : addr_bus)","documentation":{"description":"\n  Return this maximum address.  This should always be less than or equal to\n  the configured size.","parameters":[{"name":"self","description":""},{"name":"size","description":""}]}},{"id":"bd8541bf17d484da","name":"size","qualified_name":"BBS.Sim_CPU.bus.pdp11.size","kind":"ada_function","location":{"file":"../../../../home/runner/.local/share/alire/builds/bbs_simcpu_0.5.0_c779a728/9cdc441e7ff3f33fced7ac7acaa0da633fb83bcec604d59dd89b3ca09151f539/src/bus/bbs-sim_cpu-bus-pdp11.ads","line":70,"column":13},"code":"function size(self : in out unibus) return bus_size","documentation":{"description":"\n  Bus transactions from the processor depend on the address, the processor\n  mode, and the address type.  An address type of ADDR_IO signifies I/O\n  addresses for processors that implement them.  These functions may\n  include address translation.\n\n  These are read logical and write logical.  The logical address may be translated\n  into a physical address.\n\n\n  Read various sizes in LSB first","parameters":[{"name":"self","description":""}]}},{"id":"440914275125ab4b","name":"writel16l","qualified_name":"BBS.Sim_CPU.bus.pdp11.writel16l","kind":"ada_procedure","location":{"file":"../../../../home/runner/.local/share/alire/builds/bbs_simcpu_0.5.0_c779a728/9cdc441e7ff3f33fced7ac7acaa0da633fb83bcec604d59dd89b3ca09151f539/src/bus/bbs-sim_cpu-bus-pdp11.ads","line":96,"column":14},"code":"procedure writel16l(self : in out unibus; addr : addr_bus; data : word; mode : proc_mode;\n                 addr_kind : addr_type; status : out bus_stat)","documentation":{"description":"\n  Bus transactions from I/O devices are generally direct to memory (DMA) without\n  address translation.  The I/O device must be given the physical address to use.\n\n  These are read physical and write physical.  The physical address is used\n  directly to access memory.\n\n  Note that with 22 bit addressing, a unibus map registers may be used to\n  translate from 18 bit unibus addresses to 22 bit memory addresses.  Some\n  devices however can use 22 bit addressing.","parameters":[{"name":"self","description":""},{"name":"addr","description":""},{"name":"data","description":""},{"name":"mode","description":""},{"name":"addr_kind","description":""},{"name":"status","description":""}]}},{"id":"858ca28eba20fd8f","name":"writel8l","qualified_name":"BBS.Sim_CPU.bus.pdp11.writel8l","kind":"ada_procedure","location":{"file":"../../../../home/runner/.local/share/alire/builds/bbs_simcpu_0.5.0_c779a728/9cdc441e7ff3f33fced7ac7acaa0da633fb83bcec604d59dd89b3ca09151f539/src/bus/bbs-sim_cpu-bus-pdp11.ads","line":93,"column":14},"code":"procedure writel8l(self : in out unibus; addr : addr_bus; data : byte; mode : proc_mode;\n                 addr_kind : addr_type; status : out bus_stat)","documentation":{"description":"\n  Bus transactions from I/O devices are generally direct to memory (DMA) without\n  address translation.  The I/O device must be given the physical address to use.\n\n  These are read physical and write physical.  The physical address is used\n  directly to access memory.\n\n  Note that with 22 bit addressing, a unibus map registers may be used to\n  translate from 18 bit unibus addresses to 22 bit memory addresses.  Some\n  devices however can use 22 bit addressing.","parameters":[{"name":"self","description":""},{"name":"addr","description":""},{"name":"data","description":""},{"name":"mode","description":""},{"name":"addr_kind","description":""},{"name":"status","description":""}]}},{"id":"90eedf5bd673d667","name":"writep","qualified_name":"BBS.Sim_CPU.bus.pdp11.writep","kind":"ada_procedure","location":{"file":"../../../../home/runner/.local/share/alire/builds/bbs_simcpu_0.5.0_c779a728/9cdc441e7ff3f33fced7ac7acaa0da633fb83bcec604d59dd89b3ca09151f539/src/bus/bbs-sim_cpu-bus-pdp11.ads","line":113,"column":14},"code":"procedure writep(self : in out unibus; addr : addr_bus; data: data_bus; status : out bus_stat)","documentation":{"description":"\n  Memory size and adjustment.  If not overridden, they will return 0 for\n  sizes and do nothing.\n\n  The the size that memory has been configured for.  This should not change\n  over the lifetime of the object.","parameters":[{"name":"self","description":""},{"name":"addr","description":""},{"name":"data","description":""},{"name":"status","description":""}]}}]}