rc-data_structures-skip_lists-unbounded.ads","line":40,"column":14},"code":"procedure Clear (List : in out Skip_List)","documentation":{"description":"Makes List empty\n\nTime: O(N)","parameters":[{"name":"List","description":""}]}},{"id":"af4ba74024aa9d08","name":"Delete","qualified_name":"PragmARC.Data_Structures.Skip_Lists.Unbounded.Delete","kind":"ada_procedure","location":{"file":"../../../home/runner/.local/share/alire/builds/pragmarc_20240323.0.0_31d8919a/e70a8c739ac58c125da41ab4417fc0154dea7b33835cea0fd59dd11d63775117/src/pragmarc-data_structures-skip_lists-unbounded.ads","line":78,"column":14},"code":"procedure Delete (List : in out Skip_List; Item : in Element)","documentation":{"description":"Deletes the value in List which is = Item\nIf there is no such value in List, this procedure has no effect\n\nTime : approximately O(log N)","parameters":[{"name":"List","description":""},{"name":"Item","description":""}]}},{"id":"bc7ee9d6e2c87ab1","name":"Get_First","qualified_name":"PragmARC.Data_Structures.Skip_Lists.Unbounded.Get_First","kind":"ada_function","location":{"file":"../../../home/runner/.local/share/alire/builds/pragmarc_20240323.0.0_31d8919a/e70a8c739ac58c125da41ab4417fc0154dea7b33835cea0fd59dd11d63775117/src/pragmarc-data_structures-skip_lists-unbounded.ads","line":84,"column":13},"code":"function Get_First (List : in Skip_List) return Element","documentation":{"description":"Returns the first value stored in List (values are ordered by \"<\")\n\nTime: O(1)","parameters":[{"name":"List","description":""}]}},{"id":"773046ecc8bb844a","name":"Get_Last","qualified_name":"PragmARC.Data_Structures.Skip_Lists.Unbounded.Get_Last","kind":"ada_function","location":{"file":"../../../home/runner/.local/share/alire/builds/pragmarc_20240323.0.0_31d8919a/e70a8c739ac58c125da41ab4417fc0154dea7b33835cea0fd59dd11d63775117/src/pragmarc-data_structures-skip_lists-unbounded.ads","line":90,"column":13},"code":"function Get_Last (List : in Skip_List) return Element","docum