ld_Date_Range is DateRanges.SQL_Field_Range;"}],"subprograms":[{"id":"a36b1c759a67b6b9","name":"\"&\"","qualified_name":"GNATCOLL.SQL.Postgres.\"&\"","kind":"ada_function","location":{"file":"gnatcoll-sql-postgres.ads","line":152,"column":13},"code":"function \"&\"\n  (Query     : SQL_Query;\n   Extension : SQL_PG_Extension'Class) return SQL_Query","documentation":{"description":"Extends an existing query with postgres-specific additions. For\ninstance:\n    R.Fetch (DB, SQL_Select (...) & Returning (Field1));","parameters":[{"name":"Query","description":""},{"name":"Extension","description":""}]}},{"id":"325fa7077347f429","name":"Build_Connection","qualified_name":"GNATCOLL.SQL.Postgres.Build_Connection","kind":"ada_function","location":{"file":"gnatcoll-sql-postgres.ads","line":38,"column":24},"code":"function Build_Connection\n  (Self : access Postgres_Description) return Database_Connection"},{"id":"7a47d17a56d229bc","name":"Consume_Input","qualified_name":"GNATCOLL.SQL.Postgres.Consume_Input","kind":"ada_procedure","location":{"file":"gnatcoll-sql-postgres.ads","line":92,"column":14},"code":"procedure Consume_Input (DB : Database_Connection)","documentation":{"description":"If input is available from the backend, consume it.\nNote that the result does not say whether any input\ndata was actually collected. After calling Consume_Input, the\napplication may check Is_Busy and/or Notifies to see if their state\nhas changed.\n\nConsume_Input may be called even if the application is not prepared to\ndeal with a result or notification just yet. The routine will read\navailable data and save it in a buffer, thereby causing a select(2)\nread-ready indication to go away. The application can thus use\nConsume_Input to clear the select condition immediately, and then\nexamine the results at leisure.","parameters":[{"name":"DB","description":""}]}},{"id":"2e451978373de2df","name":"For_Update","qualified_name":"GNATCOLL.SQL.Postgres.For_Update","kind":"ada_function","location":{"file":"gnatcoll-sql-postgres.ads","line":147,"column":13},"code":"function For_Update\n  (Tables  : SQL_Table_List := Empty_Table_List;\n   No_Wait : Boolean := False) return SQL_PG_Extension'Class","documentation":{"description":"FOR UPDATE clause for SELECT query","parameters":[{"name":"Tables","description":""},{"name":"No_Wait","description":""}]}},{"id":"7a1e5562ed1441b7","name":"Get_Connection_String","qualified_name":"GNATCOLL.SQL.Postgres.Get_Connection_String","kind":"ada_function","location":{"file":"gnatcoll-sql-postgres.ads","line":66,"column":13},"code":"function Get_Connection_String\n  (Description   : Database_Description;\n   With_Password : Boolean) return String","documentation":{"description":"Create a connection string from the database description","parameters":[{"name":"Description","description":""},{"name":"With_Password","description":""}]}},{"id":"0306fa27e558ca72","name":"Notifies","qualified_name":"GNATCOLL.SQL.Postgres.Notifies","kind":"ada_procedure","location":{"file":"gnatcoll-sql-postgres.ads","line":81,"column":14},"code":"procedure Notifies\n  (DB      : Database_Connection;\n   Message : out Notification;\n   Done    : out Boolean)","documentation":{"description":"Returns the next notification from a list of unhandled notification\nmessages received from the backend. Done is set to False if there are\nno pending notifications. In this case Message is not be set. If Done\nis set to False, Message contains a valid Notification. Once a\nnotification is returned from Notifies, it is considered handled and\nwill be removed from the list of notifications.","parameters":[{"name":"DB","description":""},{"name":"Message","description":""},{"name":"Done","description":""}]}},{"id":"1d49b1958c59b3d3","name":"OID_Field","qualified_name":"GNATCOLL.SQL.Postgres.OID_Field","kind":"ada_function","location":{"file":"gnatcoll-sql-postgres.ads","line":119,"column":13},"code":"function OID_Field (Table : SQL_Table'Class) return SQL_Field_Integer","documentation":{"description":"The object identifier field, available in each table. This is postgres\nspecific. It can be used for instance to retrieve the newly inserted\nrow in a table, by retrieving the OID of the previous result.\nWith recent versions of PostgreSQL, you must explicitly create the table\nwith support for oids (\"CREATE TABLE (...) WITH OIDS\"), otherwise the\noid will always be null. For this reason, and since oids slow things\ndone a little, and take space, it is not recommended to depend on them.","parameters":[{"name":"Table","description":""}]}},{"id":"27dd54560da0a7f5","name":"Regexp","qualified_name":"GNATCOLL.SQL.Postgres.Regexp","kind":"ada_function","location":{"file":"gnatcoll-sql-postgres.ads","line":131,"column":13},"code":"function Regexp\n  (Self : Text_Fields.Field'Class;\n   Str  : String) return SQL_Criteria","documentation":{"description":"Check whether the field matches a regular expression. This is the \"~*\"\noperator specific to postgreSQL.","parameters":[{"name":"Self","description":""},{"name":"Str","description":""}]}},{"id":"734d6edb2489ad77","name":"Returning","qualified_name":"GNATCOLL.SQL.Postgres.Returning","kind":"ada_function","location":{"file":"gnatcoll-sql-postgres.ads","line":144,"column":13},"code":"function Returning (Fields : SQL_Field_List) return SQL_PG_Extension'Class","documentation":{"description":"RETURNING clause for UPDATE query","parameters":[{"name":"Fields","description":""}]}},{"id":"f37e6920bff58723","name":"Setup","qualified_name":"GNATCOLL.SQL.Postgres.Setup","kind":"ada_function","location":{"file":"gnatcoll-sql-postgres.ads","line":50,"column":13},"code":"function Setup\n  (Database      : String;\n   User          : String := \"\";\n   Host          : String := \"\";\n   Password      : String := \"\";\n   Port          : Integer := -1;\n   SSL           : SSL_Mode := Allow;\n   Cache_Support : Boolean := True;\n   Errors        : access Error_Reporter'Class := null)\n  return Database_Description","documentation":{"description":"Return a database description for PostgreSQL.\nIf postgres was not detected at installation time, this function will\nreturn null.\nErrors (if specified) will be used to report errors and warnings to the\napplication. Errors is never freed.","parameters":[{"name":"Database","description":""},{"name":"User","description":""},{"name":"Host","description":""},{"name":"Password","description":""},{"name":"Port","description":""},{"name":"SSL","description":""},{"name":"Cache_Support","description":""},{"name":"Errors","description":""}]}},{"id":"0a2945930c4afd43","name":"To_String","qualified_name":"GNATCOLL.SQL.Postgres.To_String","kind":"ada_function","location":{"file":"gnatcoll-sql-postgres.ads","line":140,"column":13},"code":"function To_String\n   (Self : SQL_PG_Extension; Format : Formatter'Class)\n   return Ada.Strings.Unbounded.Unbounded_String"},{"id":"cc897e8acf24d893","name":"Wait_For_Input","qualified_name":"GNATCOLL.SQL.Postgres.Wait_For_Input","kind":"ada_function","location":{"file":"gnatcoll-sql-postgres.ads","line":106,"column":13},"code":"function Wait_For_Input\n  (DB      : Database_Connection;\n   Timeout : Duration := Duration'Last) return Boolean","documentation":{"description":"Waiting for available input and return False on timeout or True on\nsuccess. No need to call Consume_Input afterward, it is already called\ninternally on wait success.","parameters":[{"name":"DB","description":""},{"name":"Timeout","description":""}]}}],"generic_instantiations":[{"id":"4b8d5006c5793f94","name":"BigintRanges","qualified_name":"GNATCOLL.SQL.Postgres.BigintRanges","kind":"ada_package_instantiation","location":{"file":"gnatcoll-sql-postgres.ads","line":182,"column":12},"code":"package BigintRanges is new GNATCOLL.SQL.Ranges\n   (Base_Fields    => GNATCOLL.SQL.Bigint_Fields,\n    SQL_Type       => \"int8range\",\n    Ada_Field_Type => \"GNATCOLL.SQL.Postgres.SQL_Field_Bigint_Range\");"},{"id":"e21142b25e21ca87","name":"DateRanges","qualified_name":"GNATCOLL.SQL.Postgres.DateRanges","kind":"ada_package_instantiation","location":{"file":"gnatcoll-sql-postgres.ads","line":159,"column":12},"code":"package DateRanges is new GNATCOLL.SQL.Ranges\n   (Base_Fields    => GNATCOLL.SQL.Date_Fields,\n    SQL_Type       => \"daterange\",\n    Ada_Field_Type => \"GNATCOLL.SQL.Postgres.SQL_Field_Date_Range\");"},{"id":"a39f26bc3a93514a","name":"IntegerRanges","qualified_name":"GNATCOLL.SQL.Postgres.IntegerRanges","kind":"ada_package_instantiation","location":{"file":"gnatcoll-sql-postgres.ads","line":174,"column":12},"code":"package IntegerRanges is new GNATCOLL.SQL.Ranges\n   (Base_Fields    => GNATCOLL.SQL.Integer_Fields,\n    SQL_Type       => \"int4range\",\n    Ada_Field_Type => \"GNATCOLL.SQL.Postgres.SQL_Field_Integer_Range\");"},{"id":"95f4f8ccca4c8bcb","name":"Now","qualified_name":"GNATCOLL.SQL.Postgres.Now","kind":"ada_package_instantiation","location":{"file":"gnatcoll-sql-postgres.ads","line":128,"column":13},"code":"function Now is new Time_Fields.SQL_Function (\"now()\");","documentation":{"description":"Return the current timestamp, same as Current_Timestamp"}},{"id":"12e5273bbf381c95","name":"NumRanges","qualified_name":"GNATCOLL.SQL.Postgres.NumRanges","kind":"ada_package_instantiation","location":{"file":"gnatcoll-sql-postgres.ads","line":166,"column":12},"code":"package NumRanges is new GNATCOLL.SQL.Ranges\n   (Base_Fields    => GNATCOLL.SQL.Float_Fields,\n    SQL_Type       => \"numrange\",\n    Ada_Field_Type => \"GNATCOLL.SQL.Postgres.SQL_Field_Num_Range\");"}]}