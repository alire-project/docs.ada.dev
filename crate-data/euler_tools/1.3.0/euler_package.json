{"schema_version":"1","crate":"euler_tools","version":"1.3.0","id":"4c32091ab01ea644","name":"Euler_Package","qualified_name":"Euler_Package","kind":"ada_package","location":{"file":"src/euler_package.ads","line":24,"column":9},"code":"generic\n   type Int_Type is range <>;\npackage Euler_Package","documentation":{"description":" ---------------------------------------------------------------------------\n\n Copyright (c) 2023 Francesc Rocher <francesc.rocher@gnail.com>\n SPDX-License-Identifier: MIT\n\n ---------------------------------------------------------------------------\n  _____      _             _____           _\n | ____|   _| | ___ _ __  |_   _|__   ___ | |___   Mathematical functions\n |  _|| | | | |/ _ \\ '__|   | |/ _ \\ / _ \\| / __|  and tools to solve\n | |__| |_| | |  __/ |      | | (_) | (_) | \\__ \\  Project Euler problems\n |_____\\__,_|_|\\___|_|      |_|\\___/ \\___/|_|___/  https://projecteuler.net\n\n----------------------------------------------------------------------------","formals":[{"name":"Int_Type","description":""}]},"simple_types":[{"id":"dbe0f8b554a44fb0","name":"Prime_Cursor_Type","qualified_name":"Euler_Package.Prime_Cursor_Type","kind":"ada_simple_type","location":{"file":"src/euler_package.ads","line":58,"column":9},"code":"type Prime_Cursor_Type is private;","documentation":{"description":"The prime numbers generator requires private data to avoid interfering\nwith other functions."}}],"record_types":[{"id":"d903ae77705e945e","name":"Decimal_Division_Type","qualified_name":"Euler_Package.Decimal_Division_Type","kind":"ada_record_type","location":{"file":"src/euler_package.ads","line":49,"column":9},"code":"type Decimal_Division_Type is record\n   Dividend   : Int_Type;\n   Divisor    : Int_Type;\n   Quotient   : Int_Type;\n   Decimals   : Crumbled_Natural;\n   Cycle      : Natural;\n   Remainders : List_Type;\nend record;"}],"subtypes":[{"id":"51c5f7f19c06e9e8","name":"Crumbled_Natural","qualified_name":"Euler_Package.Crumbled_Natural","kind":"ada_subtype","location":{"file":"src/euler_package.ads","line":41,"column":12},"code":"subtype Crumbled_Natural is Numeral_Package.Vector;","documentation":{"description":"Crumbled_Natural type is a representation or an arbitrary long Natural\ntype, regardless of the particular type instantiated in the generic\npackage."}},{"id":"93795108238b9afe","name":"Integer_Type","qualified_name":"Euler_Package.Integer_Type","kind":"ada_subtype","location":{"file":"src/euler_package.ads","line":26,"column":12},"code":"subtype Integer_Type is Int_Type;"},{"id":"650aa69eaf4fb78c","name":"List_Type","qualified_name":"Euler_Package.List_Type","kind":"ada_subtype","location":{"file":"src/euler_package.ads","line":29,"column":12},"code":"subtype List_Type is List_Package.List;"},{"id":"83ba01bd4bacbabe","name":"Numeral_Type","qualified_name":"Euler_Package.Numeral_Type","kind":"ada_subtype","location":{"file":"src/euler_package.ads","line":36,"column":12},"code":"subtype Numeral_Type is Natural range 0 .. 9;"},{"id":"7703b63dbc5f6b41","name":"Set_Type","qualified_name":"Euler_Package.Set_Type","kind":"ada_subtype","location":{"file":"src/euler_package.ads","line":33,"column":12},"code":"subtype Set_Type is Set_Package.Set;"}],"constants":[{"id":"1734acc3173bd24a","name":"CN_Empty","qualified_name":"Euler_Package.CN_Empty","kind":"ada_constant","location":{"file":"src/euler_package.ads","line":46,"column":4},"code":"CN_Empty : constant Crumbled_Natural := Numeral_Package.Empty_Vector;"},{"id":"a70b61247e4bce62","name":"CN_Zero","qualified_name":"Euler_Package.CN_Zero","kind":"ada_constant","location":{"file":"src/euler_package.ads","line":47,"column":4},"code":"CN_Zero  : constant Crumbled_Natural := [0];"}],"subprograms":[{"id":"ef5c2d33fde04829","name":"All_Divisors","qualified_name":"Euler_Package.All_Divisors","kind":"ada_function","location":{"file":"src/euler_package.ads","line":67,"column":13},"code":"function All_Divisors (Number : Int_Type) return Set_Type","documentation":{"description":"Returns the set of all divisors of Number, including 1 and Number.","parameters":[{"name":"Number","description":""}]}},{"id":"9d76cb1c7c081028","name":"Are_Amicable","qualified_name":"Euler_Package.Are_Amicable","kind":"ada_function","location":{"file":"src/euler_package.ads","line":70,"column":13},"code":"function Are_Amicable (A, B : Int_Type) return Boolean","documentation":{"description":"Return True is A and B are an amicable pair: A and B are amicable if\nSum (Proper_Divisors (A)) = B  and  Sum (Proper_Divisors (B)) = A.","parameters":[{"name":"A","description":""},{"name":"B","description":""}]}},{"id":"225904ed81c6ab8e","name":"CN_Assign","qualified_name":"Euler_Package.CN_Assign","kind":"ada_procedure","location":{"file":"src/euler_package.ads","line":75,"column":14},"code":"procedure CN_Assign (Left : in out Crumbled_Natural; Right : Int_Type)","documentation":{"description":"Assigns the value of Right number to the Crumbled_Naturals of the\nLeft.","parameters":[{"name":"Left","description":""},{"name":"Right","description":""}]}},{"id":"924f479d559cc3fe","name":"CN_Assign","qualified_name":"Euler_Package.CN_Assign","kind":"ada_procedure","location":{"file":"src/euler_package.ads","line":79,"column":14},"code":"procedure CN_Assign (Left : in out Int_Type; Right : Crumbled_Natural)","documentation":{"description":"Assigns the value of the Crumbled_Natural in the Right to the Left\nnumber.","parameters":[{"name":"Left","description":""},{"name":"Right","description":""}]}},{"id":"bcac1f684e24553d","name":"CN_Assign","qualified_name":"Euler_Package.CN_Assign","kind":"ada_procedure","location":{"file":"src/euler_package.ads","line":83,"column":14},"code":"procedure CN_Assign\n  (Left                   : in out Int_Type; Right : Crumbled_Natural;\n   Digit_Start, Digit_End :        Positive)","documentation":{"description":"Assigns the value of the Crumbled_Natural in the Right to the Left\nnumber using digits from Digit_Start to Digit_End.","parameters":[{"name":"Left","description":""},{"name":"Right","description":""},{"name":"Digit_Start","description":""},{"name":"Digit_End","description":""}]}},{"id":"e73e0fb595e82832","name":"Collatz_Next","qualified_name":"Euler_Package.Collatz_Next","kind":"ada_function","location":{"file":"src/euler_package.ads","line":90,"column":13},"code":"function Collatz_Next (Number : Int_Type) return Int_Type","documentation":{"description":"Returns the next number in the Collatz sequence, defined by:\nCollatz_Next = N/2 if N is even, and Collatz_Next = 3*N+1 if N is odd,\nwhere N is the previous number in the Collatz sequence.","parameters":[{"name":"Number","description":""}]}},{"id":"b821a25b928b9611","name":"Combination","qualified_name":"Euler_Package.Combination","kind":"ada_function","location":{"file":"src/euler_package.ads","line":96,"column":13},"code":"function Combination (N, K : Int_Type) return Int_Type","documentation":{"description":"Returns the combinatorial number of N over K.","parameters":[{"name":"N","description":""},{"name":"K","description":""}]}},{"id":"a9c4931f35787c25","name":"Concat","qualified_name":"Euler_Package.Concat","kind":"ada_function","location":{"file":"src/euler_package.ads","line":100,"column":13},"code":"function Concat (Left, Right : Int_Type) return Int_Type","documentation":{"description":"Returns the number obtained by concatenating Left and Right numbers.","parameters":[{"name":"Left","description":""},{"name":"Right","description":""}]}},{"id":"6d78604f03e24dce","name":"Decimal_Division","qualified_name":"Euler_Package.Decimal_Division","kind":"ada_function","location":{"file":"src/euler_package.ads","line":104,"column":13},"code":"function Decimal_Division\n  (Dividend, Divisor : Int_Type; Decimals : Natural)\n   return Decimal_Division_Type","documentation":{"description":"Returns the division of Dividend / Divisor with a maximum\nnumber of Decimals in the Quotient. It mimics the manual operation of\ndividing both numbers up to a certain number of decimals.","parameters":[{"name":"Dividend","description":""},{"name":"Divisor","description":""},{"name":"Decimals","description":""}]}},{"id":"6498e9ce44ffe2b2","name":"Decimal_Division_Increase","qualified_name":"Euler_Package.Decimal_Division_Increase","kind":"ada_procedure","location":{"file":"src/euler_package.ads","line":112,"column":14},"code":"procedure Decimal_Division_Increase\n  (DDiv : in out Decimal_Division_Type; Decimals : Natural)","documentation":{"description":"Returns the division of Dividend / Divisor with a maximum\nnumber of Decimals in the Quotient. It mimics the manual operation of\ndividing both numbers up to a certain number of decimals.","parameters":[{"name":"DDiv","description":""},{"name":"Decimals","description":""}]}},{"id":"8d012a7fb81eb0b1","name":"Element_First","qualified_name":"Euler_Package.Element_First","kind":"ada_function","location":{"file":"src/euler_package.ads","line":119,"column":13},"code":"function Element_First (Set : Set_Type) return Int_Type","documentation":{"description":"Returns the first element of the ordered, non-empty Set.","parameters":[{"name":"Set","description":""}]}},{"id":"49d1afeb768ea198","name":"Element_Nth","qualified_name":"Euler_Package.Element_Nth","kind":"ada_function","location":{"file":"src/euler_package.ads","line":123,"column":13},"code":"function Element_Nth (Set : Set_Type; Nth : Natural) return Int_Type","documentation":{"description":"Return the Nth element of the ordered, non-empty Set.","parameters":[{"name":"Set","description":""},{"name":"Nth","description":""}]}},{"id":"0daddad7981e60a2","name":"Equals","qualified_name":"Euler_Package.Equals","kind":"ada_function","location":{"file":"src/euler_package.ads","line":127,"column":13},"code":"function Equals (List : List_Type) return Boolean","documentation":{"description":"Returns True if all element of the list are equal.","parameters":[{"name":"List","description":""}]}},{"id":"93a1c8293e130035","name":"Factorial","qualified_name":"Euler_Package.Factorial","kind":"ada_function","location":{"file":"src/euler_package.ads","line":131,"column":13},"code":"function Factorial (Number : Int_Type) return Int_Type","documentation":{"description":"Return the factorial of Number: 1* 2 * 3 * .. * Number.","parameters":[{"name":"Number","description":""}]}},{"id":"10ab4bc6c0aa1653","name":"Fibonacci_Next","qualified_name":"Euler_Package.Fibonacci_Next","kind":"ada_function","location":{"file":"src/euler_package.ads","line":144,"column":13},"code":"function Fibonacci_Next return Int_Type","documentation":{"description":"Returns the next Fibonacci number."}},{"id":"02542dfeebd7c5ab","name":"Fibonacci_Start","qualified_name":"Euler_Package.Fibonacci_Start","kind":"ada_function","location":{"file":"src/euler_package.ads","line":135,"column":13},"code":"function Fibonacci_Start return Int_Type","documentation":{"description":"Returns the first generated Fibonacci number from the initial terms 1\nand 1, which happens to be equal to 2, and resets the sequence\ngenerator."}},{"id":"0b48b4f57dc0d6a4","name":"Fibonacci_Start","qualified_name":"Euler_Package.Fibonacci_Start","kind":"ada_function","location":{"file":"src/euler_package.ads","line":140,"column":13},"code":"function Fibonacci_Start (A, B : Int_Type) return Int_Type","documentation":{"description":"Resets the Fibonacci sequence generator to start with the numbers A\nand B, and return the first generated Fibonacci number (A + B).","parameters":[{"name":"A","description":""},{"name":"B","description":""}]}},{"id":"1ce8d0453d8bcb88","name":"Greatest_Common_Divisor","qualified_name":"Euler_Package.Greatest_Common_Divisor","kind":"ada_function","location":{"file":"src/euler_package.ads","line":147,"column":13},"code":"function Greatest_Common_Divisor (A, B : Int_Type) return Int_Type","documentation":{"description":"Returns the greatest common divisor of A, B, also known as Gcd (A, B).","parameters":[{"name":"A","description":""},{"name":"B","description":""}]}},{"id":"f10819807bac0c91","name":"Greatest_Common_Divisor","qualified_name":"Euler_Package.Greatest_Common_Divisor","kind":"ada_function","location":{"file":"src/euler_package.ads","line":150,"column":13},"code":"function Greatest_Common_Divisor (List : List_Type) return Int_Type","documentation":{"description":"Returns the Gcd of all numbers in the list using the formula\n   Gcd ({Ai}) = Gcd (A1, Gcd (A2, Gcd ( ... ))).","parameters":[{"name":"List","description":""}]}},{"id":"5fb1e503643b46dc","name":"Hundreds","qualified_name":"Euler_Package.Hundreds","kind":"ada_function","location":{"file":"src/euler_package.ads","line":155,"column":13},"code":"function Hundreds (Number : Int_Type) return Int_Type","documentation":{"description":"Returns the hundreds of Number.","parameters":[{"name":"Number","description":""}]}},{"id":"749b397ec29ce1c0","name":"Is_Abundant","qualified_name":"Euler_Package.Is_Abundant","kind":"ada_function","location":{"file":"src/euler_package.ads","line":158,"column":13},"code":"function Is_Abundant (Number : Int_Type) return Boolean","documentation":{"description":"Returns True if the sum of the proper divisors of Number is greater\nthan itself: Sum (Proper_Divisors (Number)) > Number","parameters":[{"name":"Number","description":""}]}},{"id":"01bd0a64b5861484","name":"Is_Deficient","qualified_name":"Euler_Package.Is_Deficient","kind":"ada_function","location":{"file":"src/euler_package.ads","line":162,"column":13},"code":"function Is_Deficient (Number : Int_Type) return Boolean","documentation":{"description":"Returns True if the sum of the proper divisors of Number is lesser\nthan itself: Sum (Proper_Divisors (Number)) < Number","parameters":[{"name":"Number","description":""}]}},{"id":"387f4107b03aeb24","name":"Is_Divisor","qualified_name":"Euler_Package.Is_Divisor","kind":"ada_function","location":{"file":"src/euler_package.ads","line":166,"column":13},"code":"function Is_Divisor (Number, Divisor : Int_Type) return Boolean","documentation":{"description":"Returns True is Number can by evenly divided by Divisor.","parameters":[{"name":"Number","description":""},{"name":"Divisor","description":""}]}},{"id":"0bdb44bd0106fc11","name":"Is_Even","qualified_name":"Euler_Package.Is_Even","kind":"ada_function","location":{"file":"src/euler_package.ads","line":170,"column":13},"code":"function Is_Even (Number : Int_Type) return Boolean","documentation":{"description":"Returns True is Number is even.","parameters":[{"name":"Number","description":""}]}},{"id":"8c5f414ab59eee5e","name":"Is_Odd","qualified_name":"Euler_Package.Is_Odd","kind":"ada_function","location":{"file":"src/euler_package.ads","line":173,"column":13},"code":"function Is_Odd (Number : Int_Type) return Boolean","documentation":{"description":"Returns True is Number is odd.","parameters":[{"name":"Number","description":""}]}},{"id":"473bb494b28b786b","name":"Is_Palindrome","qualified_name":"Euler_Package.Is_Palindrome","kind":"ada_function","location":{"file":"src/euler_package.ads","line":176,"column":13},"code":"function Is_Palindrome (Number : Int_Type) return Boolean","documentation":{"description":"Returns True if Number is the same read from left to right and right\nto left.","parameters":[{"name":"Number","description":""}]}},{"id":"207ebff906a9e132","name":"Is_Perfect","qualified_name":"Euler_Package.Is_Perfect","kind":"ada_function","location":{"file":"src/euler_package.ads","line":180,"column":13},"code":"function Is_Perfect (Number : Int_Type) return Boolean","documentation":{"description":"Returns True if the sum of the proper divisors of Number is equal to\nitself: Sum (Proper_Divisors (Number)) = Number","parameters":[{"name":"Number","description":""}]}},{"id":"4297778bc0d04e86","name":"Is_Prime","qualified_name":"Euler_Package.Is_Prime","kind":"ada_function","location":{"file":"src/euler_package.ads","line":184,"column":13},"code":"function Is_Prime (Number : Int_Type) return Boolean","documentation":{"description":"Returns True if Number is prime.","parameters":[{"name":"Number","description":""}]}},{"id":"4fbbd28092b8b56f","name":"Least_Common_Multiple","qualified_name":"Euler_Package.Least_Common_Multiple","kind":"ada_function","location":{"file":"src/euler_package.ads","line":187,"column":13},"code":"function Least_Common_Multiple (A, B : Int_Type) return Int_Type","documentation":{"description":"Returns the least common multiple computed with the formula\n   Lcm (A, B) = Min (A, B) * (Max (A, B) / Gcd(A, B))","parameters":[{"name":"A","description":""},{"name":"B","description":""}]}},{"id":"e9910aa5b8f28408","name":"Least_Common_Multiple","qualified_name":"Euler_Package.Least_Common_Multiple","kind":"ada_function","location":{"file":"src/euler_package.ads","line":191,"column":13},"code":"function Least_Common_Multiple (List : List_Type) return Int_Type","documentation":{"description":"Returns the leas common multiple of all numbers in the list using the\nformula  Lcm ({Ai}}) = Lcm (A1, Lcm (A2, Lcm ( ... ))).","parameters":[{"name":"List","description":""}]}},{"id":"ef838dabb44d5093","name":"Left","qualified_name":"Euler_Package.Left","kind":"ada_function","location":{"file":"src/euler_package.ads","line":196,"column":13},"code":"function Left (Number : Int_Type; Positions : Positive) return Int_Type","documentation":{"description":"Returns the number formed by the leftmost digit Positions of Number.","parameters":[{"name":"Number","description":""},{"name":"Positions","description":""}]}},{"id":"c13bfc7f3742ca1e","name":"Length","qualified_name":"Euler_Package.Length","kind":"ada_function","location":{"file":"src/euler_package.ads","line":199,"column":13},"code":"function Length (Number : Crumbled_Natural) return Natural","documentation":{"description":"Returns the Length of the Crumbled_Natural Number;","parameters":[{"name":"Number","description":""}]}},{"id":"4aaf4ef7d5bf362d","name":"Length","qualified_name":"Euler_Package.Length","kind":"ada_function","location":{"file":"src/euler_package.ads","line":202,"column":13},"code":"function Length (Number : Integer_Type) return Natural","documentation":{"description":"Returns the total number of digits in Number.","parameters":[{"name":"Number","description":""}]}},{"id":"ab19c70faeef4ada","name":"Length","qualified_name":"Euler_Package.Length","kind":"ada_function","location":{"file":"src/euler_package.ads","line":205,"column":13},"code":"function Length (List : List_Type) return Natural","documentation":{"description":"Returns the number of elements in the List.","parameters":[{"name":"List","description":""}]}},{"id":"2ed1a22b7a2237d2","name":"Length","qualified_name":"Euler_Package.Length","kind":"ada_function","location":{"file":"src/euler_package.ads","line":208,"column":13},"code":"function Length (Set : Set_Type) return Natural","documentation":{"description":"Returns the number of elements in Set.","parameters":[{"name":"Set","description":""}]}},{"id":"bad7e4250f7c5141","name":"Library_Name","qualified_name":"Euler_Package.Library_Name","kind":"ada_function","location":{"file":"src/euler_package.ads","line":62,"column":13},"code":"function Library_Name return String","documentation":{"description":"Basic information."}},{"id":"92b7f09eb6b53097","name":"Library_Version","qualified_name":"Euler_Package.Library_Version","kind":"ada_function","location":{"file":"src/euler_package.ads","line":63,"column":13},"code":"function Library_Version return String","documentation":{"description":"Basic information."}},{"id":"c28f7dc98643cbed","name":"Prime_Factors","qualified_name":"Euler_Package.Prime_Factors","kind":"ada_function","location":{"file":"src/euler_package.ads","line":211,"column":13},"code":"function Prime_Factors (Number : Int_Type) return List_Type","documentation":{"description":"Returns the list of prime factors of Number.","parameters":[{"name":"Number","description":""}]}},{"id":"1b6a0ae11c767fdc","name":"Prime_First","qualified_name":"Euler_Package.Prime_First","kind":"ada_function","location":{"file":"src/euler_package.ads","line":214,"column":13},"code":"function Prime_First (Cursor : in out Prime_Cursor_Type) return Int_Type","documentation":{"description":"Returns the first prime number (2) and resets the prime number\ngenerator Cursor.","parameters":[{"name":"Cursor","description":""}]}},{"id":"1eee7773f815f322","name":"Prime_Next","qualified_name":"Euler_Package.Prime_Next","kind":"ada_function","location":{"file":"src/euler_package.ads","line":218,"column":13},"code":"function Prime_Next\n  (Cursor : in out Prime_Cursor_Type; Nth : Int_Type := 1) return Int_Type","documentation":{"description":"Returns the next prime number. Optionally, Nth parameter can be\nspecified to jump N numbers. That is, Prime_Next (C, 10) is equivalent\nto call Prime_Next (C) 10 times","parameters":[{"name":"Cursor","description":""},{"name":"Nth","description":""}]}},{"id":"619aa609abe37fa9","name":"Prime_Nth","qualified_name":"Euler_Package.Prime_Nth","kind":"ada_function","location":{"file":"src/euler_package.ads","line":224,"column":13},"code":"function Prime_Nth (Nth : Int_Type) return Int_Type","documentation":{"description":"Returns the Nth prime number.","parameters":[{"name":"Nth","description":""}]}},{"id":"57349720dfaeac84","name":"Product","qualified_name":"Euler_Package.Product","kind":"ada_function","location":{"file":"src/euler_package.ads","line":227,"column":13},"code":"function Product (List : List_Type) return Int_Type","documentation":{"description":"Returns the product of all numbers in List.","parameters":[{"name":"List","description":""}]}},{"id":"a1519d3c3643506f","name":"Proper_Divisors","qualified_name":"Euler_Package.Proper_Divisors","kind":"ada_function","location":{"file":"src/euler_package.ads","line":231,"column":13},"code":"function Proper_Divisors (Number : Int_Type) return Set_Type","documentation":{"description":"Returns the set of proper divisors of Number (that is, excluding\nNumber). If Number is equal to 1, then returns the empty set.","parameters":[{"name":"Number","description":""}]}},{"id":"d091c9b8a297e867","name":"Right","qualified_name":"Euler_Package.Right","kind":"ada_function","location":{"file":"src/euler_package.ads","line":235,"column":13},"code":"function Right (Number : Int_Type; Positions : Positive) return Int_Type","documentation":{"description":"Return the number formed by the rightmost digit Positions of Number.","parameters":[{"name":"Number","description":""},{"name":"Positions","description":""}]}},{"id":"90e6e3165f7fdb77","name":"Sort","qualified_name":"Euler_Package.Sort","kind":"ada_procedure","location":{"file":"src/euler_package.ads","line":238,"column":14},"code":"procedure Sort (List : in out List_Type)","documentation":{"description":"Sorts the List of numbers in place.","parameters":[{"name":"List","description":""}]}},{"id":"1734078610661cc3","name":"Square_Root","qualified_name":"Euler_Package.Square_Root","kind":"ada_function","location":{"file":"src/euler_package.ads","line":241,"column":13},"code":"function Square_Root (Number : Int_Type) return Int_Type","documentation":{"description":"Return the truncated square root of Number if Number > 0, 0 otherwise.","parameters":[{"name":"Number","description":""}]}},{"id":"c7220dc480bb8128","name":"Sub_Number","qualified_name":"Euler_Package.Sub_Number","kind":"ada_function","location":{"file":"src/euler_package.ads","line":245,"column":13},"code":"function Sub_Number\n  (Number : Int_Type; Start, Length : Positive) return Int_Type","documentation":{"description":"Return the number formed with the digits of Number from Start position\nup to the specified Length (mimics the Sub_String function). Returns 0\nif Start is greater than the Number length. Returns less that Length\ndigits if there are no enough digits in Number from the Start.","parameters":[{"name":"Number","description":""},{"name":"Start","description":""},{"name":"Length","description":""}]