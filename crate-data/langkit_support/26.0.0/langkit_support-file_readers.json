s (Buffer : String) return File_Contents","documentation":{"description":"Create a ``File_Contents`` value that contains a copy of ``Buffer``","parameters":[{"name":"Buffer","description":""}]}},{"id":"2c8fa087969413c3","name":"Create_File_Fetcher_Reference","qualified_name":"Langkit_Support.File_Readers.Create_File_Fetcher_Reference","kind":"ada_function","location":{"file":"langkit_support-file_readers.ads","line":94,"column":13},"code":"function Create_File_Fetcher_Reference\n  (File_Fetcher : File_Fetcher_Interface'Class)\n   return File_Fetcher_Reference","documentation":{"description":"Simple wrapper around the ``GNATCOLL.Refcount`` API to create file\nfetcher references.","parameters":[{"name":"File_Fetcher","description":""}]}},{"id":"492ca18bf51b99b7","name":"Create_File_Reader_Reference","qualified_name":"Langkit_Support.File_Readers.Create_File_Reader_Reference","kind":"ada_function","location":{"file":"langkit_support-file_readers.ads","line":219,"column":13},"code":"function Create_File_Reader_Reference\n  (Fetcher  : File_Fetcher_Reference;\n   Refiners : File_Refiner_Array) return File_Reader_Reference","documentation":{"description":"Create a file reader as the composition of a file fetcher and a chain of\nfile refiners. The resulting file buffers are decoded using\n``Decode_Buffer``.","parameters":[{"name":"Fetcher","description":""},{"name":"Refiners","description":""}]}},{"id":"171351707c665e93","name":"Create_File_Reader_Reference","qualified_name":"Langkit_Support.File_Readers.Create_File_Reader_Reference","kind":"ada_function","location":{"file":"langkit_support-file_readers.ads","line":214,"column":13},"code":"function Create_File_Reader_Reference\n  (File_Reader : File_Reader_Interface'Class) return File_Reader_Reference","documentation":{"description":"Simple wrapper around the ``GNATCOLL.Refcount`` API to create file\nreader references.","parameters":[{"name":"File_Reader","description":""}]}},{"id":"6ec8cb686efce422","name":"Create_File_Refiner_Reference","qualified_name":"Langkit_Support.File_Readers.Create_File_Refiner_Reference","kind":"ada_function","location":{"file":"langkit_support-file_readers.ads","line":166,"column":13},"code":"function Create_File_Refiner_Reference\n  (File_Refiner : File_Refiner_Interface'Class)\n   return File_Refiner_Reference","documentation":{"description":"Simple wrapper around the ``GNATCOLL.Refcount`` API to create file\nfetcher references.","parameters":[{"name":"File_Refiner","description":""}]}},{"id":"f5ca85a7cef5f825","name":"Create_File_Stub_Store","qualified_name":"Langkit_Support.File_Readers.Create_File_Stub_Store","kind":"ada_function","location":{"file":"langkit_support-file_readers.ads","line":114,"column":13},"code":"function Create_File_Stub_Store return File_Stub_Store","documentation":{"description":"Return an empty file stub store"}},{"id":"4abda2f87b15268d","name":"Create_Filesystem_Fetcher","qualified_name":"Langkit_Support.File_Readers.Create_Filesystem_Fetcher","kind":"ada_function","location":{"file":"langkit_support-file_readers.ads","line":100,"column":13},"code":"function Create_Filesystem_Fetcher return File_Fetcher_Reference","documentation":{"description":"Return a file fetcher instance that just reads file from the filesystem"}},{"id":"cbe6790b577514e7","name":"Create_Stubbing_Fetcher","qualified_name":"Langkit_Support.File_Readers.Create_Stubbing_Fetcher","kind":"ada_function","location":{"file":"langkit_support-file_readers.ads","line":127,"column":13},"code":"function Create_Stubbing_Fetcher\n  (Store : File_Stub_Store) return File_Fetcher_Reference","documentation":{"description":"Create a file fetcher backed by the given file stub ``Store``","parameters":[{"name":"Store","description":""}]}},{"id":"c35eb0e5994bd5d0","name":"Decode_Buffer","qualified_name":"Langkit_Support.File_Readers.Decode_Buffer","kind":"ada_procedure","location":{"file":"langkit_support-file_readers.ads","line":230,"column":14},"code":"procedure Decode_Buffer\n  (Buffer      : String;\n   Charset     : String;\n   Read_BOM    : Boolean;\n   Contents    : out Decoded_File_Contents;\n   Diagnostics : in out Diagnostics_Vectors.Vector)","documentation":{"description":"Decode the bytes in ``Buffer`` according to ``Charset``/``Read_BOM``\ninto ``Contents``.  The bytes decoding itself is delegated to\n``GNATCOLL.Iconv``.\n\nIf there is an error during this process, append an error message to\n``Diagnostics``. In that case, Contents is considered uninitialized.","parameters":[{"name":"Buffer","description":""},{"name":"Charset","description":""},{"name":"Read_BOM","description":""},{"name":"Contents","description":""},{"name":"Diagnostics","description":""}]}},{"id":"ef2e81844aa9fa56","name":"Direct_Read","qualified_name":"Langkit_Support.File_Readers.Direct_Read","kind":"ada_procedure","location":{"file":"langkit_support-file_readers.ads","line":243,"column":14},"code":"procedure Direct_Read\n  (Filename    : String;\n   Charset     : String;\n   Read_BOM    : Boolean;\n   Contents    : out Decoded_File_Contents;\n   Diagnostics : in out Diagnostics_Vectors.Vector)","documentation":{"description":"Simple implementation of ``Read`` to read the source file through\n``GNATCOLL.Mmap`` and to decode it using ``GNATCOLL.Iconv``.","parameters":[{"name":"Filename","description":""},{"name":"Charset","description":""},{"name":"Read_BOM","description":""},{"name":"Contents","description":""},{"name":"Diagnostics","description":""}]}},{"id":"c45ded982f4ddb60","name":"Do_Release","qualified_name":"Langkit_Support.File_Readers.Do_Release","kind":"ada_procedure","location":{"file":"langkit_support-file_readers.ads","line":84,"column":14},"code":"procedure Do_Release (Self : in out File_Fetcher_Interface'Class)","documentation":{"description":"Helper for the instantiation below","parameters":[{"name":"Self","description":""}]}},{"id":"17049b18d04cb026","name":"Do_Release","qualified_name":"Langkit_Support.File_Readers.Do_Release","kind":"ada_procedure","location":{"file":"langkit_support-file_readers.ads","line":204,"column":14},"code":"procedure Do_Release (Self : in out File_Reader_Interface'Class)","documentation":{"description":"Helper for the instantiation below","parameters":[{"name":"Self","description":""}]}},{"id":"8cb416753f24ff30","name":"Do_Release","qualified_name":"Langkit_Support.File_Readers.Do_Release","kind":"ada_procedure","location":{"file":"langkit_support-file_readers.ads","line":156,"column":14},"code":"procedure Do_Release (Self : in out File_Refiner_Interface'Class)","documentation":{"description":"Helper for the instantiation below","parameters":[{"name":"Self","description":""}]}},{"id":"87e6892b644fb47e","name":"Fetch","qualified_name":"Langkit_Support.File_Readers.Fetch","kind":"ada_procedure","location":{"file":"langkit_support-file_readers.ads","line":68,"column":14},"code":"procedure Fetch\n  (Self        : File_Fetcher_Interface;\n   Filename    : String;\n   Contents    : out File_Contents;\n   Diagnostics : in out Diagnostics_Vectors.Vector)","documentation":{"description":"Fetch the content of the source at ``Filename``.\n\nIf there is an error during this process, append an error message to\n``Diagnostics``.\n\nWhether there are errors or not, allocate a ``String`` buffer, fill it\nand initialize ``Contents`` to refer to it.","parameters":[{"name":"Self","description":""},{"name":"Filename","description":""},{"name":"Contents","description":""},{"name":"Diagnostics","description":""}]}},{"id":"8366ed48ae049e3c","name":"Read","qualified_name":"Langkit_Support.File_Readers.Read","kind":"ada_procedure","location":{"file":"langkit_support-file_readers.ads","line":184,"column":14},"code":"procedure Read\n  (Self        : File_Reader_Interface;\n   Filename    : String;\n   Charset     : String;\n   Read_BOM    : Boolean;\n   Contents    : out Decoded_File_Contents;\n   Diagnostics : in out Diagnostics_Vectors.Vector)","documentation":{"description":"Read the content of the source at ``Filename``, decoding it using the\ngiven ``Charset`` and decoding the byte order mark if ``Read_BOM`` is\nTrue.\n\nIf there is an error during this process, append an error message to\n``Diagnostics``.\n\nWhether there are errors or not, allocate a ``Text_Type`` buffer, fill\nit and initialize Contents to refer to it.","parameters":[{"name":"Self","description":""},{"name":"Filename","description":""},{"name":"Charset","description":""},{"name":"Read_BOM","description":""},{"name":"Contents","description":""},{"name":"Diagnostics","description":""}]}},{"id":"96f26dc73122bfe7","name":"Refine","qualified_name":"Langkit_Support.File_Readers.Refine","kind":"ada_procedure","location":{"file":"langkit_support-file_readers.ads","line":139,"column":14},"code":"procedure Refine\n  (Self        : File_Refiner_Interface;\n   Filename    : String;\n   Contents    : in out File_Contents;\n   Diagnostics : in out Diagnostics_Vectors.Vector)","documentation":{"description":"Refine the content of a source file (``Contents``, the bytes content for\nthe file fetched at ``Filename``) in place.\n\nIf there is an error during this process, append an error message to\n``Diagnostics``.\n\nWhether there are errors or not, ``Contents`` must refer to a correctly\ninitialized buffer.","parameters":[{"name":"Self","description":""},{"name":"Filename","description":""},{"name":"Contents","description":""},{"name":"Diagnostics","description":""}]}},{"id":"00835b784feeb6af","name":"Release","qualified_name":"Langkit_Support.File_Readers.Release","kind":"ada_procedure","location":{"file":"langkit_support-file_readers.ads","line":81,"column":14},"code":"procedure Release (Self : in out File_Fetcher_Interface)","documentation":{"description":"Actions to perform when releasing resources associated to ``Self``","parameters":[{"name":"Self","description":""}]}},{"id":"0f0f76680afe2a70","name":"Release","qualified_name":"Langkit_Support.File_Readers.Release","kind":"ada_procedure","location":{"file":"langkit_support-file_readers.ads","line":201,"column":14},"code":"procedure Release (Self : in out File_Reader_Interface)","documentation":{"description":"Actions to perform when releasing resources associated to ``Self``","parameters":[{"name":"Self","description":""}]}},{"id":"7731eba0333c97fc","name":"Release","qualified_name":"Langkit_Support.File_Readers.Release","kind":"ada_procedure","location":{"file":"langkit_support-file_readers.ads","line":153,"column":14},"code":"procedure Release (Self : in out File_Refiner_Interface)","documentation":{"description":"Actions to perform when releasing resources associated to ``Self``","parameters":[{"name":"Self","description":""}]}},{"id":"0de54b20d0f2021f","name":"Reset_File","qualified_name":"Langkit_Support.File_Readers.Reset_File","kind":"ada_procedure","location":{"file":"langkit_support-file_readers.ads","line":123,"column":14},"code":"procedure Reset_File (Self : File_Stub_Store; Filename : String)","documentation":{"description":"If ``Self`` contains a stub for ``Filename``, remove it. This is a no-op\notherwise.","parameters":[{"name":"Self","description":""},{"name":"Filename","description":""}]}},{"id":"4f2105b1888b5d03","name":"Stub_File","qualified_name":"Langkit_Support.File_Readers.Stub_File","kind":"ada_procedure","location":{"file":"langkit_support-file_readers.ads","line":117,"column":14},"code":"procedure Stub_File\n  (Self : File_Stub_Store; Filename : String; Content : Unbounded_String)","documentation":{"description":"Add an association for ``Filename``/``Content`` to ``Self``. If there\naws already an association for ``Filename``, this new association\nreplaces it.","parameters":[{"name":"Self","description":""},{"name":"Filename","description":""},{"name":"Content","description":""}]}}],"generic_instantiations":[{"id":"819bba12b40d1e70","name":"File_Fetcher_References","qualified_name":"Langkit_Support.File_Readers.File_Fetcher_References","kind":"ada_package_instantiation","location":{"file":"langkit_support-file_readers.ads","line":87,"column":12},"code":"package File_Fetcher_References is new GNATCOLL.Refcount.Shared_Pointers\n  (File_Fetcher_Interface'Class, Do_Release);"},{"id":"5844ddb664f06fc4","name":"File_Reader_References","qualified_name":"Langkit_Support.File_Readers.File_Reader_References","kind":"ada_package_instantiation","location":{"file":"langkit_support-file_readers.ads","line":207,"column":12},"code":"package File_Reader_References is new GNATCOLL.Refcount.Shared_Pointers\n  (File_Reader_Interface'Class, Do_Release);"},{"id":"f24d4d849602938e","name":"File_Refiner_References","qualified_name":"Langkit_Support.File_Readers.File_Refiner_References","kind":"ada_package_instantiation","location":{"file":"langkit_support-file_readers.ads","line":159,"column":12},"code":"package File_Refiner_References is new GNATCOLL.Refcount.Shared_Pointers\n  (File_Refiner_Interface'Class, Do_Release);"}]}