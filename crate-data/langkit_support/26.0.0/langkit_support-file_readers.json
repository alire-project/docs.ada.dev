{"schema_version":"1","crate":"langkit_support","version":"26.0.0","id":"43a7372d9b120530","name":"Langkit_Support.File_Readers","qualified_name":"Langkit_Support.File_Readers","kind":"ada_package","location":{"file":"langkit_support-file_readers.ads","line":23,"column":9},"code":"package Langkit_Support.File_Readers","documentation":{"description":"-----------------\n File_Contents --\n-----------------"},"simple_types":[{"id":"705c44661859de02","name":"File_Stub_Store","qualified_name":"Langkit_Support.File_Readers.File_Stub_Store","kind":"ada_simple_type","location":{"file":"langkit_support-file_readers.ads","line":103,"column":9},"code":"type File_Stub_Store is private;","documentation":{"description":"Store for file stubs: filename/file content associations that \"override\"\nthe actual files on the filesystem. This is the data structure that\npowers the \"stubbing\" file fetcher: see the\n``Create_File_Stubbing_Fetcher`` function below.\n\nNote that this type has by-reference semantics, so that the store passed\nto ``Create_File_Stubbing_Store`` can be mutated with the ``Stub_File``\nand ``Reset_File`` procedures even after the file fetcher has been\ncreated."}}],"array_types":[{"id":"497620a0fb941fac","name":"File_Refiner_Array","qualified_name":"Langkit_Support.File_Readers.File_Refiner_Array","kind":"ada_array_type","location":{"file":"langkit_support-file_readers.ads","line":172,"column":9},"code":"type File_Refiner_Array is\n  array (Positive range <>) of File_Refiner_Reference;"}],"record_types":[{"id":"42f86afa722df480","name":"Decoded_File_Contents","qualified_name":"Langkit_Support.File_Readers.Decoded_File_Contents","kind":"ada_record_type","location":{"file":"langkit_support-file_readers.ads","line":46,"column":9},"code":"type Decoded_File_Contents is record\n   Buffer : Text_Access;\n   First  : Positive;\n   Last   : Natural;\nend record;","documentation":{"description":"The \"Buffer (First .. Last)\" slice contains the decoded file contents as\na