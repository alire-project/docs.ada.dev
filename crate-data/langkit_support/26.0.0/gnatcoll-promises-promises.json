031ff2799d79fd7375d2fb07b14760e1adabd5016578ac166b27/minimal/src/gnatcoll-promises.ads","line":360,"column":16},"code":"function \"&\"\n  (List  : Callback_List;\n   Cb2   : not null access Callback'Class) return Callback_List","documentation":{"description":"Create a list of callbacks that will all be subscribed to the same\npromise.","parameters":[{"name":"List","description":""},{"name":"Cb2","description":""}]}},{"id":"a2b1e3ef0395ddd0","name":"\"&\"","qualified_name":"GNATCOLL.Promises.Promises.\"&\"","kind":"ada_function","location":{"file":"../../../../../home/runner/.local/share/alire/builds/gnatcoll_minimal_26.0.0_cc5dd0a1/d137b4ee70b6031ff2799d79fd7375d2fb07b14760e1adabd5016578ac166b27/minimal/src/gnatcoll-promises.ads","line":357,"column":16},"code":"function \"&\"\n  (Cb    : not null access Callback'Class;\n   Cb2   : not null access Callback'Class) return Callback_List","documentation":{"description":"Create a list of callbacks that will all be subscribed to the same\npromise.","parameters":[{"name":"Cb","description":""},{"name":"Cb2","description":""}]}},{"id":"1b23ca8f2e6f1545","name":"\"and\"","qualified_name":"GNATCOLL.Promises.Promises.\"and\"","kind":"ada_function","location":{"file":"../../../../../home/runner/.local/share/alire/builds/gnatcoll_minimal_26.0.0_cc5dd0a1/d137b4ee70b6031ff2799d79fd7375d2fb07b14760e1adabd5016578ac166b27/minimal/src/gnatcoll-promises.ads","line":339,"column":16},"code":"function \"and\"\n  (Self : Promise; Cb : Callback_List) return Promise_Chain","documentation":{"description":"Will call Cb when Self is resolved or failed (or immediately if Self\nhas already been resolved or failed).\nAny number of callbacks can be set on each promise.\nIf you want to chain promises (i.e. your callback itself returns\na promise), take a look at the Chains package below.\n\nCb must be allocated specifically for this call, and will be\nfreed as needed. You must not reuse the same pointer for multiple\ncalls to Subscribe.\n??? This is unsafe\n\nSelf is modified, but does not need to be \"in out\" since a promise\nis a pointer. This means that Subscribe can be directly called on\nthe result of a function call, for instance.","parameters":[{"name":"Self","description":""},{"name":"Cb","description":""}]}},{"id":"70d8b6877e0eaaff","name":"\"and\"","qualified_name":"GNATCOLL.Promises.Promises.\"and\"","kind":"ada_function","location":{"file":"../../../../../home/runner/.local/share/alire/builds/gnatcoll_minimal_26.0.0_cc5dd0a1/d137b4ee70b6031ff2799d79fd7375d2fb07b14760e1adabd5016578ac166b27/minimal/src/gnatcoll-promises.ads","line":335,"column":16},"code":"function \"and\"\n  (Self  : Promise;\n   Cb    : not null access Callback'Class) return Promise_Chain","documentation":{"description":"Will call Cb when Self is resolved or failed (or immediately if Self\nhas already been resolved or failed).\nAny number of callbacks can be set on each promise.\nIf you want to chain promises (i.e. your callback itself returns\na promise), take a look at the Chains package below.\n\nCb must be allocated specifically for this call, and will be\nfreed as needed. You must not reuse the same pointer for multiple\ncalls to Subscribe.\n??? This is unsafe\n\nSelf is modified, but does not need to be \"in out\" since a promise\nis a pointer. This means that Subscribe can be directly called on\nthe result of a function call, for instance.","parameters":[{"name":"Self","description":""},{"name":"Cb","description":""}]}},{"id":"30b3bb7edb05b2c0","name":"Create","qualified_name":"GNATCOLL.Promises.Promises.Create","kind":"ada_function","location":{"file":"../../../../../home/runner/.local/share/alire/builds/gnatcoll_minimal_26.0.0_cc5dd0a1/d137b4ee70b6031ff2799d79fd7375d2fb07b14760e1adabd5016578ac166b27/minimal/src/gnatcoll-promises.ads","line":306,"column":16},"code":"function Create return Promise","documentation":{"description":"Create a new promise, with no associated value."}},{"id":"c754caa1d1873cef","name":"Get_State","