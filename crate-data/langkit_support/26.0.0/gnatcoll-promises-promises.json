ds","line":322,"column":17},"code":"procedure Set_Error (Self : in out Promise; Reason : String)","documentation":{"description":"Mark the promise has failed. It will never be resolved.\nThe callbacks' On_Error method are executed.","parameters":[{"name":"Self","description":""},{"name":"Reason","description":""}]}},{"id":"e9b6bcb2b78f2d01","name":"Set_Value","qualified_name":"GNATCOLL.Promises.Promises.Set_Value","kind":"ada_procedure","location":{"file":"../../../../../home/runner/.local/share/alire/builds/gnatcoll_minimal_26.0.0_cc5dd0a1/d137b4ee70b6031ff2799d79fd7375d2fb07b14760e1adabd5016578ac166b27/minimal/src/gnatcoll-promises.ads","line":312,"column":17},"code":"procedure Set_Value (Self : in out Promise; R : T)","documentation":{"description":"Give a result to the promise.\nThe callbacks' On_Next methods are executed.\nThis can only be called once on a promise.","parameters":[{"name":"Self","description":""},{"name":"R","description":""}]}},{"id":"cc32b4713d1ea916","name":"Subscribe","qualified_name":"GNATCOLL.Promises.Promises.Subscribe","kind":"ada_procedure","location":{"file":"../../../../../home/runner/.local/share/alire/builds/gnatcoll_minimal_26.0.0_cc5dd0a1/d137b4ee70b6031ff2799d79fd7375d2fb07b14760e1adabd5016578ac166b27/minimal/src/gnatcoll-promises.ads","line":331,"column":17},"code":"procedure Subscribe\n  (Self : Promise;\n   Cb   : not null access Callback'Class)","documentation":{"description":"Will call Cb when Self is resolved or failed (or immediately if Self\nhas already been resolved or failed).\nAny number of callbacks can be set on each promise.\nIf you want to chain promises (i.e. your callback itself returns\na promise), take a look at the Chains package below.\n\nCb must be allocated specifically for this call, and will be\nfreed as needed. You must not reuse the same pointer for multiple\ncalls to Subscribe.\n??? This is unsafe\n\nSelf is modified, but does not need to be \"in out\" since a promise\nis a pointer. This means that Subscribe can be directly called on\nthe result of a function call, for instance.","parameters":[{"name":"Self","description":""},{"name":"Cb","description":""}]}}],"formals":[{"id":"1e06b2badeadedcd","name":"T","qualified_name":"GNATCOLL.Promises.Promises.T","kind":"ada_formal","location":{"file":"../../../../../home/runner/.local/share/alire/builds/gnatcoll_minimal_26.0.0_cc5dd0a1/d137b4ee70b6031ff2799d79fd7375d2fb07b14760e1adabd5016578ac166b27/minimal/src/gnatcoll-promises.ads","line":277,"column":12},"code":"type T (<>) is private;"}]}