45,"column":14},"code":"procedure Canonicalize (This : in out Rational)","documentation":{"description":"Remove any factors that are common to the numerator and denominator of\nThis, and make the denominator positive.\n\nAll rational arithmetic functions assume operands have a canonical form,\nand canonicalize their result. The canonical form means that the\ndenominator and the numerator have no common factors, and that the\ndenominator is positive. Zero has the unique representation 0/1.\n\nSet procedures canonicalize the assigned variable by default (see Set\nmethods below) so you don't have to worry about it. If you do not need\nexplicitly to handle non-canonical values, you don't have to use this\nprocedure, every rational number is automatically canonicalized.","parameters":[{"name":"This","description":""}]}},{"id":"901420813d757a3b","name":"Denominator","qualified_name":"GNATCOLL.GMP.Rational_Numbers.Denominator","kind":"ada_function","location":{"file":"../../../../../home/runner/.local/share/alire/builds/gnatcoll_gmp_26.0.0_dacec6f3/242aa4cd4e9577b95d7699186629be7359b559da44c5f7e45241e32597386b75/gmp/gnatcoll-gmp-rational_numbers.ads","line":162,"column":13},"code":"function Denominator (This : Rational) return Big_Integer","documentation":{"description":"Return the denominator of This","parameters":[{"name":"This","description":""}]}},{"id":"71470c907f8cdca5","name":"Image","qualified_name":"GNATCOLL.GMP.Rational_Numbers.Image","kind":"ada_function","location":{"file":"../../../../../home/runner/.local/share/alire/builds/gnatcoll_gmp_26.0.0_dacec6f3/242aa4cd4e9577b95d7699186629be7359b559da44c5f7e45241e32597386b75/gmp/gnatcoll-gmp-rational_numbers.ads","line":110,"column":13},"code":"function Image (This : Rational; Base : Integer := 10) return String","documentation":{"description":"See GMP.Lib.mpq_get_str for more documentation about Base","parameters":[{"name":"This","description":""},{"name":"Base","description":""}]}},{"id":"cd501e632ace5bae","name":"Is_Canonical","qualified_name":"GNATCOLL.GMP.Rational_Numbers.Is_Canonical","kind":"ada_function","location":{"file":"../../../../../home/runner/.local/share/alire/builds/gnatcoll_gmp_26.0.0_dacec6f3/242aa4cd4e9577b95d7699186629be7359b559da44c5f7e45241e32597386b75/gmp/gnatcoll-gmp-rational_numbers.ads","line":59,"column":13},"code":"function Is_Canonical (This : Rational) return Boolean","documentation":{"description":"Return whether This is in canonical form","parameters":[{"name":"This","description":""}]}},{"id":"0b0ef5e716f8bcbf","name":"Numerator","qualified_name":"GNATCOLL.GMP.Rational_Numbers.Numerator","kind":"ada_function","location":{"file":"../../../../../home/runner/.local/share/alire/builds/gnatcoll_gmp_26.0.0_dacec6f3/242aa4cd4e9577b95d7699186629be7359b559da44c5f7e45241e32597386b75/gmp/gnatcoll-gmp-rational_numbers.ads","line":159,"column":13},"code":"function Numerator (This : Rational) return Big_Integer","documentation":{"description":"Return the numerator of This","parameters":[{"name":"This","description":""}]}},{"id":"a148c629d1dd6f74","name":"Set","qualified_name":"GNATCOLL.GMP.Rational_Numbers.Set","kind":"ada_procedure","location":{"file":"../../../../../home/runner/.local/share/alire/builds/gnatcoll_gmp_26.0.0_dacec6f3/242aa4cd4e9577b95d7699186629be7359b559da44c5f7e45241e32597386b75/gmp/gnatcoll-gmp-rational_numbers.ads","line":102,"column":14},"code":"procedure Set (This : out Rational; To : Double)","documentation":{"description":"Set This to a Double","parameters":[{"name":"This","description":""},{"name":"To","description":""}]}},{"id":"13fda1339caa6a07","name":"Set","qualified_name":"GNATCOLL.GMP.Rational_Numbers.Set","kind":"ada_procedure","location":{"file":"../../../../../home/runner/.local/share/alire/builds/gnatcoll_gmp_26.0.0_dacec6f3/242aa4cd4e9577b95d7699186629be7359b559da44c5f7e45241e32597386b75/gmp/gnatcoll-gmp-rational_numbers.ads","line":70,"column":14},"code":"procedure Set (This : out Rational; To : Big_Integer)","documentation":{"description":"Set This rational to a Big_Integer","parameters":[{"name":"This","description":""},{"name":"To","description":""}]}},{"id":"fa57ca580a8994c3","name":"Set","qualified_name":"GNATCOLL.GMP.Rational_Numbers.Set","kind":"ada_procedure","location":{"file":"../../../../../home/runner/.local/share/alire/builds/gnatcoll_gmp_26.0.0_dacec6f3/242aa4cd4e9577b95d7699186629be7359b559da44c5f7e45241e32597386b75/gmp/gnatcoll-gmp-rational_numbers.ads","line":73,"column":14},"code":"procedure Set\n  (This         : out Rational;\n   Num          : Long;\n   Den          : Unsigned_Long := 1;\n   Canonicalize : Boolean       := True)","documentation":{"description":"Set This rational to \"Num/Den\" integers","parameters":[{"name":"This","description":""},{"name":"Num","description":""},{"name":"Den","description":""},{"name":"Canonicalize","description":""}]}},{"id":"19423637fbb26c15","name":"Set","qualified_name":"GNATCOLL.GMP.Rational_Numbers.Set","kind":"ada_procedure","location":{"file":"../../../../../home/runner/.local/share/alire/builds/gnatcoll_gmp_26.0.0_dacec6f3/242aa4cd4e9577b95d7699186629be7359b559da44c5f7e45241e32597386b75/gmp/gnatcoll-gmp-rational_numbers.ads","line":64,"column":14},"code":"procedure Set\n  (This         : out Rational;\n   To           : Rational;\n   Canonicalize : Boolean := True)","documentation":{"description":"Copy the To rational number to This","parameters":[{"name":"This","description":""},{"name":"To","description":""},{"name":"Canonicalize","description":""}]}},{"id":"7c37679b9f94b1dd","name":"Set","qualified_name":"GNATCOLL.GMP.Rational_Numbers.Set","kind":"ada_procedure","location":{"file":"../../../../../home/runner/.local/share/alire/builds/gnatcoll_gmp_26.0.0_dacec6f3/242aa4cd4e9577b95d7699186629be7359b559da44c5f7e45241e32597386b75/gmp/gnatcoll-gmp-rational_numbers.ads","line":80,"column":14},"code":"procedure Set\n  (This         : out Rational;\n   To           : String;\n   Base         : Int     := 10;\n   Canonicalize : Boolean := True)","documentation":{"description":"Set This from the string To in the given Base.\n\nThe string can be an integer like \"41\" or a fraction like \"41/152\". The\nfraction must be in canonical form, or if not then Canonicalize must\nbe called.\n\nThe numerator and optional denominator are parsed the same as in\nIntegers.Set. White space is allowed in the string, and is simply\nignored. The base can vary from 2 to 62, or if base is 0 then the\nleading characters are used: 0x or 0X for hex, 0b or 0B for binary, 0\nfor octal, or decimal otherwise. Note that this is done separately for\nthe numerator and denominator, so for instance 0xEF/100 is 239/100,\nwhereas 0xEF/0x100 is 239/256.\n\nRaise a Failure exception if the string is not valid or if the\ndenominator is 0.","parameters":[{"name":"This","description":""},{"name":"To","description":""},{"name":"Base","description":""},{"name":"Canonicalize","description":""}]}},{"id":"79927dc6c55d5f3d","name":"Set_Den","qualified_name":"GNATCOLL.GMP.Rational_Numbers.Set_Den","kind":"ada_procedure","location":{"file":"../../../../../home/runner/.local/share/alire/builds/gnatcoll_gmp_26.0.0_dacec6f3/242aa4cd4e9577b95d7699186629be7359b559da44c5f7e45241e32597386b75/gmp/gnatcoll-gmp-rational_numbers.ads","line":171,"column":14},"code":"procedure Set_Den\n  (This         : in out Rational;\n   Den          : Big_Integer;\n   Canonicalize : Boolean := True)","documentation":{"description":"Set the denominator of This","parameters":[{"name":"This","description":""},{"name":"Den","description":""},{"name":"Canonicalize","description":""}]}},{"id":"ebfe869cfc88440c","name":"Set_Num","qualified_name":"GNATCOLL.GMP.Rational_Numbers.Set_Num","kind":"ada_procedure","location":{"file":"../../../../../home/runner/.local/share/alire/builds/gnatcoll_gmp_26.0.0_dacec6f3/242aa4cd4e9577b95d7699186629be7359b559da44c5f7e45241e32597386b75/gmp/gnatcoll-gmp-rational_numbers.ads","line":165,"column":14},"code":"procedure Set_Num\n  (This         : in out Rational;\n   Num          : Big_Integer;\n   Canonicalize : Boolean := True)","documentation":{"description":"Set the numerator of This","parameters":[{"name":"This","description":""},{"name":"Num","description":""},{"name":"Canonicalize","description":""}]}},{"id":"fdfcabe6e4567181","name":"Swap","qualified_name":"GNATCOLL.GMP.Rational_Numbers.Swap","kind":"ada_procedure","location":{"file":"../../../../../home/runner/.local/share/alire/builds/gnatcoll_gmp_26.0.0_dacec6f3/242aa4cd4e9577b95d7699186629be7359b559da44c5f7e45241e32597386b75/gmp/gnatcoll-gmp-rational_numbers.ads","line":105,"column":14},"code":"procedure Swap (R1, R2 : in out Rational)","documentation":{"description":"Swap two Rational numbers","parameters":[{"name":"R1","description":""},{"name":"R2","description":""}]}},{"id":"aada770ac8674a99","name":"To_Double","qualified_name":"GNATCOLL.GMP.Rational_Numbers.To_Double","kind":"ada_function","location":{"file":"../../../../../home/runner/.local/share/alire/builds/gnatcoll_gmp_26.0.0_dacec6f3/242aa4cd4e9577b95d7699186629be7359b559da44c5f7e45241e32597386b75/gmp/gnatcoll-gmp-rational_numbers.ads","line":115,"column":13},"code":"function To_Double (This : Rational) return Double","documentation":{"description":"Convert This to a double, truncating if necessary (i.e. rounding towards\nzero).\n\nIf the exponent from the conversion is too big or too small to fit a\ndouble then the result is system dependent. For too big numbers an\ninfinity is returned when available. For too small numbers, 0.0 is\nnormally returned. Hardware overflow, underflow and denorm traps may or\nmay not occur.","parameters":[{"name":"This","description":""}]}}]}