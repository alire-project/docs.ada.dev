_HTable.Null_Ptr","kind":"ada_formal","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/bdea63aefd2c9f503503d03ddcc8ea23c3dca8fb74694724dfc6a305bb8a89de/gnat/s-htable.ads","line":153,"column":7},"code":"Null_Ptr : Elmt_Ptr;","documentation":{"description":"The null value of the Elmt_Ptr type"}},{"id":"98b2f14ebcb70388","name":"Set_Next","qualified_name":"System.HTable.Static_HTable.Set_Next","kind":"ada_formal","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/bdea63aefd2c9f503503d03ddcc8ea23c3dca8fb74694724dfc6a305bb8a89de/gnat/s-htable.ads","line":156,"column":22},"code":"procedure Set_Next (E : Elmt_Ptr; Next : Elmt_Ptr)","documentation":{"description":"The type must provide an internal link for the sake of the\nstaticness of the HTable.","parameters":[{"name":"E","description":""},{"name":"Next","description":""}]}}]}