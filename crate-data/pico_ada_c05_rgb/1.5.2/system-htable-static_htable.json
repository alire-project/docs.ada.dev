{"schema_version":"1","crate":"pico_ada_c05_rgb","version":"1.5.2","id":"eb1e82079b62f39c","name":"Static_HTable","qualified_name":"System.HTable.Static_HTable","kind":"ada_package","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/bdea63aefd2c9f503503d03ddcc8ea23c3dca8fb74694724dfc6a305bb8a89de/gnat/s-htable.ads","line":166,"column":12},"code":"generic\n   type Header_Num is range <>;\n   type Element (<>) is limited private;\n   pragma Warnings (Off, Element);\n   type Elmt_Ptr is private;\n   Null_Ptr : Elmt_Ptr;\n   with procedure Set_Next (E : Elmt_Ptr; Next : Elmt_Ptr);\n   with function  Next     (E : Elmt_Ptr) return Elmt_Ptr;\n   type Key is limited private;\n   with function Get_Key (E : Elmt_Ptr) return Key;\n   with function Hash    (F : Key)      return Header_Num;\n   with function Equal   (F1, F2 : Key) return Boolean;\npackage Static_HTable","documentation":{"description":"+-------------------+\n|       Key         |\n+-------------------+\n:    other data     :\n+-------------------+\n|     Next Elmt     |\n+-------------------+","formals":[{"name":"Header_Num","description":""},{"name":"Element","description":""},{"name":"Elmt_Ptr","description":""},{"name":"Null_Ptr","description":""},{"name":"Set_Next","description":""},{"name":"Next","description":""},{"name":"Key","description":""},{"name":"Get_Key","description":""},{"name":"Hash","description":""},{"name":"Equal","description":""}]},"subprograms":[{"id":"777c453e1e53eb8e","name":"Get","qualified_name":"System.HTable.Static_HTable.Get","kind":"ada_function","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/bdea63aefd2c9f503503d03ddcc8ea23c3dca8fb74694724dfc6a305bb8a89de/gnat/s-htable.ads","line":180,"column":16},"code":"function Get (K : Key) return Elmt_Ptr","documentation":{"description":"Returns the latest inserted element pointer with the given Key\nor null if none.","parameters":[{"name":"K","description":""}]}},{"id":"92b7a9b5f0a23f74","name":"Get_First","qualified_name":"System.HTable.Static_HTable.Get_First","kind":"ada_function","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/bdea63aefd2c9f503503d03ddcc8ea23c3dca8fb74694724dfc6a305bb8a89de/gnat/s-htable.ads","line":196,"column":16},"code":"function Get_First return Elmt_Ptr","documentation":{"description":"Returns Null_Ptr if the HTable is empty, otherwise returns one\nnon specified element. There is no guarantee that two calls to this\nfunction will return the same element."}},{"id":"0e0f31e4328f537a","name":"Get_Next","qualified_name":"System.HTable.Static_HTable.Get_Next","kind":"ada_function","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/bdea63aefd2c9f503503d03ddcc8ea23c3dca8fb74694724dfc6a305bb8a89de/gnat/s-htable.ads","line":201,"column":16},"code":"function Get_Next return Elmt_Ptr","documentation":{"description":"Returns a non-specified element that has not been returned by the\nsame function since the last call to Get_First or Null_Ptr if\nthere is no such element or Get_First has never been called. If\nthere is no call to 'Set' in between Get_Next calls, all the\nelements of the HTable will be traversed."}},{"id":"725ae5afe8e8fa9f","name":"Present","qualified_name":"System.HTable.Static_HTable.Present","kind":"ada_function","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/bdea63aefd2c9f503503d03ddcc8ea23c3dca8fb74694724dfc6a305bb8a89de/gnat/s-htable.ads","line":184,"column":16},"code":"function Present (K : Key) return Boolean","documentation":{"description":"True if an element whose Get_Key is K is in the table","parameters":[{"name":"K","description":""}]}},{"id":"e810cab3182bc1f9","name":"Remove","qualified_name":"System.HTable.Static_HTable.Remove","kind":"ada_procedure","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/bdea63aefd2c9f503503d03ddcc8ea23c3dca8fb74694724dfc6a305bb8a89de/gnat/s-htable.ads","line":192,"column":17},"code":"procedure Remove (K : Key)","documentation":{"description":"Removes the latest inserted element pointer associated with the\ngiven key if any, does nothing if none.","parameters":[{"name":"K","description":""}]}},{"id":"008efc36a5eb15fd","name":"Reset","qualified_name":"System.HTable.Static_HTable.Reset","kind":"ada_procedure","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/bdea63aefd2c9f503503d03ddcc8ea23c3dca8fb74694724dfc6a305bb8a89de/gnat/s-htable.ads","line":168,"column":17},"code":"procedure Reset","documentation":{"description":"Resets the hash table by setting all its elements to Null_Ptr. The\neffect is to clear the hash table so that it can be reused. For the\nmost common case where Elmt_Ptr is an access type, and Null_Ptr is\nnull, this is only needed if the same table is reused in a new\ncontext. If Elmt_Ptr is other than an access type, or Null_Ptr is\nother than null, then Reset must be called before the first use\nof the hash table."}},{"id":"3270d0944d972ef1","name":"Set","qualified_name":"System.HTable.Static_HTable.Set","kind":"ada_procedure","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/bdea63aefd2c9f503503d03ddcc8ea23c3dca8fb74694724dfc6a305bb8a89de/gnat/s-htable.ads","line":177,"column":17},"code":"procedure Set (E : Elmt_Ptr)","documentation":{"description":"Insert the element pointer in the HTable","parameters":[{"name":"E","description":""}]}},{"id":"8d798d4d68d9ddcd","name":"Set_If_Not_Present","qualified_name":"System.HTable.Static_HTable.Set_If_Not_Present","kind":"ada_function","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/bdea63aefd2c9f503503d03ddcc8ea23c3dca8fb74694724dfc6a305bb8a89de/gnat/s-htable.ads","line":187,"column":16},"code":"function Set_If_Not_Present (E : Elmt_Ptr) return Boolean","documentation":{"description":"If Present (Get_Key (E)), returns False. Otherwise, does Set (E), and\nthen returns True. Present (Get_Key (E)) is always True afterward,\nand the result True indicates E is newly Set.","parameters":[{"name":"E","description":""}]}}],"formals":[{"id":"2e79a7a6bf34fb7d","name":"Element","qualified_name":"System.HTable.Static_HTable.Element","kind":"ada_formal","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/bdea63aefd2c9f503503d03ddcc8ea23c3dca8fb74694724dfc6a305bb8a89de/gnat/s-htable.ads","line":139,"column":12},"code":"type Element (<>) is limited private;","documentation":{"description":"The type of element to be stored. This is historically part of the\ninterface, even though it is not used at all in the operations of\nthe package."}},{"id":"abf8bbdd67dd5817","name":"Elmt_Ptr","qualified_name":"System.HTable.Static_HTable.Elmt_Ptr","kind":"ada_formal","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/bdea63aefd2c9f503503d03ddcc8ea23c3dca8fb74694724dfc6a305bb8a89de/gnat/s-htable.ads","line":149,"column":12},"code":"type Elmt_Ptr is private;","documentation":{"description":"The type used to reference an element (will usually be an access\ntype, but could be some other form of type such as an integer type)."}},{"id":"2e3e4c294a4dd17a","name":"Equal","qualified_name":"System.HTable.Static_HTable.Equal","kind":"ada_formal","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/bdea63aefd2c9f503503d03ddcc8ea23c3dca8fb74694724dfc6a305bb8a89de/gnat/s-htable.ads","line":164,"column":21},"code":"function Equal   (F1, F2 : Key) return Boolean"},{"id":"58a57aa45515d262","name":"Get_Key","qualified_name":"System.HTable.Static_HTable.Get_Key","kind":"ada_formal","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_1