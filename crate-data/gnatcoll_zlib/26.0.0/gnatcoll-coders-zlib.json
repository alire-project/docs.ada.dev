Coders.ZLib.Deflate_Init","id":"7f5c466127147bdb","unit":"gnatcoll-coders-zlib"},{"qualified_name":"GNATCOLL.Coders.ZLib.Finalize","id":"9d2133cb2ef4c58b","unit":"gnatcoll-coders-zlib"},{"qualified_name":"GNATCOLL.Coders.ZLib.Finished","id":"0df1532110d9f8e4","unit":"gnatcoll-coders-zlib"},{"qualified_name":"GNATCOLL.Coders.ZLib.Inflate_Init","id":"9d0038506702f5ac","unit":"gnatcoll-coders-zlib"},{"qualified_name":"GNATCOLL.Coders.ZLib.Is_Open","id":"2464baf60c313fb5","unit":"gnatcoll-coders-zlib"},{"qualified_name":"GNATCOLL.Coders.ZLib.Total_In","id":"e981ec6e008d1198","unit":"gnatcoll-coders-zlib"},{"qualified_name":"GNATCOLL.Coders.ZLib.Total_Out","id":"4fbd5f83534c27d2","unit":"gnatcoll-coders-zlib"},{"qualified_name":"GNATCOLL.Coders.ZLib.Transcode","id":"9727a47f2fde91d7","unit":"gnatcoll-coders-zlib"}],"prefix_callable_inherited":[{"qualified_name":"GNATCOLL.Coders.Close","id":"c47809b33b1889e3","unit":"gnatcoll-coders"},{"qualified_name":"GNATCOLL.Coders.Finished","id":"3a76e3574b704ed6","unit":"gnatcoll-coders"},{"qualified_name":"GNATCOLL.Coders.Flush","id":"4ca2b5a8d05eee80","unit":"gnatcoll-coders"},{"qualified_name":"GNATCOLL.Coders.Is_Open","id":"72e7e9a138173837","unit":"gnatcoll-coders"},{"qualified_name":"GNATCOLL.Coders.Total_In","id":"538a2a177dcecc99","unit":"gnatcoll-coders"},{"qualified_name":"GNATCOLL.Coders.Total_Out","id":"e970b5013ad4678c","unit":"gnatcoll-coders"},{"qualified_name":"GNATCOLL.Coders.Transcode","id":"0750786d5f37f90c","unit":"gnatcoll-coders"}]}],"constants":[{"id":"807258f1025cf7b5","name":"Best_Compression","qualified_name":"GNATCOLL.Coders.ZLib.Best_Compression","kind":"ada_constant","location":{"file":"gnatcoll-coders-zlib.ads","line":67,"column":4},"code":"Best_Compression    : constant Compression_Level := 9;"},{"id":"ef858fd4e6a9306d","name":"Best_Speed","qualified_name":"GNATCOLL.Coders.ZLib.Best_Speed","kind":"ada_constant","location":{"file":"gnatcoll-coders-zlib.ads","line":66,"column":4},"code":"Best_Speed          : constant Compression_Level := 1;"},{"id":"cec5459783f55f57","name":"Default_Compression","qualified_name":"GNATCOLL.Coders.ZLib.Default_Compression","kind":"ada_constant","location":{"file":"gnatcoll-coders-zlib.ads","line":68,"column":4},"code":"Default_Compression : constant Compression_Level := -1;"},{"id":"dcbe00990be10194","name":"Default_Memory_Level","qualified_name":"GNATCOLL.Coders.ZLib.Default_Memory_Level","kind":"ada_constant","location":{"file":"gnatcoll-coders-zlib.ads","line":51,"column":4},"code":"Default_Memory_Level : constant Memory_Level_Type := 8;"},{"id":"7759307448430cb6","name":"Default_Strategy","qualified_name":"GNATCOLL.Coders.ZLib.Default_Strategy","kind":"ada_constant","location":{"file":"gnatcoll-coders-zlib.ads","line":79,"column":4},"code":"Default_Strategy : constant Strategy_Type;"},{"id":"d37fc4cd7e2dc9bd","name":"Default_Window_Bits","qualified_name":"GNATCOLL.Coders.ZLib.Default_Window_Bits","kind":"ada_constant","location":{"file":"gnatcoll-coders-zlib.ads","line":52,"column":4},"code":"Default_Window_Bits  : constant Window_Bits_Type  := 15;"},{"id":"78e88bf995996548","name":"Deflated","qualified_name":"GNATCOLL.Coders.ZLib.Deflated","kind":"ada_constant","location":{"file":"gnatcoll-coders-zlib.ads","line":58,"column":4},"code":"Deflated : constant Compression_Method;","documentation":{"description":"Only one method allowed in this ZLib version"}},{"id":"ac0019fe795470b0","name":"Filtered","qualified_name":"GNATCOLL.Coders.ZLib.Filtered","kind":"ada_constant","location":{"file":"gnatcoll-coders-zlib.ads","line":76,"column":4},"code":"Filtered         : constant Strategy_Type;"},{"id":"45adced95a2a51c3","name":"Huffman_Only","qualified_name":"GNATCOLL.Coders.ZLib.Huffman_Only","kind":"ada_constant","location":{"file":"gnatcoll-coders-zlib.ads","line":77,"column":4},"code":"Huffman_Only     : constant Strategy_Type;"},{"id":"58e7cacc1feb37d1","name":"No_Compression","qualified_name":"GNATCOLL.Coders.ZLib.No_Compression","kind":"ada_constant","location":{"file":"gnatcoll-coders-zlib.ads","line":65,"column":4},"code":"No_Compression      : constant Compression_Level := 0;"},{"id":"6db2f8695e9982f8","name":"RLE","qualified_name":"GNATCOLL.Coders.ZLib.RLE","kind":"ada_constant","location":{"file":"gnatcoll-coders-zlib.ads","line":78,"column":4},"code":"RLE              : constant Strategy_Type;"}],"exceptions":[{"id":"6ae359e81ba38eb4","name":"ZLib_Error","qualified_name":"GNATCOLL.Coders.ZLib.ZLib_Error","kind":"ada_exception","location":{"file":"gnatcoll-coders-zlib.ads","line":151,"column":4},"code":"ZLib_Error   : exception;"}],"subprograms":[{"id":"7da0da7f99dab6e0","name":"Close","qualified_name":"GNATCOLL.Coders.ZLib.Close","kind":"ada_procedure","location":{"file":"gnatcoll-coders-zlib.ads","line":146,"column":25},"code":"procedure Close (Coder : in out Coder_Type)","documentation":{"description":"Frees internal coder memory allocations. Note that coder is derived from\nLimited_Controlled and will free all memory automatically on\nfinalization.","parameters":[{"name":"Coder","description":""}]}},{"id":"7f5c466127147bdb","name":"Deflate_Init","qualified_name":"GNATCOLL.Coders.ZLib.Deflate_Init","kind":"ada_procedure","location":{"file":"gnatcoll-coders-zlib.ads","line":84,"column":14},"code":"procedure Deflate_Init\n  (Coder        : in out Coder_Type;\n   Level        :        Compression_Level  := Default_Compression;\n   Strategy     :        Strategy_Type      := Default_Strategy;\n   Method       :        Compression_Method := Deflated;\n   Window_Bits  :        Window_Bits_Type   := Default_Window_Bits;\n   Memory_Level :        Memory_Level_Type  := Default_Memory_Level;\n   Header       :        Header_Type        := Default)","documentation":{"description":"Compressor initialization.\nWhen Header parameter is Auto or Default, then default zlib header\nwould be provided for compressed data.\nWhen Header is GZip, then gzip header would be set instead of\ndefault header.\nWhen Header is None, no header would be set for compressed data.","parameters":[{"name":"Coder","description":""},{"name":"Level","description":""},{"name":"Strategy","description":""},{"name":"Method","description":""},{"name":"Window_Bits","description":""},{"name":"Memory_Level","description":""},{"name":"Header","description":""}]}},{"id":"0df1532110d9f8e4","name":"Finished","qualified_name":"GNATCOLL.Coders.ZLib.Finished","kind":"ada_function","location":{"file":"gnatcoll-coders-zlib.ads","line":142,"column":24},"code":"function Finished (Coder : Coder_Type) return Boolean","documentation":{"description":"Indicates that incoming data stream is complete and all internally\nprocessed data is out of coder.","parameters":[{"name":"Coder","description":""}]}},{"id":"9d0038506702f5ac","name":"Inflate_Init","qualified_name":"GNATCOLL.Coders.ZLib.Inflate_Init","kind":"ada_procedure","location":{"file":"gnatcoll-coders-zlib.ads","line":99,"column":14},"code":"procedure Inflate_Init\n  (Coder       : in out Coder_Type;\n   Window_Bits :        Window_Bits_Type := Default_Window_Bits;\n   Header      :        Header_Type      := Default)","documentation":{"description":"Decompressor initialization.\nDefault header type mean that ZLib default header is expecting in the\ninput compressed stream.\nHeader type None mean that no header is expecting in the input stream.\nGZip header type mean that GZip header is expecting in the\ninput compressed stream.\nAuto header type mean that header type (GZip or Native) would be\ndetected automatically in the input stream.\nNote that header types parameter values None, GZip and Auto are\nsupported for inflate routine only in ZLib versions 1.2.0.2 and later.\nDeflate_Init is supporting all header types.","parameters":[{"name":"Coder","description":""},{"name":"Window_Bits","description":""},{"name":"Header","description":""}]}},{"id":"2464baf60c313fb5","name":"Is_Open","qualified_name":"GNATCOLL.Coders.ZLib.Is_Open","kind":"ada_function","location":{"file":"gnatcoll-coders-zlib.ads","line":115,"column":24},"code":"function Is_Open (Coder : Coder_Type) return Boolean","documentation":{"description":"Indicates that coder is ready to transcode data, i.e either Easy_Encoder\nor Auto_Decoder called.","parameters":[{"name":"Coder","description":""}]}},{"id":"e981ec6e008d1198","name":"Total_In","qualified_name":"GNATCOLL.Coders.ZLib.Total_In","kind":"ada_function","location":{"file":"gnatcoll-coders-zlib.ads","line":134,"column":24},"code":"function Total_In\n  (Coder : Coder_Type) return Stream_Element_Count","documentation":{"description":"Returns the total amount of input data sent into the coder","parameters":[{"name":"Coder","description":""}]}},{"id":"4fbd5f83534c27d2","name":"Total_Out","qualified_name":"GNATCOLL.Coders.ZLib.Total_Out","kind":"ada_function","location":{"file":"gnatcoll-coders-zlib.ads","line":138,"column":24},"code":"function Total_Out\n  (Coder : Coder_Type) return Stream_Element_Count","documentation":{"description":"Returns the total amount of output data taken from the coder","parameters":[{"name":"Coder","description":""}]}},{"id":"9727a47f2fde91d7","name":"Transcode","qualified_name":"GNATCOLL.Coders.ZLib.Transcode","kind":"ada_procedure","location":{"file":"gnatcoll-coders-zlib.ads","line":119,"column":25},"code":"procedure Transcode\n  (Coder    : in out Coder_Type;\n   In_Data  :        Stream_Element_Array;\n   In_Last  :    out Stream_Element_Offset;\n   Out_Data :    out Stream_Element_Array;\n   Out_Last :    out Stream_Element_Offset;\n   Flush    :        Flush_Mode := No_Flush)","documentation":{"description":"Transcodes data from In_Data to Out_Data.\nIn_Last is the index of last element from In_Data accepted by\nthe Coder.\nOut_Last is the index of the last element written to Out_Data.\nTo tell the Coder that incoming data is complete pass Finish as the\nFlush parameter and call Transcoder with empty In_Data until Stream_End\nroutine indicates end of stream.","parameters":[{"name":"Coder","description":""},{"name":"In_Data","description":""},{"name":"In_Last","description":""},{"name":"Out_Data","description":""},{"name":"Out_Last","description":""},{"name":"Flush","description":""}]}},{"id":"c04ce345ed3edc3a","name":"Version","qualified_name":"GNATCOLL.Coders.ZLib.Version","kind":"ada_function","location":{"file":"gnatcoll-coders-zlib.ads","line":81,"column":13},"code":"function Version return String","documentation":{"description":"Return string representation of the ZLib version"}}]}