e\nfinal result."}},{"id":"b56022cdcb7a2aa2","name":"Reflect_Input","qualified_name":"LibCRC.Generic_Nbit_CRCs.Table_Based.Reflect_Input","kind":"ada_formal","location":{"file":"src/libcrc-generic_nbit_crcs-table_based.ads","line":17,"column":4},"code":"Reflect_Input : Boolean;","documentation":{"description":"Whether the input data is reflected (bit reversed) during the CRC\ncomputation."}},{"id":"929085edf5a6a891","name":"Reflect_Output","qualified_name":"LibCRC.Generic_Nbit_CRCs.Table_Based.Reflect_Output","kind":"ada_formal","location":{"file":"src/libcrc-generic_nbit_crcs-table_based.ads","line":21,"column":4},"code":"Reflect_Output : Boolean;","documentation":{"description":"Whether the computed CRC is reflected (bit reversed) before applying the\nFinal_XOR."}},{"id":"1a88e6e7c3e2589f","name":"Seed","qualified_name":"LibCRC.Generic_Nbit_CRCs.Table_Based.Seed","kind":"ada_formal","location":{"file":"src/libcrc-generic_nbit_crcs-table_based.ads","line":10,"column":4},"code":"Seed : CRC_Type;","documentation":{"description":"The default initial value for the CRC computation."}}]}