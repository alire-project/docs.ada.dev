,{"id":"30a0b81ab1fd760f","name":"Is_Executable","qualified_name":"GNATCOLL.OS.Dir.Is_Executable","kind":"ada_function","location":{"file":"../../../../home/runner/.local/share/alire/builds/gnatcoll_26.0.0_cc5dd0a1/7ccbed38d8b88fe1ce3c718d0f0a1da149c4b5af155bbe12ed9d190dcda52463/core/src/os/gnatcoll-os-dir.ads","line":95,"column":13},"code":"function Is_Executable (Self : Dir_Entry) return Boolean","documentation":{"description":"Return True if the file is executable","parameters":[{"name":"Self","description":""}]}},{"id":"77c3c2e3ae3d412b","name":"Is_Executable_File","qualified_name":"GNATCOLL.OS.Dir.Is_Executable_File","kind":"ada_function","location":{"file":"../../../../home/runner/.local/share/alire/builds/gnatcoll_26.0.0_cc5dd0a1/7ccbed38d8b88fe1ce3c718d0f0a1da149c4b5af155bbe12ed9d190dcda52463/core/src/os/gnatcoll-os-dir.ads","line":104,"column":13},"code":"function Is_Executable_File (Self : Dir_Entry) return Boolean","documentation":{"description":"Return True if the file is a regular file and is executable","parameters":[{"name":"Self","description":""}]}},{"id":"e5e61cfbc8cdfa82","name":"Is_File","qualified_name":"GNATCOLL.OS.Dir.Is_File","kind":"ada_function","location":{"file":"../../../../home/runner/.local/share/alire/builds/gnatcoll_26.0.0_cc5dd0a1/7ccbed38d8b88fe1ce3c718d0f0a1da149c4b5af155bbe12ed9d190dcda52463/core/src/os/gnatcoll-os-dir.ads","line":86,"column":13},"code":"function Is_File (Self : Dir_Entry) return Boolean","documentation":{"description":"Return True if the file is a regular file","parameters":[{"name":"Self","description":""}]}},{"id":"58981b8768b53d5e","name":"Is_Opened","qualified_name":"GNATCOLL.OS.Dir.Is_Opened","kind":"ada_function","location":{"file":"../../../../home/runner/.local/share/alire/builds/gnatcoll_26.0.0_cc5dd0a1/7ccbed38d8b88fe1ce3c718d0f0a1da149c4b5af155bbe12ed9d190dcda52463/core/src/os/gnatcoll-os-dir.ads","line":54,"column":13},"code":"function Is_Opened (Handle : Dir_Handle) return Boolean","documentation":{"description":"Return True of the handle is opened.","parameters":[{"name":"Handle","description":""}]}},{"id":"c054c41c8db91a0f","name":"Is_Readable","qualified_name":"GNATCOLL.OS.Dir.Is_Readable","kind":"ada_function","location":{"file":"../../../../home/runner/.local/share/alire/builds/gnatcoll_26.0.0_cc5dd0a1/7ccbed38d8b88fe1ce3c718d0f0a1da149c4b5af155bbe12ed9d190dcda52463/core/src/os/gnatcoll-os-dir.ads","line":98,"column":13},"code":"function Is_Readable (Self : Dir_Entry) return Boolean","documentation":{"description":"Return True if the file is readable","parameters":[{"name":"Self","description":""}]}},{"id":"ebe81537aa269208","name":"Is_Symbolic_Link","qualified_name":"GNATCOLL.OS.Dir.Is_Symbolic_Link","kind":"ada_function","location":{"file":"../../../../home/runner/.local/share/alire/builds/gnatcoll_26.0.0_cc5dd0a1/7ccbed38d8b88fe1ce3c718d0f0a1da149c4b5af155bbe12ed9d190dcda52463/core/src/os/gnatcoll-os-dir.ads","line":92,"column":13},"code":"function Is_Symbolic_Link (Self : Dir_Entry) return Boolean","documentation":{"description":"Return True if the file is a symbolic link","parameters":[{"name":"Self","description":""}]}},{"id":"08d16d1fc3b6d6a8","name":"Is_Writable","qualified_name":"GNATCOLL.OS.Dir.Is_Writable","kind":"ada_function","location":{"file":"../../../../home/runner/.local/share/alire/builds/gnatcoll_26.0.0_cc5dd0a1/7ccbed38d8b88fe1ce3c718d0f0a1da149c4b5af155bbe12ed9d190dcda52463/core/src/os/gnatcoll-os-dir.ads","line":101,"column":13},"code":"function Is_Writable (Self : Dir_Entry) return Boolean","documentation":{"description":"Return True if the file is writable","parameters":[{"name":"Self","description":""}]}},{"id":"28111e2a59374bfa","name":"Modification_Time","qualified_name":"GNATCOLL.OS.Dir.Modification_Time","kind":"ada_function","location":{"file":"../../../../home/runner/.local/share/alire/builds/gnatcoll_26.0.0_cc5dd0a1/7ccbed38d8b88fe1ce3c718d0f0a1da149c4b5af155bbe12ed9d190dcda52463/core/src/os/gnatcoll-os-dir.ads","line":107,"column":13},"code":"function Modification_Time (Self : Dir_Entry) return Time","documentation":{"description":"Return file modification time","parameters":[{"name":"Self","description":""}]}},{"id":"1e95f988d13d2054","name":"Name","qualified_name":"GNATCOLL.OS.Dir.Name","kind":"ada_function","location":{"file":"../../../../home/runner/.local/share/alire/builds/gnatcoll_26.0.0_cc5dd0a1/7ccbed38d8b88fe1ce3c718d0f0a1da149c4b5af155bbe12ed9d190dcda52463/core/src/os/gnatcoll-os-dir.ads","line":77,"column":13},"code":"function Name (Self : Dir_Entry) return UTF8.UTF_8_String","documentation":{"description":"Return the filename for Self (note that this is just the basename)","parameters":[{"name":"Self","description":""}]}},{"id":"ad6cfaa361991556","name":"Open","qualified_name":"GNATCOLL.OS.Dir.Open","kind":"ada_function","location":{"file":"../../../../home/runner/.local/share/alire/builds/gnatcoll_26.0.0_cc5dd0a1/7ccbed38d8b88fe1ce3c718d0f0a1da149c4b5af155bbe12ed9d190dcda52463/core/src/os/gnatcoll-os-dir.ads","line":47,"column":13},"code":"function Open (Path : UTF8.UTF_8_String) return Dir_Handle","documentation":{"description":"Open a directory at path Path. In case of error OS_Error exception is\nraised.","parameters":[{"name":"Path","description":""}]}},{"id":"d8813bd5e163bb39","name":"Path","qualified_name":"GNATCOLL.OS.Dir.Path","kind":"ada_function","location":{"file":"../../../../home/runner/.local/share/alire/builds/gnatcoll_26.0.0_cc5dd0a1/7ccbed38d8b88fe1ce3c718d0f0a1da149c4b5af155bbe12ed9d190dcda52463/core/src/os/gnatcoll-os-dir.ads","line":68,"column":13},"code":"function Path (Handle : Dir_Handle) return UTF8.UTF_8_String","documentation":{"description":"Returned path associated with the handle. If Handle is not opened then\nOS_Error is raised.","parameters":[{"name":"Handle","description":""}]}},{"id":"0ed72e050ec73681","name":"Path","qualified_name":"GNATCOLL.OS.Dir.Path","kind":"ada_function","location":{"file":"../../../../home/runner/.local/share/alire/builds/gnatcoll_26.0.0_cc5dd0a1/7ccbed38d8b88fe1ce3c718d0f0a1da149c4b5af155bbe12ed9d190dcda52463/core/src/os/gnatcoll-os-dir.ads","line":80,"column":13},"code":"function Path (Dir : Dir_Handle; Self : Dir_Entry) return UTF8.UTF_8_String","documentation":{"description":"Return the full path for a given entry","parameters":[{"name":"Dir","description":""},{"name":"Self","description":""}]}},{"id":"042943e1db030425","name":"Raise_Exception_On_Error","qualified_name":"GNATCOLL.OS.Dir.Raise_Exception_On_Error","kind":"ada_procedure","location":{"file":"../../../../home/runner/.local/share/alire/builds/gnatcoll_26.0.0_cc5dd0a1/7ccbed38d8b88fe1ce3c718d0f0a1da149c4b5af155bbe12ed9d190dcda52463/core/src/os/gnatcoll-os-dir.ads","line":135,"column":14},"code":"procedure Raise_Exception_On_Error\n   (Dir     : Dir_Handle;\n    Element : Dir_Entry;\n    Error   : Walk_Error;\n    Msg     : String)","documentation":{"description":"Raise exception in case of error","parameters":[{"name":"Dir","description":""},{"name":"Element","description":""},{"name":"Error","description":""},{"name":"Msg","description":""}]}},{"id":"9fae6807e6039e52","name":"Read","qualified_name":"GNATCOLL.OS.Dir.Read","kind":"ada_function","location":{"file":"../../../../home/runner/.local/share/alire/builds/gnatcoll_26.0.0_cc5dd0a1/7ccbed38d8b88fe1ce3c718d0f0a1da149c4b5af155bbe12ed9d190dcda52463/core/src/os/gnatcoll-os-dir.ads","line":57,"column":13},"code":"function Read\n   (Handle          : Dir_Handle;\n    Follow_Symlinks : Boolean := True)\n   return Dir_Entry","documentation":{"description":"Read next entry in directory Handle. In case of error OS_Error is\nraised. When reaching the end of the entry list a special Dir_Entry E\nis returned for which End_Of_Iteration (E) is True. If Follow_Symlinks\nis set to True, the stat information stored is the Dir_Entry is the\nstat information of the file targeted by the link. Otherwise the stat\ninformation of the link itself is returned.","parameters":[{"name":"Handle","description":""},{"name":"Follow_Symlinks","description":""}]}},{"id":"b95046310c5bccaa","name":"Walk","qualified_name":"GNATCOLL.OS.Dir.Walk","kind":"ada_procedure","location":{"file":"../../../../home/runner/.local/share/alire/builds/gnatcoll_26.0.0_cc5dd0a1/7ccbed38d8b88fe1ce3c718d0f0a1da149c4b5af155bbe12ed9d190dcda52463/core/src/os/gnatcoll-os-dir.ads","line":145,"column":14},"code":"procedure Walk\n   (Path                 : UTF8.UTF_8_String;\n    File_Handler         : Process_File;\n    Dir_Handler          : Process_Directory := null;\n    Max_Depth            : Positive          := 256;\n    On_Error             : Process_Error     := Ignore;\n    Follow_Symlinks      : Boolean           := False;\n    Propagate_Exceptions : Boolean           := False;\n    Exit_Dir_Handler     : Exit_Directory    := null)","documentation":{"description":"Explore recursively a directory Path. For each entry found, call\nDir_Handler if the entry is a directory and File_Handler otherwise.\nif a call to Dir_Handler returns True then Walk explores that\nsubdirectory. Otherwise the subdirectory is skipped. Note that if a null\nDir_Handler is passed then Walk behaves as if Dir_Handler always returns\nTrue (and thus explore all subdirectories).\n\nMax_Depth limits the depth of the exploration. For example a Max_Depth\nof 1 is equivalent to a non recursive call as it returns only direct\nentries of Path.\n\nOn_Error handler is called on each error during the exploration of Path.\nTwo default handlers are already implemented: Ignore and Raise_OS_Error.\n\nIf Follow_Symlinks is True, each time a symbolic link is encountered the\ntarget of the link is returned. If False, the link itself is returned.\nNote that setting Follow_Symlink to True might lead in theory to\ninfinite loop. In our case the Max_Depth parameter provides a limit.\n\nIf Propagate_Exceptions is True, exceptions raised during the dir and\nfile handler are propagated to the caller.","parameters":[{"name":"Path","description":""},{"name":"File_Handler","description":""},{"name":"Dir_Handler","description":""},{"name":"Max_Depth","description":""},{"name":"On_Error","description":""},{"name":"Follow_Symlinks","description":""},{"name":"Propagate_Exceptions","description":""},{"name":"Exit_Dir_Handler","description":""}]}}]}