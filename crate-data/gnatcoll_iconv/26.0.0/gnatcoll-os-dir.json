{"schema_version":"1","crate":"gnatcoll_iconv","version":"26.0.0","id":"ab6511370a9dfbef","name":"GNATCOLL.OS.Dir","qualified_name":"GNATCOLL.OS.Dir","kind":"ada_package","location":{"file":"../../../../home/runner/.local/share/alire/builds/gnatcoll_26.0.0_cc5dd0a1/7ccbed38d8b88fe1ce3c718d0f0a1da149c4b5af155bbe12ed9d190dcda52463/core/src/os/gnatcoll-os-dir.ads","line":36,"column":9},"code":"package GNATCOLL.OS.Dir","documentation":{"description":"Provides a low-level portable API to iterate on directories content. The\nmain advantage of this implementation over the default one in the GNAT\nruntime is that it returns both the filename and the \"stat\" information\nfor each entry in a given directory. On systems such as Windows this\nreduce significantly the cost of file system operations as the Win32 API\ncan achieve this with one system call (the equivalent to readdir)."},"simple_types":[{"id":"55e11557332b171b","name":"Dir_Entry","qualified_name":"GNATCOLL.OS.Dir.Dir_Entry","kind":"ada_simple_type","location":{"file":"../../../../home/runner/.local/share/alire/builds/gnatcoll_26.0.0_cc5dd0a1/7ccbed38d8b88fe1ce3c718d0f0a1da149c4b5af155bbe12ed9d190dcda52463/core/src/os/gnatcoll-os-dir.ads","line":44,"column":9},"code":"type Dir_Entry is private;","documentation":{"description":"Directory entry"}},{"id":"f170894085ec321e","name":"Dir_Handle","qualified_name":"GNATCOLL.OS.Dir.Dir_Handle","kind":"ada_simple_type","location":{"file":"../../../../home/runner/.local/share/alire/builds/gnatcoll_26.0.0_cc5dd0a1/7ccbed38d8b88fe1ce3c718d0f0a1da149c4b5af155bbe12ed9d190dcda52463/core/src/os/gnatcoll-os-dir.ads","line":41,"column":9},"code":"type Dir_Handle is private;","documentation":{"description":"Handle on a directory"}},{"id":"2d9393ca9f68f487","name":"Walk_Error","qualified_name":"GNATCOLL.OS.Dir.Walk_Error","kind":"ada_simple_type","location":{"file":"../../../../home/runner/.local/share/alire/builds/gnatcoll_26.0.0_cc5dd0a1/7ccbed38d8b88fe1ce3c718d0f0a1da149c4b5af155bbe12ed9d190dcda52463/core/src/os/gnatcoll-os-dir.ads","line":126,"column":9},"code":"type Walk_Error is (OPEN_DIR_ERROR, OTHER_ERROR);"}],"access_types":[{"id":"2bc08a1ab492a6ad","name":"Exit_Directory","qualified_name":"GNATCOLL.OS.Dir.Exit_Directory","kind":"ada_access_type","location":{"file":"../../../../home/runner/.local/share/alire/builds/gnatcoll_26.0.0_cc5dd0a1/7ccbed38d8b88fe1ce3c718d0f0a1da149c4b5af155bbe12ed9d190dcda52463/core/src/os/gnatcoll-os-dir.ads","line":120,"column":9},"code":"type Exit_Directory is access\n   procedure (Dir : Dir_Handle);","documentation":{"description":"Function called on each directory found by Walk once the directory has\nbeen explored. Note that the Dir_Handle passed to Exit_Directory is\nclosed and thus only the path is relevant.","parameters":[{"name":"Dir","description":""}]}},{"id":"07f3dc118eb93b55","name":"Process_Directory","qualified_name":"GNATCOLL.OS.Dir.Process_Directory","kind":"ada_access_type","location":{"file":"../../../../home/runner/.local/share/alire/builds/gnatcoll_26.0.0_cc5dd0a1/7ccbed38d8b88fe1ce3c718d0f0a1da149c4b5af155bbe12ed9d190dcda52463/core/src/os/gnatcoll-os-dir.ads","line":114,"column":9},"code":"type Process_Directory is access\n   function (Dir : Dir_Handle; Element : Dir_Entry) return Boolean;","documentation":{"description":"Function called on each directory found by Walk. If the handler returns\nTrue then the directory is also explored. If False then the directory\nis skipped.","parameters":[{"name":"Dir","description":""},{"name":"Element","description":""}]}},{"id":"1b286c245fc3002d","name":"Process_Error","qualified_name":"GNATCOLL.OS.Dir.Process_Error","kind":"ada_access_type","location":{"file":"../../../../home/runner/.local/share/alire/builds/gnatcoll_26.0.0_cc5dd0a1/7ccbed38d8b88fe1ce3c718d0f0a1da149c4b5af155bbe12ed9d190dcda52463/core/src/os/gnatcoll-os-dir.ads","line":128,"column":9},"code":"type Process_Error is access\n   procedure (Dir     : Dir_Handle;\n              Element : Dir_Entry;\n              Error   : Walk_Error;\n              Msg     : String);","documentation":{"description":"Function called in case an error occurs during a call to walk","parameters":[{"name":"Dir","description":""},{"name":"Element","description":""},{"name":"Error","description":""},{"name":"Msg","description":""}]}},{"id":"31e4bcd90928bb50","name":"Process_File","qualified_name":"GNATCOLL.OS.Dir.Process_File","kind":"ada_access_type","location":{"file":"../../../../home/runner/.local/share/alire/builds/gnatcoll_26.0.0_cc5dd0a1/7ccbed38d8b88fe1ce3c718d0f0a1da149c4b5af155bbe12ed9d190dcda52463/core/src/os/gnatcoll-os-dir.ads","line":110,"column":9},"code":"type Process_File is access\n   procedure (Dir : Dir_Handle; Element : Dir_Entry);","documentation":{"description":"Function called on each file except directories found by Walk","parameters":[{"name":"Dir","description":""},{"name":"Element","description":""}]}}],"constants":[{"id":"9dc71e18d760f3aa","name":"Ignore","qualified_name":"GNATCOLL.OS.Dir.Ignore","kind":"ada_constant","location":{"file":"../../../../home/runner/.local/share/alire/builds/gnatcoll_26.0.0_cc5dd0a1/7ccbed38d8b88fe1ce3c718d0f0a1da149c4b5af155bbe12ed9d190dcda52463/core/src/os/gnatcoll-os-dir.ads","line":142,"column":4},"code":"Ignore         : constant Process_Error := null;"},{"id":"a9bb237e26164b87","name":"Raise_OS_Error","qualified_name":"GNATCOLL.OS.Dir.Raise_OS_Error","kind":"ada_constant","location":{"file":"../../../../home/runner/.local/share/alire/builds/gnatcoll_26.0.0_cc5dd0a1/7ccbed38d8b88fe1ce3c718d0f0a1da149c4b5af155bbe12ed9d190dcda52463/core/src/os/gnatcoll-os-dir.ads","line":143,"column":4},"code":"Raise_OS_Error : constant Process_Error := Raise_Exception_On_Error'Access;"}],"subprograms":[{"id":"cc353d71ab5b485e","name":"Attributes","qualified_name":"GNATCOLL.OS.Dir.Attributes","kind":"ada_function","location":{"file":"../../../../home/runner/.local/share/alire/builds/gnatcoll_26.0.0_cc5dd0a1/7ccbed38d8b88fe1ce3c718d