{"schema_version":"1","crate":"pico_xbsp","version":"1.5.2","id":"5a82decfef73f622","name":"BBqueue.Buffers.framed","qualified_name":"BBqueue.Buffers.framed","kind":"ada_package","location":{"file":"../../../home/runner/.local/share/alire/builds/bbqueue_1.0.0_f508818c/6b55862f91826f221c65748131dccf10160914638d5e473d2ce80a83525080c9/src/bbqueue-buffers-framed.ads","line":20,"column":9},"code":"package BBqueue.Buffers.framed","documentation":{"description":"This unit is based on BBqueue.Buffers and uses markers in the buffer to\ntrack the size of each commited write grants. The size of consequent read\ngrants will conrespond to the sizes of commited write grants.\n\nIt can be used to handle variable lenght packets:\n\n   Q   : aliased Framed_Buffer (64);\n   WG  : Write_Grant := Empty;\n   RG  : Read_Grant := Empty;\n   S   : Slice_Rec;\nbegin\n   Grant (Q, WG, 8); -- Get a worst case grant of size 8\n   Commit (Q, WG, 4); -- Only commit 4\n   Grant (Q, WG, 8); -- Get a worst case grant of size 8\n   Commit (Q, WG, 5); -- Only commit 5\n   Read (W, RG); -- Returns a grant of size 4"},"simple_types":[{"id":"7bd0900e53163840","name":"Framed_Buffer","qualified_name":"BBqueue.Buffers.framed.Framed_Buffer","kind":"ada_simple_type","location":{"file":"../../../home/runner/.local/share/alire/builds/bbqueue_1.0.0_f508818c/6b55862f91826f221c65748131dccf10160914638d5e473d2ce80a83525080c9/src/bbqueue-buffers-framed.ads","line":34,"column":9},"code":"type Framed_Buffer (Size   : Buffer_Size)\nis limited private;"},{"id":"c0702cf60a4cc9b0","name":"Read_Grant","qualified_name":"BBqueue.Buffers.framed.Read_Grant","kind":"ada_simple_type","location":{"file":"../../../home/runner/.local/share/alire/builds/bbqueue_1.0.0_f508818c/6b55862f91826f221c65748131dccf10160914638d5e473d2ce80a83525080c9/src/bbqueue-buffers-framed.ads","line":74,"column":9},"code":"type Read_Grant is limited private;"},{"id":"23f2adf294cc7325","name":"Write_Grant","qualified_name":"BBqueue.Buffers.framed.Write_Grant","kind":"ada_simple_type","location":{"file":"../../../home/runner/.local/share/alire/builds/bbqueue_1.0.0_f508818c/6b55862f91826f221c65748131dccf10160914638d5e473d2ce80a83525080c9/src/bbqueue-buffers-framed.ads","line":39,"column":9},"code":"type Write_Grant is limited private;"}],"subtypes":[{"id":"85bfe475833ded1b","name":"Framed_Count","qualified_name":"BBqueue.Buffers.framed.Framed_Count","kind":"ada_subtype","location":{"file":"../../../home/runner/.local/share/alire/builds/bbqueue_1.0.0_f508818c/6b55862f91826f221c65748131dccf10160914638d5e473d2ce80a83525080c9/src/bbqueue-buffers-framed.ads","line":28,"column":12},"code":"subtype Framed_Count\n  is Count range Count'First .. Count'Last - Max_Frame_Header_Size;","documentation":{"description":"The frame can take up to 9 bytes in addition to the allocated size. The\nsize of what can be allocated is therefore lower than for a non-framed\nbuffer."}}],"constants":[{"id":"53b6c633e780ab15","name":"Max_Frame_Header_Size","qualified_name":"BBqueue.Buffers.framed.Max_Frame_Header_Size","kind":"ada_constant","location":{"file":"../../../home/runner/.local/share/alire/builds/bbqueue_1.0.0_f508818c/6b55862f91826f221c65748131dccf10160914638d5e473d2ce80a83525080c9/src/bbqueue-buffers-framed.ads","line":26,"column":4},"code":"Max_Frame_Header_Size : constant := 9;"}],"subprograms":[{"id":"8cc386bfb268e313","name":"Commit","qualified_name":"BBqueue.Buffers.framed.Commit","kind":"ada_procedure","location":{"file":"../../../home/runner/.local/share/alire/builds/bbqueue_1.0.0_f508818c/6b55862f91826f221c65748131dccf10160914638d5e473d2ce80a83525080c9/src/bbqueue-buffers-framed.ads","line":51,"column":14},"code":"procedure Commit (This : in out Framed_Buffer;\n                  G    : in out Write_Grant;\n                  Size :        Framed_Count := Framed_Count'Last)","documentation":{"description":"Commit a writeable slice. Size can be smaller than the granted slice for\npartial commits. The commited slice is then available