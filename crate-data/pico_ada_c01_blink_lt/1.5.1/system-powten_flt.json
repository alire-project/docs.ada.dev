 :=\n  [00 => [5.0**00, 0.0],\n   01 => [5.0**01, 0.0],\n   …\n   20 => [5.0**20, 5.0**20 - Float'Machine (5.0**20)]];"},{"id":"13b4360fedd2794a","name":"Powten","qualified_name":"System.Powten_Flt.Powten","kind":"ada_constant","location":{"file":"../../../home/runner/.local/share/alire/builds/light_tasking_rp2040_15.3.0_c9c04aed/4065265df7b86a3736218c3d73ac26491bb2d7b8c240d11b26563991788017d8/gnat/s-powflt.ads","line":68,"column":4},"code":"Powten : constant array (0 .. Maxpow, 1 .. 2) of Float :=\n  [00 => [1.0E+00, 0.0],\n   01 => [1.0E+01, 0.0],\n   …\n   20 => [1.0E+20, 1.0E+20 - Float'Machine (1.0E+20)]];"}]}