lumn":4},"code":"Clock_Frequency  : constant := Board_Parameters.Main_Clock_Frequency;"},{"id":"e21f0a184e56f930","name":"Context_Buffer_Capacity","qualified_name":"System.BB.Parameters.Context_Buffer_Capacity","kind":"ada_constant","location":{"file":"../../../home/runner/.local/share/alire/builds/light_tasking_rp2040_15.3.0_c9c04aed/4065265df7b86a3736218c3d73ac26491bb2d7b8c240d11b26563991788017d8/gnat/s-bbpara.ads","line":95,"column":4},"code":"Context_Buffer_Capacity : constant := 10;","documentation":{"description":"The context buffer contains registers r4 .. r11 and the SP_process\n(PSP). The size is rounded up to an even number for alignment"}},{"id":"977fdd809e3a99d5","name":"Has_FPU","qualified_name":"System.BB.Parameters.Has_FPU","kind":"ada_constant","location":{"file":"../../../home/runner/.local/share/alire/builds/light_tasking_rp2040_15.3.0_c9c04aed/4065265df7b86a3736218c3d73ac26491bb2d7b8c240d11b26563991788017d8/gnat/s-bbpara.ads","line":113,"column":4},"code":"Has_FPU : constant Boolean := False;","documentation":{"description":"Set to true if core has a FPU"}},{"id":"47cef25d18b596de","name":"Has_OS_Extensions","qualified_name":"System.BB.Parameters.Has_OS_Extensions","kind":"ada_constant","location":{"file":"../../../home/runner/.local/share/alire/builds/light_tasking_rp2040_15.3.0_c9c04aed/4065265df7b86a3736218c3d73ac26491bb2d7b8c240d11b26563991788017d8/gnat/s-bbpara.ads","line":120,"column":4},"code":"Has_OS_Extensions : constant Boolean := True;","documentation":{"description":"Set to true if core has armv6-m OS extensions (PendSV, MSP, PSP,\netc...)."}},{"id":"f2d311d7da8ce274","name":"Has_VTOR","qualified_name":"System.BB.Parameters.Has_VTOR","kind":"ada_constant","location":{"file":"../../../home/runner/.local/share/alire/builds/light_tasking_rp2040_15.3.0_c9c04aed/4065265df7b86a3736218c3d73ac26491bb2d7b8c240d11b26563991788017d8/gnat/s-bbpara.ads","line":116,"column":4},"code":"Has_VTOR : constant Boolean := True;","documentation":{"description":"Set to true if core has a Vector Table Offset Register (VTOR).\nVTOR is implemented in Cortex-M0+, Cortex-M4 and above."}},{"id":"53563da691349ff7","name":"Interrupt_Sec_Stack_Size","qualified_name":"System.BB.Parameters.Interrupt_Sec_Stack_Size","kind":"ada_constant","location":{"file":"../../../home/runner/.local/share/alire/builds/light_tasking_rp2040_15.3.0_c9c04aed/4065265df7b86a3736218c3d73ac26491bb2d7b8c240d11b26563991788017d8/gnat/s-bbpara.ads","line":109,"column":4},"code":"Interrupt_Sec_Stack_Size : constant :=\n  RP2040_Runtime_Config.Interrupt_Secondary_Stack_Size;","documentation":{"description":"Size of the secondary stack for interrupt handlers"}},{"id":"9be409d4cde52aaf","name":"Interrupt_Stack_Size","qualified_name":"System.BB.Parameters.Interrupt_Stack_Size","kind":"ada_constant","location":{"file":"../../../home/runner/.local/share/alire/builds/light_tasking_rp2040_15.3.0_c9c04aed/4065265df7b86a3736218c3d73ac26491bb2d7b8c240d11b26563991788017d8/gnat/s-bbpara.ads","line":103,"column":4},"code":"Interrupt_Stack_Size : constant :=\n  RP2040_Runtime_Config.Interrupt_Stack_Size;","documentation":{"description":"Size of each of the interrupt stacks in bytes. While there nominally is\nan interrupt stack per interrupt priority, the entire space is used as a\nsingle stack."}},{"id":"3d471d0441d07a31","name":"Is_ARMv6m","qualified_name":"System.BB.Parameters.Is_ARMv6m","kind":"ada_constant","location":{"file":"../../../home/runner/.local/share/alire/builds/light_tasking_rp2040_15.3.0_c9c04aed/4065265df7b86a3736218c3d73ac26491bb2d7b8c240d11b26563991788017d8/gnat/s-bbpara.ads","line":124,"column":4},"code":"Is_ARMv6m : constant Boolean := True;","documentation":{"description":"Set to true if core is an armv6-m (Cortex-M0, Cortex-M0+, Cortex-M1)"}},{"id":"b3ecd737662ba3a3","name":"Max_Number_Of_CPUs","qualified_name":"System.BB.Parameters.Max_Number_Of_CPUs","kind":"ada_constant","location":{"file":"../../../home/runner/.local/share/alire/builds/light_tasking_rp2040_15.3.0_c9c04aed/4065265df7b86a3736218c3d73ac26491bb2d7b8c240d11b26563991788017d8/gnat/s-bbpara.ads","line":131,"column":4},"code":"Max_Number_Of_CPUs : constant := RP2040_Runtime_Config.Max_CPUs;","documentation":{"description":"Maximum number of CPUs"}},{"id":"ed653e82b99ece57","name":"Multiprocessor","qualified_name":"System.BB.Parameters.Multiprocessor","kind":"ada_constant","location":{"file":"../../../home/runner/.local/share/alire/builds/light_tasking_rp2040_15.3.0_c9c04aed/4065265df7b86a3736218c3d73ac26491bb2d7b8c240d11b26563991788017d8/gnat/s-bbpara.ads","line":134,"column":4},"code":"Multiprocessor : constant Boolean := Max_Number_Of_CPUs /= 1;","documentation":{"description":"Are we on a multiprocessor board?"}},{"id":"92800f86579807e6","name":"NVIC_Priority_Bits","qualified_name":"System.BB.Parameters.NVIC_Priority_Bits","kind":"ada_constant","location":{"file":"../../../home/runner/.local/share/alire/builds/light_tasking_rp2040_15.3.0_c9c04aed/4065265df7b86a3736218c3d73ac26491bb2d7b8c240d11b26563991788017d8/gnat/s-bbpara.ads","line":65,"column":4},"code":"NVIC_Priority_Bits : constant Cortex_Priority_Bits_Width := 4;","documentation":{"description":"The number of bits allocated by this specific hardware implementation."}},{"id":"60fcb01f0cac04e5","name":"Ticks_Per_Second","qualified_name":"System.BB.Parameters.Ticks_Per_Second","kind":"ada_constant","location":{"file":"../../../home/runner/.local/share/alire/builds/light_tasking_rp2040_15.3.0_c9c04aed/4065265df7b86a3736218c3d73ac26491bb2d7b8c240d11b26563991788017d8/gnat/s-bbpara.ads","line":53,"column":4},"code":"Ticks_Per_Second : constant := Board_Parameters.Main_Clock_Frequency;"},{"id":"4616499dd8e22579","name":"Trap_Vectors","qualified_name":"System.BB.Parameters.Trap_Vectors","kind":"ada_constant","location":{"file":"../../../home/runner/.local/share/alire/builds/light_tasking_rp2040_15.3.0_c9c04aed/4065265df7b86a3736218c3d73ac26491bb2d7b8c240d11b26563991788017d8/gnat/s-bbpara.ads","line":72,"column":4},"code":"Trap_Vectors : constant := 17;","documentation":{"description":"While on this target there is little difference between interrupts\nand traps, we consider the following traps:\n\n  Name                        Nr\n\n  Reset_Vector                 1\n  NMI_Vector                   2\n  Hard_Fault_Vector            3\n  Mem_Manage_Vector            4\n  Bus_Fault_Vector             5\n  Usage_Fault_Vector           6\n  SVC_Vector                  11\n  Debug_Mon_Vector            12\n  Pend_SV_Vector              14\n  Sys_Tick_Vector             15\n  Interrupt_Request_Vector    16\n\nThese trap vectors correspond to different low-level trap handlers in\nthe run time. Note that as all interrupt requests (IRQs) will use the\nsame interrupt wrapper, there is no benefit to using separate vectors\nfor each."}}]}