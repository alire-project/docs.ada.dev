rocedure","location":{"file":"src/io/bbs-sim_cpu-io-disk.ads","line":118,"column":14},"code":"procedure setGeometry(self : in out fd_ctrl; drive : drive_num; geom : geometry)","documentation":{"description":"\n  Get the name of the attached file, if any.","parameters":[{"name":"self","description":""},{"name":"drive","description":""},{"name":"geom","description":""}]}},{"id":"27ad54c67a6746d2","name":"write","qualified_name":"BBS.Sim_CPU.io.disk.write","kind":"ada_procedure","location":{"file":"src/io/bbs-sim_cpu-io-disk.ads","line":146,"column":14},"code":"procedure write(self : in out fd_ctrl)","documentation":{"description":"-------------------------------------------------------------------------\n\n Definitions for a hard disk controller with 32 bit addressing.\n The geomentry of this device is simplified into a simple linear\n sequence of blocks.\n\n Port usage (base +)\n 0 - Command\n 1 - Status\n 2 - Value MSB\n 3 - Value\n 4 - Value\n 5 - Value LSB\n\n Commands are:\n 0 - Do nothing\n 1 - Set drive\n 2 - Set starting block\n 3 - Set block count\n 4 - Set DMA address\n 5 - Read data\n 6 - Write data\n 7 - Read max drive number\n 8 - Read max block number\n Status bits are\n 7 - Unused\n 6 - Unused\n 5 - Unused\n 4 - Bad command\n 3 - Drive out of range\n 2 - Count out of range\n 1 - Starting block out of range\n 0 - Drive out of range\n\n In operation, write the value first and then issue the set command to\n set a value.  To read a value, issue a read command, then read the value.","parameters":[{"name":"self","description":""}]}},{"id":"f2bd79ef2c6d4fdf","name":"write","qualified_name":"BBS.Sim_CPU.io.disk.write","kind":"ada_procedure","location":{"file":"src/io/bbs-sim_cpu-io-disk.ads","line":84,"column":14},"code":"procedure write(self : in out fd_ctrl; addr : addr_bus; data : data_bus)","documentation":{"description":"\n  Read from a port address","parameters":[{"name":"self","description":""},{"name":"addr","description":""},{"name":"data","description":""}]}},{"id":"4a62d1c27c612d41","name":"write","qualified_name":"BBS.Sim_CPU.io.disk.write","kind":"ada_procedure","location":{"file":"src/io/bbs-sim_cpu-io-disk.ads","line":234,"column":14},"code":"procedure write(self : in out hd_ctrl)","documentation":{"description":"=========================================================================","parameters":[{"name":"self","description":""}]}},{"id":"09b2335e51195dbd","name":"write","qualified_name":"BBS.Sim_CPU.io.disk.write","kind":"ada_procedure","location":{"file":"src/io/bbs-sim_cpu-io-disk.ads","line":193,"column":14},"code":"procedure write(self : in out hd_ctrl; addr : addr_bus; data : data_bus)","documentation":{"description":"\n  Read from a port address","parameters":[{"name":"self","description":""},{"name":"addr","description":""},{"name":"data","description":""}]}}],"formals":[{"id":"94d56517395b8305","name":"sector_size","qualified_name":"BBS.Sim_CPU.io.disk.sector_size","kind":"ada_formal","location":{"file":"src/io/bbs-sim_cpu-io-disk.ads","line":23,"column":3},"code":"sector_size : Natural;"}]}