_Format","qualified_name":"Ada.Wide_Wide_Characters.Handling.Is_Other_Format","kind":"ada_function","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/0b5b32120df8a3ef486d57e8668a7b1b8eaeb4016de40c4c2ac49d41bc4ad171/gnat/a-zchhan.ads","line":93,"column":13},"code":"function Is_Other_Format (Item : Wide_Wide_Character) return Boolean","documentation":{"description":"Returns True if the Wide_Wide_Character designated by Item is\ncategorized as other_format, otherwise returns false.","parameters":[{"name":"Item","description":""}]}},{"id":"256bdd0fdb4d3357","name":"Is_Punctuation_Connector","qualified_name":"Ada.Wide_Wide_Characters.Handling.Is_Punctuation_Connector","kind":"ada_function","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/0b5b32120df8a3ef486d57e8668a7b1b8eaeb4016de40c4c2ac49d41bc4ad171/gnat/a-zchhan.ads","line":98,"column":13},"code":"function Is_Punctuation_Connector\n  (Item : Wide_Wide_Character) return Boolean","documentation":{"description":"Returns True if the Wide_Wide_Character designated by Item is\ncategorized as punctuation_connector, otherwise returns false.","parameters":[{"name":"Item","description":""}]}},{"id":"351907cd37928df0","name":"Is_Space","qualified_name":"Ada.Wide_Wide_Characters.Handling.Is_Space","kind":"ada_function","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/0b5b32120df8a3ef486d57e8668a7b1b8eaeb4016de40c4c2ac49d41bc4ad171/gnat/a-zchhan.ads","line":104,"column":13},"code":"function Is_Space (Item : Wide_Wide_Character) return Boolean","documentation":{"description":"Returns True if the Wide_Wide_Character designated by Item is\ncategorized as separator_space, otherwise returns false.","parameters":[{"name":"Item","description":""}]}},{"id":"a59d5e2706fe1be9","name":"Is_Special","qualified_name":"Ada.Wide_Wide_Characters.Handling.Is_Special","kind":"ada_function","location":{"