o_Basic","kind":"ada_function","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/0b5b32120df8a3ef486d57e8668a7b1b8eaeb4016de40c4c2ac49d41bc4ad171/gnat/a-zchhan.ads","line":152,"column":13},"code":"function To_Basic (Item : Wide_Wide_String) return Wide_Wide_String","documentation":{"description":"Returns the result of applying the To_Basic conversion to each\nWide_Wide_Character element of the Wide_Wide_String designated by Item.\nThe result is the null Wide_Wide_String if the value of the formal\nparameter is the null Wide_Wide_String. The lower bound of the result\nWide_Wide_String is 1.","parameters":[{"name":"Item","description":""}]}},{"id":"2f26f22a56f353a6","name":"To_Lower","qualified_name":"Ada.Wide_Wide_Characters.Handling.To_Lower","kind":"ada_function","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/0b5b32120df8a3ef486d57e8668a7b1b8eaeb4016de40c4c2ac49d41bc4ad171/gnat/a-zchhan.ads","line":120,"column":13},"code":"function To_Lower (Item : Wide_Wide_Character) return Wide_Wide_Character","documentation":{"description":"Returns the Simple Lowercase Mapping of the Wide_Wide_Character\ndesignated by Item. If the Simple Lowercase Mapping does not exist for\nthe Wide_Wide_Character designated by Item, then the value of Item is\nreturned.","parameters":[{"name":"Item","description":""}]}},{"id":"9ee81b240f41577a","name":"To_Lower","qualified_name":"Ada.Wide_Wide_Characters.Handling.To_Lower","kind":"ada_function","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/0b5b32120df8a3ef486d57e8668a7b1b8eaeb4016de40c4c2ac49d41bc4ad171/gnat/a-zchhan.ads","line":127,"column":13},"code":"function To_Lower (Item : Wide_Wide_String) return Wide_Wide_String","documentation":{"description":"Returns the result of applying the To_Lower Wide_Wide_Character to\nWide_Wide_Character conversion to each element of the Wide_Wide_String\ndesignated by Item. The result is the null Wide_Wide_String if the value\nof the formal parameter is the null Wide_Wide_String.","parameters":[{"name":"Item","description":""}]}},{"id":"2c0ec15145c5d591","name":"To_Upper","qualified_name":"Ada.Wide_Wide_Characters.Handling.To_Upper","kind":"ada_function","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/0b5b32120df8a3ef486d57e8668a7b1b8eaeb4016de40c4c2ac49d41bc4ad171/gnat/a-zchhan.ads","line":133,"column":13},"code":"function To_Upper (Item : Wide_Wide_Character) return Wide_Wide_Character","documentation":{"description":"Returns the Simple Uppercase Mapping of the Wide_Wide_Character\ndesignated by Item. If the Simple Uppercase Mapping does not exist for\nthe Wide_Wide_Character designated by Item, then the value of Item is\nreturned.","parameters":[{"name":"Item","description":""}]}},{"id":"cf25d15a9f31b07b","name":"To_Upper","qualified_name":"Ada.Wide_Wide_Characters.Handling.To_Upper","kind":"ada_function","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/0b5b32120df8a3ef486d57e8668a7b1b8eaeb4016de40c4c2ac49d41bc4ad171/gnat/a-zchhan.ads","line":140,"column":13},"code":"function To_Upper (Item : Wide_Wide_String) return Wide_Wide_String","documentation":{"description":"Returns the result of applying the To_Upper Wide_Wide_Character to\nWide_Wide_Character conversion to each element of the Wide_Wide_String\ndesignated by Item. The result is the null Wide_Wide_String if the value\nof the formal parameter is the null Wide_Wide_String.","parameters":[{"name":"Item","description":""}]}}]}