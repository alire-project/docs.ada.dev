aracters.Handling.Is_Hexadecimal_Digit","kind":"ada_function","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/0b5b32120df8a3ef486d57e8668a7b1b8eaeb4016de40c4c2ac49d41bc4ad171/gnat/a-zchhan.ads","line":61,"column":13},"code":"function Is_Hexadecimal_Digit (Item : Wide_Wide_Character) return Boolean","documentation":{"description":"Returns True if the Wide_Wide_Character designated by Item is\ncategorized as number_decimal, or is in the range 'A' .. 'F' or\n'a' .. 'f', otherwise returns false.","parameters":[{"name":"Item","description":""}]}},{"id":"5b6db10e3bdc9982","name":"Is_Letter","qualified_name":"Ada.Wide_Wide_Characters.Handling.Is_Letter","kind":"ada_function","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/0b5b32120df8a3ef486d57e8668a7b1b8eaeb4016de40c4c2ac49d41bc4ad171/gnat/a-zchhan.ads","line":30,"column":13},"code":"function Is_Letter (Item : Wide_Wide_Character) return Boolean","documentation":{"description":"Returns True if the Wide_Wide_Character designated by Item is\ncategorized as letter_uppercase, letter_lowercase, letter_titlecase,\nletter_modifier, letter_other, or number_letter. Otherwise returns\nfalse.","parameters":[{"name":"Item","description":""}]}},{"id":"6d1134c15d7bcedd","name":"Is_Line_Terminator","qualified_name":"Ada.Wide_Wide_Characters.Handling.Is_Line_Terminator","kind":"ada_function","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/0b5b32120df8a3ef486d57e8668a7b1b8eaeb4016de40c4c2ac49d41bc4ad171/gnat/a-zchhan.ads","line":80,"column":13},"code":"function Is_Line_Terminator (Item : Wide_Wide_Character) return Boolean","documentation":{"description":"Returns True if the Wide_Wide_Character designated by Item is\ncategorized as separator_line or separator_paragraph, or if Item is a\nconventional line terminator character (CR, LF, VT, or FF). Otherwise\nreturns false.","parameters":[{"