"file":"../../../../home/runner/.local/share/alire/builds/gnatcoll_minimal_26.0.0_cc5dd0a1/d137b4ee70b6031ff2799d79fd7375d2fb07b14760e1adabd5016578ac166b27/minimal/src/gnatcoll-refcount-weakref.ads","line":76,"column":7},"code":"Null_Ref : constant Ref := Pointers.Null_Ref;"},{"id":"0c9a9bda00a0da9b","name":"Null_Weak_Ref","qualified_name":"GNATCOLL.Refcount.Weakref.Weakref_Pointers.Null_Weak_Ref","kind":"ada_constant","location":{"file":"../../../../home/runner/.local/share/alire/builds/gnatcoll_minimal_26.0.0_cc5dd0a1/d137b4ee70b6031ff2799d79fd7375d2fb07b14760e1adabd5016578ac166b27/minimal/src/gnatcoll-refcount-weakref.ads","line":91,"column":7},"code":"Null_Weak_Ref : constant Weak_Ref := Weak_Ref (Proxy_Pointers.Null_Ref);"}],"subprograms":[{"id":"9e864bf2f30e5d24","name":"\"=\"","qualified_name":"GNATCOLL.Refcount.Weakref.Weakref_Pointers.\"=\"","kind":"ada_function","location":{"file":"../../../../home/runner/.local/share/alire/builds/gnatcoll_minimal_26.0.0_cc5dd0a1/d137b4ee70b6031ff2799d79fd7375d2fb07b14760e1adabd5016578ac166b27/minimal/src/gnatcoll-refcount-weakref.ads","line":86,"column":16},"code":"function \"=\" (P1, P2 : Pointers.Encapsulated_Access) return Boolean","documentation":{"description":"The manipulation of the smart pointers","parameters":[{"name":"P1","description":""},{"name":"P2","description":""}]}},{"id":"c8d7651180f9128c","name":"\"=\"","qualified_name":"GNATCOLL.Refcount.Weakref.Weakref_Pointers.\"=\"","kind":"ada_function","location":{"file":"../../../../home/runner/.local/share/alire/builds/gnatcoll_minimal_26.0.0_cc5dd0a1/d137b4ee70b6031ff2799d79fd7375d2fb07b14760e1adabd5016578ac166b27/minimal/src/gnatcoll-refcount-weakref.ads","line":84,"column":16},"code":"function \"=\" (P1, P2 : Ref) return Boolean","documentation":{"description":"The manipulation of the smart pointers","parameters":[{"name":"P1","description":""},{"name":"P2","description":""}]}},{"id":"a410ab79552fb8da","name":"\"=\"","qualified_name":"GNATCOLL.Refcount.Weakref.Weakref_Pointers.\"=\"","kind":"ada_function","location":{"file":"../../../../home/runner/.local/share/alire/builds/gnatcoll_minimal_26.0.0_cc5dd0a1/d137b4ee70b6031ff2799d79fd7375d2fb07b14760e1adabd5016578ac166b27/minimal/src/gnatcoll-refcount-weakref.ads","line":92,"column":16},"code":"function \"=\" (P1, P2 : Weak_Ref) return Boolean"},{"id":"df72de3faf29509d","name":"Get","qualified_name":"GNATCOLL.Refcount.Weakref.Weakref_Pointers.Get","kind":"ada_function","location":{"file":"../../../../home/runner/.local/share/alire/builds/gnatcoll_minimal_26.0.0_cc5dd0a1/d137b4ee70b6031ff2799d79fd7375d2fb07b14760e1adabd5016578ac166b27/minimal/src/gnatcoll-refcount-weakref.ads","line":82,"column":16},"code":"function Get (P : Ref) return Encapsulated_Access","documentation":{"description":"The manipulation of the smart pointers","parameters":[{"name":"P","description":""}]}},{"id":"e26acf0964ad1e4c","name":"Get","qualified_name":"GNATCOLL.Refcount.Weakref.Weakref_Pointers.Get","kind":"ada_function","location":{"file":"../../../../home/runner/.local/share/alire/builds/gnatcoll_minimal_26.0.0_cc5dd0a1/d137b4ee70b6031ff2799d79fd7375d2fb07b14760e1adabd5016578ac166b27/minimal/src/gnatcoll-refcount-weakref.ads","line":108,"column":16},"code":"function Get (Self : Weak_Ref'Class) return Ref","documentation":{"description":"Return the weakly referenced object. This will return Null_Ref\nif the object has already been destroyed.\nThe procedure version can be used if you have subclassed Ref.\nThe code should look like:\n\n    --  Create the smart pointer\n    Tmp : Refcounted_Access := new My_Refcounted_Type;\n    R   : Ref := Allocate (Tmp);  --  Hold a ref to Tmp\n\n    WRef := Get_Weak_Ref (R);  -- Does not hold a ref to Tmp\n\n    R := Null_Ref;   --  Releases ref to Tmp, and free Tmp\n    we now have Get (WRef) = null\n\nIn the case of a multitasking application, you must write your code\nso that the referenced type is not freed while you are using it. For\ninstance:\n    declare\n       R : constant Ref := Get (WRef);  --  hold a ref to Tmp\n    begin\n       if R /= Null_Ref then\n           ... manipulate R\n           Tmp cannot be freed while in the declare block, since we\n           own a reference to it\n       end if;\n    end;","parameters":[{"name":"Self","description":""}]}},{"id":"26e299b93da7a30f","name":"Get","qualified_name":"GNATCOLL.Refcount.Weakref.Weakref_Pointers.Get","kind":"ada_procedure","location":{"file":"../../../../home/runner/.local/share/alire/builds/gnatcoll_minimal_26.0.0_cc5dd0a1/d137b4ee70b6031ff2799d79fd7375d2fb07b14760e1adabd5016578ac166b27/minimal/src/gnatcoll-refcount-weakref.ads","line":109,"column":17},"code":"procedure Get (Self : Weak_Ref'Class; R : out Ref'Class)","documentation":{"description":"Return the weakly referenced object. This will return Null_Ref\nif the object has already been destroyed.\nThe procedure version can be used if you have subclassed Ref.\nThe code should look like:\n\n    --  Create the smart pointer\n    Tmp : Refcounted_Access := new My_Refcounted_Type;\n    R   : Ref := Allocate (Tmp);  --  Hold a ref to Tmp\n\n    WRef := Get_Weak_Ref (R);  -- Does not hold a ref to Tmp\n\n    R := Null_Ref;   --  Releases ref to Tmp, and free Tmp\n    we now have Get (WRef) = null\n\nIn the case of a multitasking application, you must write your code\nso that the referenced type is not freed while you are using it. For\ninstance:\n    declare\n       R : constant Ref := Get (WRef);  --  hold a ref to Tmp\n    begin\n       if R /= Null_Ref then\n           ... manipulate R\n           Tmp cannot be freed while in the declare block, since we\n           own a reference to it\n       end if;\n    end;","parameters":[{"name":"Self","description":""},{"name":"R","description":""}]}},{"id":"0002c4407f892b64","name":"Get_Weak_Ref","qualified_name":"GNATCOLL.Refcount.Weakref.Weakref_Pointers.Get_Weak_Ref","kind":"ada_function","location":{"file":"../../../../home/runner/.local/share/alire/builds/gnatcoll_minimal_26.0.0_cc5dd0a1/d137b4ee70b6031ff2799d79fd7375d2fb07b14760e1adabd5016578ac166b27/minimal/src/gnatcoll-refcount-weakref.ads","line":95,"column":16},"code":"function Get_Weak_Ref (Self : Ref'Class) return Weak_Ref","documentation":{"description":"Return a weak reference to Self.\nIt does not hold a reference to Self, which means that Self could be\ndestroyed while the weak reference exists. However, this will not\nresult\nin a Storage_Error when you access the reference.","parameters":[{"name":"Self","description":""}]}},{"id":"2eb80e492e2ade17","name":"Set","qualified_name":"GNATCOLL.Refcount.Weakref.Weakref_Pointers.Set","kind":"ada_procedure","location":{"file":"../../../../home/runner/.local/share/alire/builds/gnatcoll_minimal_26.0.0_cc5dd0a1/d137b4ee70b6031ff2799d79fd7375d2fb07b14760e1adabd5016578ac166b27/minimal/src/gnatcoll-refcount-weakref.ads","line":80,"column":17},"code":"procedure Set (Self : in out Ref; Data : access Encapsulated'Class)","documentation":{"description":"The manipulation of the smart pointers","parameters":[{"name":"Self","description":""},{"name":"Data","description":""}]}},{"id":"b6cc709c1cedc1a1","name":"Set","qualified_name":"GNATCOLL.Refcount.Weakref.Weakref_Pointers.Set","kind":"ada_procedure","location":{"file":"../../../../home/runner/.local/share/alire/builds/gnatcoll_minimal_26.0.0_cc5dd0a1/d137b4ee70b6031ff2799d79fd7375d2fb07b14760e1adabd5016578ac166b27/minimal/src/gnatcoll-refcount-weakref.ads","line":78,"column":17},"code":"procedure Set (Self : in out Ref; Data : Encapsulated'Class)","documentation":{"description":"The manipulation of the smart pointers","parameters":[{"name":"Self","description":""},{"name":"Data","description":""}]}},{"id":"309facc93ef84b1a","name":"Was_Freed","qualified_name":"GNATCOLL.Refcount.Weakref.Weakref_Pointers.Was_Freed","kind":"ada_function","location":{"file":"../../../../home/runner/.local/share/alire/builds/gnatcoll_minimal_26.0.0_cc5dd0a1/d137b4ee70b6031ff2799d79fd7375d2fb07b14760e1adabd5016578ac166b27/minimal/src/gnatcoll-refcount-weakref.ads","line":102,"column":16},"code":"function Was_Freed (Self : Weak_Ref'Class) return Boolean","documentation":{"description":"True if the weakly referenced element was freed (thus Get would\nreturn Null_Ref). It is more efficient to use this function than\ncompare the result of Get with Null_Ref, since the latter will need\nto play with refcounting.","parameters":[{"name":"Self","description":""}]}}],"generic_instantiations":[{"id":"6220135c0910f4ac","name":"Pointers","qualified_name":"GNATCOLL.Refcount.Weakref.Weakref_Pointers.Pointers","kind":"ada_package_instantiation","location":{"file":"../../../../home/runner/.local/share/alire/builds/gnatcoll_minimal_26.0.0_cc5dd0a1/d137b4ee70b6031ff2799d79fd7375d2fb07b14760e1adabd5016578ac166b27/minimal/src/gnatcoll-refcount-weakref.ads","line":72,"column":15},"code":"package Pointers is new Smart_Pointers (Encapsulated);"}],"formals":[{"id":"96b903369518e047","name":"Encapsulated","qualified_name":"GNATCOLL.Refcount.Weakref.Weakref_Pointers.Encapsulated","kind":"ada_formal","location":{"file":"../../../../home/runner/.local/share/alire/builds/gnatcoll_minimal_26.0.0_cc5dd0a1/d137b4ee70b6031ff2799d79fd7375d2fb07b14760e1adabd5016578ac166b27/minimal/src/gnatcoll-refcount-weakref.ads","line":70,"column":12},"code":"type Encapsulated is abstract new Weak_Refcounted with private;"}]}