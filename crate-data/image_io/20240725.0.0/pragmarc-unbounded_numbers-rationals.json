"kind":"ada_function","location":{"file":"../../../home/runner/.local/share/alire/builds/pragmarc_20240323.0.0_31d8919a/e70a8c739ac58c125da41ab4417fc0154dea7b33835cea0fd59dd11d63775117/src/pragmarc-unbounded_numbers-rationals.ads","line":30,"column":13},"code":"function Compose (Numerator : in Integers.Unbounded_Integer; Denominator : in Integers.Unbounded_Integer) return Rational","documentation":{"description":"Creates the value Numerator / Denominator","parameters":[{"name":"Numerator","description":""},{"name":"Denominator","description":""}]}},{"id":"703c8af60d37c5e5","name":"Decompose","qualified_name":"PragmARC.Unbounded_Numbers.Rationals.Decompose","kind":"ada_procedure","location":{"file":"../../../home/runner/.local/share/alire/builds/pragmarc_20240323.0.0_31d8919a/e70a8c739ac58c125da41ab4417fc0154dea7b33835cea0fd59dd11d63775117/src/pragmarc-unbounded_numbers-rationals.ads","line":34,"column":14},"code":"procedure Decompose\n   (Value : in Rational; Numerator : out Integers.Unbounded_Integer; Denominator : out Integers.Unbounded_Integer)","documentation":{"description":"Returns the Numerator and Denominator that make up Value\nThe sign of Value will be in Numerator; Denominator will be positive","parameters":[{"name":"Value","description":""},{"name":"Numerator","description":""},{"name":"Denominator","description":""}]}},{"id":"b4293dcc0b0f037d","name":"Image","qualified_name":"PragmARC.Unbounded_Numbers.Rationals.Image","kind":"ada_function","location":{"file":"../../../home/runner/.local/share/alire/builds/pragmarc_20240323.0.0_31d8919a/e70a8c739ac58c125da41ab4417fc0154dea7b33835cea0fd59dd11d63775117/src/pragmarc-unbounded_numbers-rationals.ads","line":58,"column":13},"code":"function Image\n   (Value : in Rational; As_Fraction : in Boolean := False; Base : in Base_Number := 10; Decorated : in Boolean := False)\nreturn String","documentation":{"description":"Returns the image of Value\nIf As_Fraction, result is in the format Numerator/Denominator; otherwise, result is in the format of a real literal\nNo initial blank for non-negative values\nIf Decorated, the image includes the base in numeric-literal format: 16#FFFFFFFFFFFFFFFFFFFFFFFF#/16#7#, 2#1.1#\nIf not As_Fraction\n   if abs Value < 1.0, result will have at most 1,000 significant digits\n   otherwise, result will have at most 1,000 digits to the right of the radix point","parameters":[{"name":"Value","description":""},{"name":"As_Fraction","description":""},{"name":"Base","description":""},{"name":"Decorated","description":""}]}},{"id":"24cf477a63f10ef1","name":"Value","qualified_name":"PragmARC.Unbounded_Numbers.Rationals.Value","kind":"ada_function","location":{"file":"../../../home/runner/.local/share/alire/builds/pragmarc_20240323.0.0_31d8919a/e70a8c739ac58c125da41ab4417fc0154dea7b33835cea0fd59dd11d63775117/src/pragmarc-unbounded_numbers-rationals.ads","line":69,"column":13},"code":"function Value (Image : in String) return Rational","documentation":{"description":"Image must be one of:\n   Equivalent to a result of calling function Image, possibly with leading or trailing spaces\n   The image of an integer literal (9876543210)\n   The image of a real literal (9.87654321)\nif Image is in a base other than 10, Image must be decorated\nLetters may be upper or lower case\nRaises Constraint_Error if Image is invalid","parameters":[{"name":"Image","description":""}]}}]}