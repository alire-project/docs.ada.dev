s Item'Length (if\nTrim_Nul is False) or the length of the slice of Item preceding the\nfirst nul (if Trim_Nul is True). The lower bound of the result is 1.\nIf Trim_Nul is False, then for each component Item(I) the corresponding\ncomponent in the result is To_Ada applied to Item(I). If Trim_Nul\nis True, then for each component Item(I) before the first nul the\ncorresponding component in the result is To_Ada applied to Item(I). The\nfunction propagates Terminator_Error if Trim_Nul is True and Item does\nnot contain nul.","parameters":[{"name":"Item","description":""},{"name":"Trim_Nul","description":""}]}},{"id":"14dcf24eaf9ae294","name":"To_Ada","qualified_name":"Interfaces.C.To_Ada","kind":"ada_function","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/bdea63aefd2c9f503503d03ddcc8ea23c3dca8fb74694724dfc6a305bb8a89de/gnat/i-c.ads","line":298,"column":13},"code":"function To_Ada\n  (Item     : wchar_array;\n   Trim_Nul : Boolean := True) return Wide_String"},{"id":"4479d322817dc875","name":"To_Ada","qualified_name":"Interfaces.C.To_Ada","kind":"ada_function","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/bdea63aefd2c9f503503d03ddcc8ea23c3dca8fb74694724dfc6a305bb8a89de/gnat/i-c.ads","line":257,"column":13},"code":"function To_Ada (Item : wchar_t) return Wide_Character"},{"id":"489cec19aa520fe5","name":"To_Ada","qualified_name":"Interfaces.C.To_Ada","kind":"ada_procedure","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/bdea63aefd2c9f503503d03ddcc8ea23c3dca8fb74694724dfc6a305bb8a89de/gnat/i-c.ads","line":458,"column":14},"code":"procedure To_Ada\n  (Item     : char16_array;\n   Target   : out Wide_String;\n   Count    : out Natural;\n   Trim_Nul : Boolean := True)"},{"id":"ca1b91fbd412b71e","name":"To_Ada","qualified_name":"Interfaces.C.To_Ada","kind":"ada_procedure","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/bdea63aefd2c9f503503d03ddcc8ea23c3dca8fb74694724dfc6a305bb8a89de/gnat/i-c.ads","line":578,"column":14},"code":"procedure To_Ada\n  (Item     : char32_array;\n   Target   : out Wide_Wide_String;\n   Count    : out Natural;\n   Trim_Nul : Boolean := True)"},{"id":"3e51e829b145d676","name":"To_Ada","qualified_name":"Interfaces.C.To_Ada","kind":"ada_procedure","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/bdea63aefd2c9f503503d03ddcc8ea23c3dca8fb74694724dfc6a305bb8a89de/gnat/i-c.ads","line":212,"column":14},"code":"procedure To_Ada\n  (Item     : char_array;\n   Target   : out String;\n   Count    : out Natural;\n   Trim_Nul : Boolean := True)","documentation":{"description":"For procedure To_Ada, each element of Item (if Trim_Nul is False) or\neach element of Item preceding the first nul (if Trim_Nul is True) is\nconverted (via the To_Ada function) to a Character, which is assigned\nto the corresponding element of Target. Count is set to the number of\nTarget elements assigned. If Target is not long enough, Constraint_Error\nis propagated. If Trim_Nul is True and Item does not contain nul, then\nTerminator_Error is propagated.","parameters":[{"name":"Item","description":""},{"name":"Target","description":""},{"name":"Count","description":""},{"name":"Trim_Nul","description":""}]}},{"id":"7cc85146cf8b7f08","name":"To_Ada","qualified_name":"Interfaces.C.To_Ada","kind":"ada_procedure","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/bdea63aefd2c9f503503d03ddcc8ea23c3dca8fb74694724dfc6a305bb8a89de/gnat/i-c.ads","line":333,"column":14},"code":"procedure To_Ada\n  (Item     : wchar_array;\n   Target   : out Wide_String;\n   Count    : out Natural;\n   Trim_Nul : Boolean := True)"},{"id":"336e1250b8d2595a","name":"To_C","qualified_name":"Interfaces.C.To_C","kind":"ada_function","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/bdea63aefd2c9f503503d03ddcc8ea23c3dca8fb74694724dfc6a305bb8a89de/gnat/i-c.ads","line":116,"column":13},"code":"function To_C (Item : Character) return char"},{"id":"06ea23a82368804e","name":"To_C","qualified_name":"Interfaces.C.To_C","kind":"ada_function","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/bdea63aefd2c9f503503d03ddcc8ea23c3dca8fb74694724dfc6a305bb8a89de/gnat/i-c.ads","line":145,"column":13},"code":"function To_C\n  (Item       : String;\n   Append_Nul : Boolean := True) return char_array","documentation":{"description":"The result of To_C is a char_array value of length Item'Length (if\nAppend_Nul is False) or Item'Length+1 (if Append_Nul is True). The lower\nbound is 0. For each component Item(I), the corresponding component\nin the result is To_C applied to Item(I). The value nul is appended if\nAppend_Nul is True. If Append_Nul is False and Item'Length is 0, then\nTo_C propagates Constraint_Error.","parameters":[{"name":"Item","description":""},{"name":"Append_Nul","description":""}]}},{"id":"b2b8461f08a9eda9","name":"To_C","qualified_name":"Interfaces.C.To_C","kind":"ada_function","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/bdea63aefd2c9f503503d03ddcc8ea23c3dca8fb74694724dfc6a305bb8a89de/gnat/i-c.ads","line":370,"column":13},"code":"function To_C (Item : Wide_Character) return char16_t"},{"id":"7d811f61fbe5accd","name":"To_C","qualified_name":"Interfaces.C.To_C","kind":"ada_function","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/bdea63aefd2c9f503503d03ddcc8ea23c3dca8fb74694724dfc6a305bb8a89de/gnat/i-c.ads","line":253,"column":13},"code":"function To_C (Item : Wide_Character) return wchar_t"},{"id":"9ed8da589f1724b5","name":"To_C","qualified_name":"Interfaces.C.To_C","kind":"ada_function","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/bdea63aefd2c9f503503d03ddcc8ea23c3dca8fb74694724dfc6a305bb8a89de/gnat/i-c.ads","line":407,"column":13},"code":"function To_C\n  (Item       : Wide_String;\n   Append_Nul : Boolean := True) return char16_array"},{"id":"933c3caa4dfcbd0e","name":"To_C","qualified_name":"Interfaces.C.To_C","kind":"ada_function","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/bdea63aefd2c9f503503d03ddcc8ea23c3dca8fb74694724dfc6a305bb8a89de/gnat/i-c.ads","line":286,"column":13},"code":"function To_C\n  (Item       : Wide_String;\n   Append_Nul : Boolean := True) return wchar_array"},{"id":"76a9683bdd7d450f","name":"To_C","qualified_name":"Interfaces.C.To_C","kind":"ada_function","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/bdea63aefd2c9f503503d03ddcc8ea23c3dca8fb74694724dfc6a305bb8a89de/gnat/i-c.ads","line":490,"column":13},"code":"function To_C (Item : Wide_Wide_Character) return char32_t"},{"id":"19dccb8d551f4609","name":"To_C","qualified_name":"Interfaces.C.To_C","kind":"ada_function","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/bdea63aefd2c9f503503d03ddcc8ea23c3dca8fb74694724dfc6a305bb8a89de/gnat/i-c.ads","line":527,"column":13},"code":"function To_C\n  (Item       : Wide_Wide_String;\n   Append_Nul : Boolean := True) return char32_array"},{"id":"81293cce64624ff4","name":"To_C","qualified_name":"Interfaces.C.To_C","kind":"ada_procedure","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/bdea63aefd2c9f503503d03ddcc8ea23c3dca8fb74694724dfc6a305bb8a89de/gnat/i-c.ads","line":188,"column":14},"code":"procedure To_C\n  (Item       : String;\n   Target     : out char_array;\n   Count      : out size_t;\n   Append_Nul : Boolean := True)","documentation":{"description":"For procedure To_C, each element of Item is converted (via the To_C\nfunction) to a char, which is assigned to the corresponding element of\nTarget. If Append_Nul is True, nul is then assigned to the next element\nof Target. In either case, Count is set to the number of Target elements\nassigned. If Target is not long enough, Constraint_Error is propagated.","parameters":[{"name":"Item","description":""},{"name":"Target","description":""},{"name":"Count","description":""},{"name":"Append_Nul","description":""}]}},{"id":"13215cde8c8c4408","name":"To_C","qualified_name":"Interfaces.C.To_C","kind":"ada_procedure","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/bdea63aefd2c9f503503d03ddcc8ea23c3dca8fb74694724dfc6a305bb8a89de/gnat/i-c.ads","line":438,"column":14},"code":"procedure To_C\n  (Item       : Wide_String;\n   Target     : out char16_array;\n   Count      : out size_t;\n   Append_Nul : Boolean := True)"},{"id":"f9e5c5dfba319062","name":"To_C","qualified_name":"Interfaces.C.To_C","kind":"ada_procedure","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/bdea63aefd2c9f503503d03ddcc8ea23c3dca8fb74694724dfc6a305bb8a89de/gnat/i-c.ads","line":314,"column":14},"code":"procedure To_C\n  (Item       : Wide_String;\n   Target     : out wchar_array;\n   Count      : out size_t;\n   Append_Nul : Boolean := True)"},{"id":"24868c87957dd48a","name":"To_C","qualified_name":"Interfaces.C.To_C","kind":"ada_procedure","location":{"file":"../../../home/runner/.local/share/alire/builds/embedded_rp2040_15.3.0_860ea34a/bdea63aefd2c9f503503d03ddcc8ea23c3dca8fb74694724dfc6a305bb8a89de/gnat/i-c.ads","line":558,"column":14},"code":"procedure To_C\n  (Item       : Wide_Wide_String;\n   Target     : out char32_array;\n   Count      : out size_t;\n   Append_Nul : Boolean := True)"}]}