{"schema_version":"1","crate":"pico_ada_c02_button_and_led","version":"1.5.1","id":"2c1229cb36ec7e84","name":"RP.PIO.Touch_Sense","qualified_name":"RP.PIO.Touch_Sense","kind":"ada_package","location":{"file":"../../../home/runner/.local/share/alire/builds/rp2040_hal_2.7.1_d65f4ed4/9b6861bafb32bdb17239cabbcda7bad9e24b3883ca0ec42f68b7656bc709d803/src/drivers/rp-pio-touch_sense.ads","line":8,"column":9},"code":"package RP.PIO.Touch_Sense","documentation":{"description":"Capacitive touch sensing is based on change in capacitance typically\nintroduced by the contact or proximity of the user finger(s) with a\npin.\n\nUsing PIO, any RP2040 pin connected to ground (or 3.3v) through a large\nresistor (e.g. 1Mohm) can be a capacitive touch sensor.\n\nTwo measure modes are available: Charge or Discharge\n\nIn Discharge mode (Default): Connect the pin to ground through a\nlarge resistor. The PIO program will charge the internal pin capacitor\nby configuring the pin as an output and set it high for a few\nmicroseconds. And then set the pin as an input and count how many\ncycles it takes for the capacitor to discharge through the resistor.\n\nIn Charge mode: Connect the pin to 3.3v through a large resistor. The\nPIO program will discharge the internal pin capacitor by configuring\nthe pin as an output and set it low for a few microseconds. And then\nset the pin as an input and count how many cycles it takes for the\ncapacitor to charge through the resistor.\n\nIf users touch the pin, the capacitance will increase and therefore the\nnumber of cycles it takes to discharge/charge will increase as well."},"simple_types":[{"id":"fa54062bcde46412","name":"Touch_Mode","qualified_name":"RP.PIO.Touch_Sense.Touch_Mode","kind":"ada_simple_type","location":{"file":"../../../home/runner/.local/share/alire/builds/rp2040_hal_2.7.1_d65f4ed4/9b6861bafb32bdb17239cabbcda7bad9e24b3883ca0ec42f68b7656bc709d803/src/drivers/rp-pio-touch_sense.ads","line":35,"column":9},"code":"type Touch_Mode is (Discharge, Charge);","documentation":{"description":"Measure either capacitive discharge time (Pin pulled down) or\ncapacitive charge time (pin pulled up).","enumeration_literals":[{"name":"Discharge","description":""},{"name":"Charge","description":""}]}}],"tagged_types":[{"id":"481eb7ea03922884","name":"Touch_Sensor","qualified_name":"RP.PIO.Touch_Sense.Touch_Sensor","kind":"ada_tagged_type","location":{"file":"../../../home/runner/.local/share/alire/builds/rp2040_hal_2.7.1_d65f4ed4/9b6861bafb32bdb17239cabbcda7bad9e24b3883ca0ec42f68b7656bc709d803/src/drivers/rp-pio-touch_sense.ads","line":39,"column":9},"code":"type Touch_Sensor\n  (Pin : not null access RP.GPIO.GPIO_Point;\n   PIO : not null access PIO_Device;\n   SM  : PIO_SM)\nis tagged private;","dispatching_declared":[{"qualified_name":"RP.PIO.Touch_Sense.Initialize","id":"c54c413501b9fcdb","unit":"rp-pio-touch_sense"},{"qualified_name":"RP.PIO.Touch_Sense.Initialized","id":"0dbc6a14c8e97b96","unit":"rp-pio-touch_sense"},{"qualified_name":"RP.PIO.Touch_Sense.Raw_Value","id":"f51dc4ca7f37cc7d","unit":"rp-pio-touch_sense"},{"qualified_name":"RP.PIO.Touch_Sense.Set_Threshold","id":"ddbf11b451bc8575","unit":"rp-pio-touch_sense"},{"qualified_name":"RP.PIO.Touch_Sense.Threshold","id":"2fc696a36795583e","unit":"rp-pio-touch_sense"},{"qualified_name":"RP.PIO.Touch_Sense.Touch","id":"c69542002269343c","unit":"rp-pio-touch_sense"}],"prefix_callable_declared":[{"qualified_name":"RP.PIO.Touch_Sense.Initialize","id":"c54c413501b9fcdb","unit":"rp-pio-touch_sense"},{"qualified_name":"RP.PIO.Touch_Sense.Initialized","id":"0dbc6a14c8e97b96","unit":"rp-pio-touch_sense"},{"qualified_name":"RP.PIO.Touch_Sense.Raw_Value","id":"f51dc4ca7f37cc7d","unit":"rp-pio-touch_sense"},{"qualified_name":"RP.PIO.Touch_Sense.Set_Threshold","id":"ddbf11b451bc8575","unit":"rp-pio-touch_sense"},{"qualified_name":"RP.PIO.Touch_Sense.Threshold","id":"2fc696a36795583e","unit":"rp-pio-touch_sense"},{"qualified_name":"RP.PIO.Touch_Sense.Touch","id":"c6954200