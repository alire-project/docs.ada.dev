{"schema_version":"1","crate":"pico_ada_c03_led_bar","version":"1.5.1","id":"b8e6299cd076c9a8","name":"BBqueue","qualified_name":"BBqueue","kind":"ada_package","location":{"file":"../../../home/runner/.local/share/alire/builds/bbqueue_1.0.0_f508818c/6b55862f91826f221c65748131dccf10160914638d5e473d2ce80a83525080c9/src/bbqueue.ads","line":25,"column":9},"code":"package BBqueue","documentation":{"description":"Based on James Munns' https://github.com/jamesmunns/bbqueue\n\nBBqueue implements lock free, one producer one consumer, BipBuffers.\n\nThis unit only handles index offsets without having an internal buffer.\nIt can be used to allocate slices of an existing array, e.g.:\n\n   Buf : Storage_Array (8 .. 64) := (others => 0);\n   Q   : aliased Offsets_Only (Buf'Length);\n   WG  : Write_Grant := BBqueue.Empty;\n   S   : Slice_Rec;\nbegin\n   Grant (Q, WG, 8);\n   if State (WG) = Valid then\n      S := Slice (WG);\n      Buf (Buf'First + S.From .. Buf'First + S.To) := (others => 42);\n      Commit (Q, WG);\n   end if;"},"simple_types":[{"id":"9410fc0f68746bf3","name":"Offsets_Only","qualified_name":"BBqueue.Offsets_Only","kind":"ada_simple_type","location":{"file":"../../../home/runner/.local/share/alire/builds/bbqueue_1.0.0_f508818c/6b55862f91826f221c65748131dccf10160914638d5e473d2ce80a83525080c9/src/bbqueue.ads","line":38,"column":9},"code":"type Offsets_Only (Size : Buffer_Size) is limited private;"},{"id":"ff1d33f32f2bbf77","name":"Read_Grant","qualified_name":"BBqueue.Read_Grant","kind":"ada_simple_type","location":{"file":"../../../home/runner/.local/share/alire/builds/bbqueue_1.0.0_f508818c/6b55862f91826f221c65748131dccf10160914638d5e473d2ce80a83525080c9/src/bbqueue.ads","line":72,"column":9},"code":"type Read_Grant is limited private;"},{"id":"7971e6102120fbb6","name":"Result_Kind","qualified_name":"BBqueue.Result_Kind","kind":"ada_simple_type","location":{"file":"../../../home/runner/.local/share/alire/builds/bbqueue_1.0.0_f508818c/6b55862f91826f221c65748131dc