{"schema_version":"1","crate":"avrada_lib","version":"2.1.0","id":"bd2cf94ea36aef58","name":"AVR.Real_Time","qualified_name":"AVR.Real_Time","kind":"ada_package","location":{"file":"src/avr-real_time.ads","line":45,"column":9},"code":"package AVR.Real_Time","documentation":{"description":"The specification relies on a resolution for System.Duration being\nat least one millisecond = 0.001.  The AVR GNAT compiler is\npatched to provide a 32-bit wide type for duration that has a tick\nof at least one millisecond. Duration also spans at least 2 days\nso that day_duration'last + day_duration'last does not hit the\nupper limit of the base type duration.\n\nThe package is Pure since Clock is not part of  the specification.      --"},"simple_types":[{"id":"72dec888ce2327c0","name":"Day_Name","qualified_name":"AVR.Real_Time.Day_Name","kind":"ada_simple_type","location":{"file":"src/avr-real_time.ads","line":71,"column":9},"code":"type Day_Name is (Monday, Tuesday, Wednesday, Thursday,\n                  Friday, Saturday, Sunday);"},{"id":"43273668af7f1cf7","name":"Duration","qualified_name":"AVR.Real_Time.Duration","kind":"ada_simple_type","location":{"file":"src/avr-real_time.ads","line":53,"column":9},"code":"type Duration is delta 0.001 digits 9 range -24.0 * 3600.0 .. 48.0 * 3600.0;","documentation":{"description":"for Duration'Small use 0.001;"}},{"id":"7f9ae8c13c6af7bd","name":"Time","qualified_name":"AVR.Real_Time.Time","kind":"ada_simple_type","location":{"file":"src/avr-real_time.ads","line":48,"column":9},"code":"type Time is private;"}],"subtypes":[{"id":"b22304949e0a40b7","name":"Day_Duration","qualified_name":"AVR.Real_Time.Day_Duration","kind":"ada_subtype","location":{"file":"src/avr-real_time.ads","line":85,"column":12},"code":"subtype Day_Duration    is Duration              range 0.0 .. 86_400.0;"},{"id":"0e1856cc03a486ac","name":"Day_Number","qualified_name":"AVR.Real_Time.Day_Number","kind":"ada_subtype","location":{"file":"src/avr-real_time.ads","line":8