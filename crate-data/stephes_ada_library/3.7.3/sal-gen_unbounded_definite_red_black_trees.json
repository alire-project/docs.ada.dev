ck_Trees.Delete","kind":"ada_procedure","location":{"file":"../source/sal-gen_unbounded_definite_red_black_trees.ads","line":203,"column":14},"code":"procedure Delete (Tree : in out Pkg.Tree; Key : in Key_Type)","documentation":{"description":"Delete element with Key.\n\nRaises SAL.Not_Found if Key is not found.\n\nInvalidates any active iterators; not enforced.","parameters":[{"name":"Tree","description":""},{"name":"Key","description":""}]}},{"id":"81338c3f87733929","name":"Direction","qualified_name":"SAL.Gen_Unbounded_Definite_Red_Black_Trees.Direction","kind":"ada_function","location":{"file":"../source/sal-gen_unbounded_definite_red_black_trees.ads","line":76,"column":13},"code":"function Direction (Cursor : in Pkg.Cursor) return Direction_Type"},{"id":"6c5ae6f756da6885","name":"Element","qualified_name":"SAL.Gen_Unbounded_Definite_Red_Black_Trees.Element","kind":"ada_function","location":{"file":"../source/sal-gen_unbounded_definite_red_black_trees.ads","line":78,"column":13},"code":"function Element (Cursor : in Pkg.Cursor) return Element_Type"},{"id":"6be9ea11b728364d","name":"Finalize","qualified_name":"SAL.Gen_Unbounded_Definite_Red_Black_Trees.Finalize","kind":"ada_procedure","location":{"file":"../source/sal-gen_unbounded_definite_red_black_trees.ads","line":55,"column":25},"code":"procedure Finalize (Object : in out Tree)"},{"id":"46ea5389b6624f7c","name":"Find","qualified_name":"SAL.Gen_Unbounded_Definite_Red_Black_Trees.Find","kind":"ada_function","location":{"file":"../source/sal-gen_unbounded_definite_red_black_trees.ads","line":136,"column":13},"code":"function Find\n  (Iterator  : in Pkg.Iterator;\n   Key       : in Key_Type;\n   Direction : in Direction_Type := Ascending)\n  return Cursor","documentation":{"description":"Has_Element is False if Key is not in Container.","parameters":[{"name":"Iterator","description":""},{"name":"Key","description":""},{"name":"Direction","description":""}]}},{"id":"36bf0bd20bb2c571","name":"Find","qualified_name":"SAL.Gen_Unbounded_Definite_Red_Black_Trees.Find","kind":"ada_function","location":{"file":"../source/sal-gen_unbounded_definite_red_black_trees.ads","line":143,"column":13},"code":"function Find\n  (Container : in Tree;\n   Key       : in Key_Type;\n   Direction : in Direction_Type := Ascending)\n  return Cursor","documentation":{"description":"Creates an Iterator internally.","parameters":[{"name":"Container","description":""},{"name":"Key","description":""},{"name":"Direction","description":""}]}},{"id":"9ceaf0f21da208b5","name":"Find_In_Range","qualified_name":"SAL.Gen_Unbounded_Definite_Red_Black_Trees.Find_In_Range","kind":"ada_function","location":{"file":"../source/sal-gen_unbounded_definite_red_black_trees.ads","line":150,"column":13},"code":"function Find_In_Range\n  (Iterator    : in Pkg.Iterator;\n   Direction   : in Known_Direction_Type;\n   First, Last : in Key_Type)\n  return Cursor","documentation":{"description":"Find first element with key in range First .. Last. If Direction\nis Ascending, start at First, otherwise start at Last.\n\nHas_Element (result) is False if there is no such element.\n\nThe Iterator does not remember First, Last; the user must check\nthose for any element that Next or Previous returns.","parameters":[{"name":"Iterator","description":""},{"name":"Direction","description":""},{"name":"First","description":""},{"name":"Last","description":""}]}},{"id":"1aff10c6761a9c73","name":"Find_Or_Insert","qualified_name":"SAL.Gen_Unbounded_Definite_Red_Black_Trees.Find_Or_Insert","kind":"ada_function","location":{"file":"../source/sal-gen_unbounded_definite_red_black_trees.ads","line":194,"column":13},"code":"function Find_Or_Insert\n  (Tree    : in out Pkg.Tree;\n   Element : in     Element_Type;\n   Found   :    out Boolean)\n  return Cursor","documentation":{"description":"Search for Element; if found, Found is True. If not found, insert\nit. Return a Cursor to the found or inserted element. , and return\na cursor for it.","paramete